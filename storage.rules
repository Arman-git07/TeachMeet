
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read/write for all authenticated users for simplicity during development.
    // In a production app, you would want to tighten these rules.
    match /{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}
