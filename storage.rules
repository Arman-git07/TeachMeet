rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This is a permissive rule for development. It allows any authenticated
    // user to read and write any file in Firebase Storage.
    // This is necessary to prevent permission errors while building features.
    // WARNING: Before deploying to production, you MUST write more secure rules
    // to protect your users' data.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
