rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read and write access to all storage files for any authenticated user.
    // This is suitable for development but should be replaced with more
    // restrictive rules before launching to production.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
