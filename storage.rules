rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isClassCreator(classId) {
      let classroomDoc = get(/databases/(default)/documents/classrooms/$(classId));
      return isSignedIn() && 
        (classroomDoc.data.creatorId == request.auth.uid || 
         classroomDoc.data.createdBy == request.auth.uid ||
         classroomDoc.data.teacherId == request.auth.uid);
    }
    
    function isClassParticipant(classId) {
        return isSignedIn() && exists(/databases/(default)/documents/classrooms/$(classId)/participants/$(request.auth.uid));
    }

    function isTeacher(classId) {
        let participantDoc = get(/databases/(default)/documents/classrooms/$(classId)/participants/$(request.auth.uid));
        return isClassParticipant(classId) && participantDoc.data.role == 'teacher';
    }

    function isTeacherOrCreator(classId) {
        return isClassCreator(classId) || isTeacher(classId);
    }

    // General user documents
    match /documents/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Classroom specific files
    match /classrooms/{classId}/{allPaths=**} {
      // Teachers/Creators can write anything.
      // Enrolled participants can read anything.
      allow read: if isClassParticipant(classId);
      allow write: if isTeacherOrCreator(classId);
    }

    // Student assignment submissions need special write rule for students
    match /classrooms/{classId}/assignments/{assignmentId}/{studentId}/{fileName} {
      allow write: if isSignedIn() && request.auth.uid == studentId;
    }
    
    // User avatars
    match /avatars/{userId}/{allPaths=**} {
        allow read;
        allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
