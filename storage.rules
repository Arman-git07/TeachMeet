
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // For development, allow read/write access to all authenticated users.
    // In production, you MUST secure your data properly.
    // Example: allow read, write: if request.auth != null;
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
