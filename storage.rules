rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // WARNING: These rules are permissive and are intended for development purposes only.
    // They allow any authenticated user to upload, download, and delete any file.
    // Before launching your application, you must write more granular and secure rules.
    // For example, you might want to restrict uploads to certain file types or sizes,
    // or ensure users can only access their own files.
    //
    // For more information, see the Firebase Security Rules documentation:
    // https://firebase.google.com/docs/storage/security/get-started

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
