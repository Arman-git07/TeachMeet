rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This rule allows any authenticated user to read and write all files.
    // WARNING: This is permissive and not recommended for production.
    // You should secure your data with more granular rules.
    // For example, only allow users to upload to their own folder:
    // match /avatars/{userId}/{allPaths=**} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
