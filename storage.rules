rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
    
    // Allow authenticated users to upload their own avatars.
    // Max size: 5MB
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Allow users to read their own and public files in the documents folder.
    match /documents/{userId}/{access}/{fileName} {
      allow read: if access == 'public' || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId 
                   && request.resource.size < 25 * 1024 * 1024; // 25MB limit
    }

    // Allow users to read their own and public files in the recordings folder.
     match /recordings/{userId}/{access}/{fileName} {
      allow read: if access == 'public' || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 200 * 1024 * 1024; // 200MB limit
    }

    // Allow public read access to all avatars, documents, and recordings
    // This simplifies linking to files. Write access is still restricted above.
    match /{folder}/{userId}/{access}/{fileName} 
      where folder in ['avatars', 'documents', 'recordings'] {
      allow read: if true;
    }
  }
}
