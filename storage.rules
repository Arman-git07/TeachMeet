
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow users to upload to their own private or public folders.
    match /documents/{userId}/{privacy}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow read access to public documents for anyone.
    match /documents/{userId}/public/{fileName} {
      allow read: if true;
    }
    
    // Only allow the uploader to read their private documents.
    match /documents/{userId}/private/{fileName} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to upload to their own recording folders.
    match /recordings/{userId}/{privacy}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow read access to public recordings.
    match /recordings/{userId}/public/{fileName} {
       allow read: if true;
    }

    // Only allow the uploader to read their private recordings.
    match /recordings/{userId}/private/{fileName} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to upload their own avatar.
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true; // Avatars are public
    }
  }
}
