
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Rules for user avatars
    // Anyone can read avatars (they are public profile images)
    // Only the authenticated user can write to their own avatar path
    match /avatars/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for documents and recordings
    // The path contains the destination (public/private)
    match /{collection}/{userId}/{destination}/{fileName} where collection in ['documents', 'recordings'] {
      // A user can only write to their own folder structure.
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow read access if the destination is 'public'
      // OR if the user is reading from their own private folder.
      allow read: if destination == 'public' || (request.auth != null && request.auth.uid == userId && destination == 'private');
      
      // Only the owner can delete their files.
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
