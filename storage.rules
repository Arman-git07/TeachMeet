rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // User Avatars
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Classroom-specific files (e.g., materials, answer keys)
    // This rule is more permissive; it allows any authenticated user to write.
    // For tighter security, you would link this to a Firestore document.
    match /classrooms/{classroomId}/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null;
      // For delete, you'd ideally check ownership via a Firestore doc read,
      // but a simpler rule is to allow owner to delete. For that, we need the owner's UID in the path.
      // The current path doesn't enforce this. For now, allow authenticated deletes.
      allow delete: if request.auth != null;
    }

    // User-specific documents (private/public uploads)
    match /documents/{userId}/{allPaths=**} {
      allow read: if true; // URLs are unguessable
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // User-specific recordings
    match /recordings/{userId}/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
