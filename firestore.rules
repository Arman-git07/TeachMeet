
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // FCM Tokens: Allow users to write their own token
    match /fcmTokens/{userId} {
      allow read, write: isUser(userId);
    }

    // Meetings: Basic rules for meeting management
    match /meetings/{meetingId} {
      // Anyone signed in can create a meeting document
      allow create: isSignedIn();
      // Anyone signed in can read meeting details (e.g., to find the host)
      allow read: isSignedIn();
      // Allow host to update pending requests and add members
      allow update: isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      // Participants subcollection
      match /participants/{participantId} {
        // A user can only manage their own participant document
        allow read, write, delete: isUser(participantId);
      }
    }
    
    // Teachings: Corrected and simplified rules
    match /teachings/{teachingId} {
      // Any authenticated user can read all teachings.
      // Client-side code will filter what to display.
      allow read: isSignedIn();
      
      // Allow creation if the user is the creator and in the members list.
      allow create: isSignedIn()
                    && request.resource.data.creatorId == request.auth.uid
                    // Must be a member of your own class
                    && request.auth.uid in request.resource.data.members;

      // Allow updates for various scenarios.
      allow update: isSignedIn() && (
        // Creator can update title, description, isPublic status
        (resource.data.creatorId == request.auth.uid &&
          request.resource.data.title == request.resource.data.title &&
          request.resource.data.description == request.resource.data.description &&
          request.resource.data.isPublic == request.resource.data.isPublic
        ) ||
        // Any user can add their own ID to pendingRequests
        (request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])) ||
        // The creator can approve a request (move from pending to members)
        (resource.data.creatorId == request.auth.uid &&
          request.resource.data.members.hasAny(resource.data.pendingRequests) &&
          request.resource.data.pendingRequests.size() < resource.data.pendingRequests.size()
        ) ||
        // The creator can deny a request (remove from pending)
        (resource.data.creatorId == request.auth.uid &&
          request.resource.data.pendingRequests.size() < resource.data.pendingRequests.size()
        )
      );
        
      // Only the creator can delete the teaching.
      allow delete: isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    // Documents: Users can manage their own, and view public ones.
    match /documents/{documentId} {
      allow read: isSignedIn() && (resource.data.isPrivate == false || isUser(resource.data.uploaderId));
      allow create: isSignedIn() && isUser(request.resource.data.uploaderId);
      allow delete: isSignedIn() && isUser(resource.data.uploaderId);
    }

    // Recordings: Users can manage their own, and view public ones.
    match /recordings/{recordingId} {
      allow read: isSignedIn() && (resource.data.isPrivate == false || isUser(resource.data.uploaderId));
      allow create: isSignedIn() && isUser(request.resource.data.uploaderId);
      allow delete: isSignedIn() && isUser(resource.data.uploaderId);
    }
  }
}
