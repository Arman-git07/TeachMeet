
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isClassroomCreator(classroomId) {
      return isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
    }
    function isClassroomMember(classroomId) {
      let classroom = get(/databases/$(database)/documents/classrooms/$(classroomId)).data;
      return isUser(request.auth.uid) && (
        request.auth.uid in classroom.students ||
        request.auth.uid in classroom.teachers ||
        isClassroomCreator(classroomId)
      );
    }
    
    // Public User Profiles
    match /users/{userId} {
      allow read;
      allow create, update: if isUser(userId);
      
      // User's private subcollections
      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if isUser(userId);
      }
      match /enrolled/{classroomId} {
        allow read, write, delete: if isUser(userId);
      }
    }

    // Public Documents & Recordings
    match /documents/{documentId} {
      allow get: if resource.data.isPrivate == false;
      allow list: if false; // List only for owners via collectionGroup query
      allow create, update, delete: if isAuth() && resource.data.uploaderId == request.auth.uid;
    }
    match /recordings/{recordingId} {
      allow get: if resource.data.isPrivate == false;
      allow list: if false;
      allow create, update, delete: if isAuth() && resource.data.uploaderId == request.auth.uid;
    }

    // Classrooms
    match /classrooms/{classroomId} {
      allow read: if isAuth(); // Allow any authenticated user to read basic classroom data
      allow create: if isAuth() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isClassroomCreator(classroomId) || 
                      (isAuth() && request.auth.uid in resource.data.teachers.map(t => t.uid));
      allow delete: if isClassroomCreator(classroomId);

      // Classroom Subcollections
      match /announcements/{announcementId} {
        allow read: if isClassroomMember(classroomId);
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid && isClassroomMember(classroomId);
        allow delete: if isAuth() && (isClassroomCreator(classroomId) || resource.data.authorId == request.auth.uid);
      }
      match /materials/{materialId} {
        allow read: if isClassroomMember(classroomId);
        allow create: if isAuth() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isAuth() && (isClassroomCreator(classroomId) || resource.data.uploaderId == request.auth.uid);
      }
      match /assignments/{assignmentId} {
        allow read: if isClassroomMember(classroomId);
        allow create, update, delete: if isClassroomCreator(classroomId) ||
                                       (isAuth() && request.auth.uid in getAfter(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers.map(t => t.uid));
        
        match /submissions/{studentId} {
          allow read: if isUser(studentId) || isClassroomCreator(classroomId);
          allow create, update: if isUser(studentId);
          allow delete: if isClassroomCreator(classroomId);
        }
      }
      match /exams/{examId} {
        allow read: if isClassroomMember(classroomId);
        allow create, update, delete: if isClassroomCreator(classroomId);
      }
      match /joinRequests/{userId} {
        allow read: if isClassroomCreator(classroomId);
        allow create: if isUser(userId) && request.resource.data.requesterId == userId;
        allow delete: if isClassroomCreator(classroomId) || isUser(userId);
      }
       match /participants/{userId} {
        allow read: if isClassroomMember(classroomId);
        allow create, delete: if isClassroomCreator(classroomId);
      }
       match /teachers/{teacherId} {
        allow read: if isClassroomMember(classroomId);
        allow create, delete: if isClassroomCreator(classroomId);
      }
    }
    
    // Meetings
    match /meetings/{meetingId} {
      allow read, create, update: if isAuth();
      // Allow host to delete the meeting
      allow delete: if isAuth() && resource.data.hostId == request.auth.uid;

      // Join requests for this meeting
      match /joinRequests/{userId} {
        allow read, update, delete: if isAuth() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        allow create: if isUser(userId);
      }

      // Participants in this meeting
      match /participants/{userId} {
        allow read, write: if isAuth();
        allow delete: if isAuth() && (isUser(userId) || get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid);
      }
    }
  }
}
