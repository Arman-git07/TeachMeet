/**
 * @description This ruleset enforces a strict authentication-based access control model for meetings and associated data.
 * All read and write operations require a valid authenticated user. Schema validation is relaxed to facilitate rapid prototyping.
 * @dataStructure
 * - /meetings/{meetingId}: Stores meeting metadata.
 * - /meetings/{meetingId}/joinRequests/{requestId}: Stores requests from users to join a specific meeting.
 * - /meetings/{meetingId}/participants/{userId}: Stores a list of users that are participating in a meeting.
 * - /classrooms/{classroomId}/joinRequests/{userId}: Stores requests from users to join a specific classroom.
 * - /classrooms/{classroomId}/participants/{userId}: Stores a list of users that are participating in a classroom.
 * @keySecurityDecisions
 * - All operations require authentication.
 * - Data shape validation is relaxed for prototyping. Only authorization-critical fields are validated.
 * - The host user is not explicitly validated in the rules; all authenticated users have read/write access to meeting resources.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the top-level 'meetings' collection.
     * @path /meetings/{meetingId}
     * @allow (read) Any authenticated user can read meeting data.
     * @allow (create) Any authenticated user can create a meeting.
     * @allow (update) Any authenticated user can update a meeting.
     * @allow (delete) Any authenticated user can delete a meeting.
     * @deny (create) An unauthenticated user cannot create a meeting.
     * @principle Authenticated users can manage meeting details.
     */
    match /meetings/{meetingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to the 'joinRequests' subcollection for meetings.
     * @path /meetings/{meetingId}/joinRequests/{requestId}
     * @allow (read) Any authenticated user can read join request data.
     * @allow (create) Any authenticated user can create a join request.
     * @allow (update) Any authenticated user can update a join request.
     * @allow (delete) Any authenticated user can delete a join request.
     * @deny (create) An unauthenticated user cannot create a join request.
     * @principle Authenticated users can manage join requests for meetings.
     */
    match /meetings/{meetingId}/joinRequests/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to the 'participants' subcollection for meetings.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (read) Any authenticated user can read participant data.
     * @allow (create) Any authenticated user can create a participant entry.
     * @allow (update) Any authenticated user can update a participant entry.
     * @allow (delete) Any authenticated user can delete a participant entry.
     * @deny (create) An unauthenticated user cannot create a participant entry.
     * @principle Authenticated users can manage meeting participants.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

      /**
     * @description Controls access to the 'joinRequests' subcollection for classrooms.
     * @path /classrooms/{classroomId}/joinRequests/{userId}
     * @allow (read) Any authenticated user can read join request data.
     * @allow (create) Any authenticated user can create a join request.
     * @allow (update) Any authenticated user can update a join request.
     * @allow (delete) Any authenticated user can delete a join request.
     * @deny (create) An unauthenticated user cannot create a join request.
     * @principle Authenticated users can manage join requests for classrooms.
     */
       match /classrooms/{classroomId}/joinRequests/{userId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
      }

      /**
       * @description Controls access to the 'participants' subcollection for classrooms.
       * @path /classrooms/{classroomId}/participants/{userId}
       * @allow (read) Any authenticated user can read participant data.
       * @allow (create) Any authenticated user can create a participant entry.
       * @allow (update) Any authenticated user can update a participant entry.
       * @allow (delete) Any authenticated user can delete a participant entry.
       * @deny (create) An unauthenticated user cannot create a participant entry.
       * @principle Authenticated users can manage classroom participants.
       */
      match /classrooms/{classroomId}/participants/{userId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
      }

  }

  // Helper function to determine if a user is signed in
  function isSignedIn() {
    return request.auth != null;
  }
}