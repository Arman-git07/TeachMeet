rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings collection
    match /meetings/{meetingId} {
      // Host can create the meeting
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.hostId;

      // Anyone signed in can read meeting
      allow read: if request.auth != null;

      // Only host can update or delete
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.hostId;

      // Participants subcollection
      match /participants/{participantId} {
        // A user can create their own participant entry
        allow create: if request.auth != null
                      && request.auth.uid == participantId;

        // Signed-in users can read participants
        allow read: if request.auth != null;

        // User can update/delete only their own participant doc
        allow update, delete: if request.auth != null
                              && request.auth.uid == resource.data.uid;
      }
      
      // Join requests subcollection inside meetings
      match /joinRequests/{requestId} {
          allow create: if request.auth != null; // any signed-in user can send a join request
          allow read, update, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
    }
    
    // User data collections
    match /users/{userId}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classroom collections
    match /classrooms/{classroomId}/{document=**} {
        allow read, write: if request.auth != null; // Broad access for prototype
    }
    
    // Documents & Recordings
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    match /recordings/{recId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    // Fallback security rule - deny all other access
    match /{path=**}/documents/{wildcard} {
        allow read, write: if false;
    }
  }
}
