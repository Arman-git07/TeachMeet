rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings Collection
    match /meetings/{meetingId} {

      // A signed-in user can create a meeting document IF they set themselves as the host.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.hostId;

      // Any signed-in user can read meeting details.
      allow read: if request.auth != null;

      // Only the host can update or delete the meeting document.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Participants Subcollection
      match /participants/{participantId} {
        // A user can add themselves to the participants list.
        // A host can add any participant (needed for batch create).
        allow create: if request.auth != null;

        // Any signed-in user can see who is in the meeting.
        allow read: if request.auth != null;
        
        // A user can update/remove themselves. The host can also update/remove anyone.
        allow update, delete: if request.auth != null && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }
      
      // Join Requests Subcollection
      match /joinRequests/{userId} {
        // Any signed in user can request to join.
        allow create: if request.auth != null && request.auth.uid == userId;

        // Only the host can read/delete join requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }
    }

    // Classrooms Collection
    match /classrooms/{classroomId} {
      // Allow read for signed-in users, but create/update/delete only for the teacher/creator.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.teacherId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Subcollections within classrooms
      match /{subcollection}/{docId} {
        allow read: if request.auth != null; // General read access for subcollections
        allow write: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
       // More specific rule for submissions to allow students to write
      match /assignments/{assignmentId}/submissions/{studentId} {
        allow create, update: if request.auth != null && request.auth.uid == studentId;
        allow read: if request.auth != null;
      }
    }

    // Users Collection (for user-specific data)
    match /users/{userId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
     // Documents & Recordings collections
    match /(documents|recordings)/{docId} {
      // Public items can be read by anyone signed in.
      // Private items can only be read by the uploader.
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      
      // Allow creating documents for any signed-in user.
      allow create: if request.auth != null;
      
      // Allow update/delete only for the user who uploaded the item.
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    // Default deny all other access
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
