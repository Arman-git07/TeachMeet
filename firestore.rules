
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isTeacher(classroomId) {
      return isAuthenticated() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
    }
    function isEnrolled(classroomId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrolled/$(classroomId));
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isUser(userId);
    }
    
    // Rules for Classrooms collection
    match /classrooms/{classroomId} {
      allow create: if isAuthenticated() && request.resource.data.teacherId == request.auth.uid;
      allow read: if isAuthenticated(); // Allow any authenticated user to read class details (for discovery)
      allow update: if isTeacher(classroomId);
      allow delete: if isTeacher(classroomId);

      match /joinRequests/{userId} {
        allow create: if isUser(userId);
        allow read, delete: if isTeacher(classroomId);
      }
      
      match /announcements/{announcementId} {
        allow read: if isTeacher(classroomId) || isEnrolled(classroomId);
        allow create, update, delete: if isTeacher(classroomId);
      }
      
      match /materials/{materialId} {
         allow read: if isTeacher(classroomId) || isEnrolled(classroomId);
         allow create, update, delete: if isTeacher(classroomId);
      }
      
      match /exams/{examId} {
        allow read: if isTeacher(classroomId) || isEnrolled(classroomId);
        allow create, update, delete: if isTeacher(classroomId);
      }
      
      match /assignments/{assignmentId} {
        allow read: if isTeacher(classroomId) || isEnrolled(classroomId);
        allow create, update, delete: if isTeacher(classroomId);
        
        match /submissions/{studentId} {
           allow read: if isTeacher(classroomId) || isUser(studentId);
           allow create, update: if isUser(studentId);
           allow delete: if isTeacher(classroomId);
        }
      }
      
      match /teachers/{teacherId} {
        allow read: if isTeacher(classroomId) || isEnrolled(classroomId);
        allow create, update, delete: if isTeacher(classroomId);
      }
      
      match /chat/{messageId} {
        allow read, create: if isTeacher(classroomId) || isEnrolled(classroomId);
        // Deletion can be limited further if needed
        allow delete: if isTeacher(classroomId);
      }
    }

    // Rules for Meetings collection
    match /meetings/{meetingId} {
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;

      // Only added participants can read the meeting
      allow read: if isAuthenticated()
        && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));

      match /participants/{userId} {
        // Host or user themselves can create the participant document
        allow create: if isUser(userId)
          || (isAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);

        allow read: if isUser(userId) || exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));

        // Any approved participant can list participants
        allow list: if exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));

        allow update, delete: if isUser(userId) || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }

      match /joinRequests/{userId} {
        allow create: if isUser(userId);
        allow read, delete: if isAuthenticated()
          && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }
  }
}
