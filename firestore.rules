rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is signed in.
    function signedIn() {
      return request.auth != null;
    }

    // Meetings can be created by any authenticated user.
    // Only the meeting's host can update or delete it.
    // Any authenticated user can read meeting details (e.g., to get the topic).
    match /meetings/{meetingId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update, delete: if signedIn() && request.auth.uid == resource.data.hostId;

      // Participants can be added/removed only by the host of the meeting.
      // Any participant can read the list.
      match /participants/{participantId} {
        allow create, delete: if signedIn() && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
        allow read: if signedIn();
      }

      // Join requests can be created by any authenticated user.
      // The host of the meeting can read/update/delete requests.
      match /joinRequests/{requestId} {
        allow create: if signedIn();
        allow read, update, delete: if signedIn() && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }
    }
    
    // Classroom rules
    match /classrooms/{classroomId} {
      allow read;
      allow create: if signedIn();
      allow update, delete: if signedIn() && request.auth.uid == resource.data.teacherId || request.auth.uid == resource.data.createdBy;
      
      match /{subcollection}/{documentId} {
        allow read, write: if signedIn();
      }
      
      match /assignments/{assignmentId}/submissions/{submissionId} {
         allow read, write: if signedIn();
      }
    }

    // User-specific data can only be accessed by the user themselves.
    match /users/{userId}/{subcollection=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
     match /documents/{documentId} {
      allow read;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if signedIn() && request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recordingId} {
      allow read;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if signedIn() && request.auth.uid == resource.data.uploaderId;
    }
  }
}
