rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // WARNING: These rules are permissive and are intended for development purposes only.
    // They allow any authenticated user to read and write to any part of your database.
    // Before launching your application, you must write more granular and secure rules
    // to protect your users' data. For example, you might want to restrict writes
    // so users can only modify their own documents.
    //
    // For more information, see the Firebase Security Rules documentation:
    // https://firebase.google.com/docs/firestore/security/get-started
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
