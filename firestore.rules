rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings Collection Rules
    match /meetings/{meetingId} {
      // Host and authenticated users can read meetings
      allow read: if request.auth != null;

      // Any authenticated user can create a meeting
      allow create: if request.auth != null;

      // Update only if user is host
      allow update: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Only host can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Participants Subcollection Rules
      match /participants/{participantId} {
        allow read, create, update, delete: if request.auth != null
          && request.auth.uid == participantId;
      }
    }

    // Classroom Collection Rules (safe default)
    match /classrooms/{classroomId} {
      allow read: if resource.data.isPublic == true || request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
