rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings collection
    match /meetings/{meetingId} {
      // Any authenticated user can create or update a meeting
      allow create, update, read: if request.auth != null;
      allow delete: if request.auth != null;

      // Participants subcollection
      match /participants/{participantId} {
        // Any authenticated user can manage their own participant doc
        allow create, update, read, delete: if request.auth != null 
          && request.auth.uid == participantId;
      }
    }

    // Classroom collection
    match /classrooms/{classroomId} {
      // Public classrooms are readable by anyone
      allow read: if resource.data.isPublic == true;
      // Authenticated users can read non-public classrooms they are part of
      allow read: if request.auth != null && (
          request.auth.uid == resource.data.teacherId ||
          request.auth.uid in resource.data.students ||
          (exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid)))
      );
      
      // Only the teacher can create/update/delete the classroom
      allow create: if request.auth != null && request.auth.uid == request.resource.data.teacherId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Subcollections
      match /{subcollection}/{docId} {
        // Teacher/creator can do anything
        allow read, write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;

        // Students can read most things
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students;
        
        // Students can create submissions
        allow create: if request.auth != null 
                    && request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students
                    && subcollection == 'submissions';
      }
      
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request for themselves
        allow create: if request.auth != null && request.auth.uid == userId;
        // Teacher can read/delete requests
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // User-specific collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Document and Recording collections
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
       allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    // FCM tokens
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
