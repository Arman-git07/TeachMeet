rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    match /classrooms/{classroomId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == request.resource.data.teacherId;
      allow update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);

      match /announcements/{announcementId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if signedIn() && isOwner(resource.data.authorId);
      }
      
      match /materials/{materialId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if signedIn() && (isOwner(resource.data.uploaderId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId));
      }
      
      match /assignments/{assignmentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == request.resource.data.creatorId;
        allow update, delete: if signedIn() && isOwner(resource.data.creatorId);

        match /submissions/{submissionId} {
          allow read, create, update: if signedIn();
        }
      }

      match /exams/{examId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if signedIn() && isOwner(resource.data.authorId);
      }

      match /joinRequests/{requestId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == request.resource.data.requesterId;
        allow update: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        allow delete: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId || request.auth.uid == requestId;
      }

      match /participants/{participantId} {
        allow read: if signedIn();
        allow write: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        allow delete: if signedIn() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || request.auth.uid == participantId);
      }
      
       match /teachers/{teacherId} {
        allow read: if signedIn();
        allow write: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
    }
    
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if signedIn() && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
       allow create: if signedIn() && request.auth.uid == request.resource.data.uploaderId;
       allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
    match /meetings/{meetingId} {
      allow read, write; // Open for this prototype
      match /participants/{participantId} {
        allow read, write, delete; // Open for this prototype
      }
    }

    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
