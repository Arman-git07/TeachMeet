rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USER DATA: Only the user can read/write their own data.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Enrolled classrooms subcollection
      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // CLASSROOMS
    match /classrooms/{classroomId} {
      // Anyone can read public classrooms
      allow read: if resource.data.isPublic == true;

      // Only authenticated users can create classrooms
      allow create: if request.auth != null;

      // Only the teacher who created the class can update or delete it
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // JOIN REQUESTS for classrooms
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request for themselves
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // Only the classroom teacher can read or delete requests
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
    }
    
    // MEETINGS
    match /meetings/{meetingId} {
      // Allow read/write for authenticated users (e.g., creating the meeting doc)
      // More specific rules for subcollections below are better.
      allow read, write: if request.auth != null;

      // PARTICIPANTS in a meeting
      match /participants/{userId} {
        // A user can only manage their own participant document
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // JOIN REQUESTS for meetings
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request for themselves
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // The meeting creator (host) can read and delete requests
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }

    // DOCUMENTS and RECORDINGS: Use `request.resource.data` for create/update rules
    match /documents/{documentId} {
      allow create: if request.auth.uid == request.resource.data.uploaderId;
      allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
      allow update, delete: if resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recordingId} {
      allow create: if request.auth.uid == request.resource.data.uploaderId;
      allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
      allow update, delete: if resource.data.uploaderId == request.auth.uid;
    }
  }
}
