rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Teachings: Main collection for all classes
    match /teachings/{teachingId} {
      // Allow reading public teachings, or if user is the creator, or if they are in the allowedStudents list
      allow read: if resource.data.isPublic == true || (isSignedIn() && (resource.data.creatorId == request.auth.uid || request.auth.uid in resource.data.allowedStudents));

      // Allow creation if signed in and creatorId matches the user
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      
      // Allow updates if user is the creator
      // This includes adding/removing from pendingRequests and allowedStudents
      allow update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      // Allow deletion only by the creator
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    // User-specific subcollections
    match /users/{userId}/{collection}/{docId} {
      allow read, write, delete: if isOwner(userId);
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.creatorId);
      // Only the creator can update the main meeting document (e.g., topic, pendingRequests)
      allow update: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;

      match /participants/{participantId} {
        allow read: if isSignedIn();
        // A user can add themselves as a participant
        allow create: if isOwner(participantId);
        // A user can update their own status (mute, camera, etc.)
        allow update: if isOwner(participantId);
        // A user can remove themselves, or the host can remove them
        allow delete: if isOwner(participantId) || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }

    // Documents
    match /documents/{documentId} {
      // Read public docs, or if user is owner
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      // Create if signed in and uploaderId is correct
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      // Delete if owner
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/documents/$(documentId)).data.uploaderId == request.auth.uid;
    }

    // Recordings
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/recordings/$(recordingId)).data.uploaderId == request.auth.uid;
    }
    
    // FCM Tokens for notifications
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
