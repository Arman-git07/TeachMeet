rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read public classrooms and their own classrooms
    match /classrooms/{classId} {
      allow get: if resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.teacherId);
      allow list: if resource.data.isPublic == true;
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;

      // Rules for join requests within a classroom
      match /joinRequests/{userId} {
        // Allow any authenticated user to create a request for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;
        // Only the teacher of the classroom can read/delete requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId;
      }
    }

    match /users/{userId} {
      // Allow users to manage their own user document.
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to manage their own enrolled list.
      match /enrolled/{classroomId} {
          allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /documents/{documentId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && resource.data.uploaderId == request.auth.uid);
       allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
       allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && resource.data.uploaderId == request.auth.uid);
       allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
       allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
    
    match /meetings/{meetingId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
      
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == participantId;
        allow update: if request.auth != null && request.auth.uid == participantId;
      }
    }
    
     match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
