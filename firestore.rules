
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Classrooms: Only authenticated users can manage their own classrooms.
    // Students and other teachers are handled by subcollections.
    match /classrooms/{classroomId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.teacherId);
      allow update: if signedIn() && isOwner(resource.data.teacherId);
      allow delete: if signedIn() && isOwner(resource.data.teacherId);

      // Anyone signed in can request to join
      match /joinRequests/{userId} {
        allow read, create: if signedIn();
        // Only the classroom owner/creator can approve/deny (delete) requests
        allow delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

      // Participants: Only classroom owner can add/remove participants.
      // Participants can read their own entry.
      match /participants/{userId} {
         allow read: if signedIn();
         allow write, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      // Teachers: Can be managed by the classroom owner.
      match /teachers/{userId} {
        allow read: if signedIn();
        allow write, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

      // Any authenticated member of the classroom can access these subcollections
      match /{subcollection}/{documentId} {
        allow read, write: if signedIn();
      }
    }
    
    // Meetings: Any signed-in user can create one. Only the host can manage it.
    match /meetings/{meetingId} {
      allow read: if signedIn();
      // Allow creation if the user is authenticated and is setting themselves as the host.
      allow create: if signedIn() && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.hostId == request.auth.uid;
      
      // Participants:
      // Allow anyone to read the list.
      // Allow the host to add/remove participants.
      match /participants/{participantId} {
        allow read: if signedIn();
        allow write, delete: if signedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
      
      // Join Requests:
      // Allow anyone to create a request to join.
      // Allow the host to read and delete (approve/deny) requests.
      match /joinRequests/{requestId} {
        allow create: if signedIn();
        allow read, delete: if signedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
    }

    // Users: Users can only manage their own profile data.
    match /users/{userId} {
      allow read, create, update, delete: if signedIn() && isOwner(userId);
      
       match /enrolled/{classroomId} {
         allow read, write, delete: if signed-in() && isOwner(userId);
       }
       match /pendingJoinRequests/{classroomId} {
         allow read, write, delete: if signedIn() && isOwner(userId);
       }
    }
    
    // Documents & Recordings: Users manage their own, but can see public ones.
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || (signedIn() && isOwner(resource.data.uploaderId));
      allow create: if signedIn();
      allow update, delete: if signedIn() && isOwner(resource.data.uploaderId);
    }

    match /recordings/{recId} {
      allow read: if resource.data.isPrivate == false || (signedIn() && isOwner(resource.data.uploaderId));
      allow create: if signedIn();
      allow update, delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
    // FCM Tokens for notifications
    match /fcmTokens/{userId} {
      allow write: if signedIn() && isOwner(userId);
    }
  }
}
