
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isCreator(resourceId) {
      return get(/databases/$(database)/documents/meetings/$(resourceId)).data.creatorId == request.auth.uid;
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to manage their own data
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for meetings collection
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && isCreator(meetingId);
      allow delete: if isAuthenticated() && isCreator(meetingId);

      // Rules for participants subcollection
      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == participantId;
        allow update: if isAuthenticated() && (request.auth.uid == participantId || isCreator(meetingId));
        allow delete: if isAuthenticated() && (request.auth.uid == participantId || isCreator(meetingId));
      }
    }
    
    // Rules for documents collection
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (isAuthenticated() && resource.data.uploaderId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }

    // Rules for recordings collection
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (isAuthenticated() && resource.data.uploaderId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
    
    // Rules for classrooms and their subcollections
    match /classrooms/{classroomId} {
      allow read: if resource.data.isPublic == true || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.teacherId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;
      
      // Rules for join requests
      match /joinRequests/{userId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid || request.auth.uid == userId);
      }
      
      // Rules for various sub-collections like announcements, materials, etc.
      match /{subCollection}/{docId} {
         allow read: if isAuthenticated(); // Allow any authenticated user to read content within a classroom
         // Write access should be more specific per sub-collection if needed
         allow write: if isAuthenticated() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
    }
    
     // Rules for fcmTokens
    match /fcmTokens/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
