rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings
    match /meetings/{meetingId} {
      // meeting exists, anyone signed-in can read
      allow read: if request.auth != null;

      // host creates/updates/deletes the meeting
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;

      // participants subcollection: each user manages only their own doc
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && request.auth.uid == participantId;
      }

      // joinRequests subcollection
      match /joinRequests/{requestId} {
        // participant creates their own request
        // requestId must be the user's UID
        allow create: if request.auth != null
                      && request.auth.uid == requestId
                      && request.resource.data.requestingUserId == request.auth.uid;

        // participant can read ONLY their request
        allow read: if request.auth != null
                    && resource.data.requestingUserId == request.auth.uid;

        // host can read/update/delete ALL requests for this meeting
        allow read, update, delete: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }
    }
    
    // Classroom Collection Rules
    match /classrooms/{classroomId} {
        // Default to denying all reads and writes unless specified below
        allow read, write: if false;
    }


    // deny everything else
    match /{document=**} { allow read, write: if false; }
  }
}
