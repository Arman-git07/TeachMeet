
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users can read/write their own data in the 'users' collection.
    match /users/{userId} {
      allow read, write: if isUser(userId);
      
      // Users can only manage their own subcollections.
      match /{subcollection}/{docId} {
         allow read, write: if isUser(userId);
      }
    }

    // Rules for the 'classrooms' collection
    match /classrooms/{classroomId} {
      // Any authenticated user can create a classroom.
      allow create: if isAuthenticated();
      
      // Public classrooms are readable by any authenticated user.
      // Private classrooms are readable only by the teacher.
      allow read: if isAuthenticated() && (resource.data.isPublic == true || resource.data.teacherId == request.auth.uid);
      
      // Only the teacher can update or delete their own classroom.
      allow update, delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;

      // Rules for classroom subcollections
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request for themselves.
        allow create: if isUser(userId);
        // Only the teacher of the classroom can read/delete join requests.
        allow read, delete: if isAuthenticated() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
      // Allow enrolled students and teachers to read content.
      // Allow only teachers to create/update/delete content.
      match /{contentCollection}/{docId}
        where contentCollection in ['announcements', 'materials', 'assignments'] {
        
        // Check if the user is enrolled in the class.
        function isEnrolled() {
           return exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrolled/$(classroomId));
        }
        function isTeacher() {
          return get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        }
        
        allow read: if isAuthenticated() && (isTeacher() || isEnrolled());
        allow write: if isAuthenticated() && isTeacher();
      }
    }
    
    // Optimized query for a user to find all their pending join requests across all classrooms.
    match /{path=**}/joinRequests/{userId} {
        allow read: if isUser(userId);
    }
    
    // Meetings: Documents are temporary and can be created by any authenticated user.
    match /meetings/{meetingId} {
      allow create: if isAuthenticated();
      // Only the creator (host) can update/delete the meeting document itself.
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
      // Allow participants to read the meeting once they're approved
      allow read: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid))
      );

      match /participants/{userId} {
        allow create: if isUser(userId);
        allow read: if isUser(userId);
        // Any user who is a participant can see the list of other participants.
        allow list: if isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
        // A user can update their own status (mute, camera off, etc.) or delete their document to leave.
        allow update, delete: if isUser(userId);
      }
      
      match /joinRequests/{userId} {
        allow create: if isUser(userId);
        // Only the host can read/delete join requests for their meeting.
        allow read, delete: if isAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }
    
    // Documents & Recordings
    match /{collection}/{docId} 
      where collection in ['documents', 'recordings'] {
      // Any authenticated user can upload (create) a document/recording.
      allow create: if isAuthenticated();
      // A user can read/delete their own documents/recordings.
      // They can also read any document/recording that is not private.
      allow read, delete: if (isAuthenticated() && resource.data.uploaderId == request.auth.uid) || resource.data.isPrivate == false;
      // Only the owner can update the metadata.
      allow update: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
  }
}
