rules_version = '2';

// See: https://firebase.google.com/docs/rules/rules-and-auth
// for more information on how to secure your app
service cloud.firestore {
  match /databases/{database}/documents {
  
    // =================================================================
    // General Rules
    // =================================================================
    
    // Deny all reads/writes by default.
    // This is a good practice to prevent unintended data access.
    match /{document=**} {
      allow read, write: if false;
    }

    // =semicolon
    
    // =================================================================
    // User Profiles
    // =================================================================

    // Users can read their own profile.
    // Users can update their own profile.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users can read/write their own subcollections (like enrolled classes).
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =================================================================
    // Meetings
    // =================================================================

    // Any authenticated user can create a new meeting room.
    // The `hostId` in the new document MUST be their own user ID.
    match /meetings/{meetingId} {
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
      
      // Allow read/update/delete only for the user who is the host of the meeting.
      // This is checked against the `hostId` field stored in the document.
      allow read, update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;

      // Participants & Join Requests Subcollections
      match /{collection}/{docId} {
        // The host can read/write anything (e.g., admit/deny requests).
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        
        // Authenticated users can create their own join requests or add themselves as participants.
        // The document ID they are creating must match their own user ID.
        allow create: if request.auth != null && docId == request.auth.uid;
        
        // Authenticated users can read the general participants list.
        allow list: if request.auth != null;
      }
    }
    
    // =================================================================
    // Classrooms
    // =================================================================
    
    match /classrooms/{classroomId} {
      // Anyone can view a public classroom's details.
      allow read: if resource.data.isPublic == true;
      
      // The creator/teacher can update or delete their own classroom.
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
      
      // Any authenticated user can create a classroom.
      allow create: if request.auth != null;

      // Subcollections within classrooms.
      match /{subcollection}/{documentId} {
        // The classroom creator can manage all subcollection documents.
        allow read, write, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;

        // Any authenticated user can create join requests.
        allow create: if request.auth != null && subcollection == 'joinRequests';
      }
    }
    
    // =================================================================
    // Documents & Recordings (Library items)
    // =================================================================

    match /documents/{documentId} {
      // Allow read if the document is public.
      allow get: if resource.data.isPrivate == false;
      // Allow read/write/delete for the owner.
      allow read, write, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
      // Allow list (query) for any authenticated user. They will be filtered on the client.
      allow list: if request.auth != null;
      // Any authenticated user can upload (create) a document.
      allow create: if request.auth != null;
    }

    match /recordings/{recordingId} {
      // Allow read if the recording is public.
      allow get: if resource.data.isPrivate == false;
      // Allow read/write/delete for the owner.
      allow read, write, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
       // Allow list (query) for any authenticated user. They will be filtered on the client.
      allow list: if request.auth != null;
      // Any authenticated user can upload (create) a recording.
      allow create: if request.auth != null;
    }
    
  }
}
