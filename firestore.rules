rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /meetings/{meetingId} collection.
     * @path /meetings/{meetingId}
     * @allow (read, write) User with UID matching the meeting's `hostId` can read and write.
     *        Example: User with UID "host123" can read/write a meeting document where `resource.data.hostId == 'host123'`.
     * @allow (get, list) Any signed-in user can read meeting data.
     *        Example: A signed-in user with UID "participant456" can `get()` a meeting document.
     * @deny (create, update, delete) Non-hosts cannot create, update, or delete meetings.
     *       Example: User "participant456" cannot `update()` a meeting document where `resource.data.hostId != 'participant456'`.
     * @principle Enforces meeting ownership and allows any signed-in user to read the meeting document.
     */
    match /meetings/{meetingId} {
      // isSignedIn helper function
      function isSignedIn() {
        return request.auth != null;
      }

      // isOwner helper function
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // isExistingOwner helper function
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      // ✅ allow the host to read/write their own meeting
      allow read, write: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;

      // ✅ allow any signed-in user to read a meeting doc so they can send join requests
      allow get, list: if isSignedIn();

      allow create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    /**
     * @description Rules for the /meetings/{meetingId}/joinRequests/{requestId} subcollection.
     * @path /meetings/{meetingId}/joinRequests/{requestId}
     * @allow (create) Signed-in user can create a join request with their UID as the `userId`.
     *        Example: User "participant456" can `create()` a join request document where `request.resource.data.userId == 'participant456'`.
     * @allow (read, update, delete) The meeting host can read, update, and delete join requests.
     *        Example: User "host123" (the host) can `read()` a join request under their meeting.
     * @deny (read, update, delete) Non-hosts cannot read, update, or delete join requests.
     *       Example: User "participant456" cannot `read()` a join request under a meeting they don't host.
     * @principle  Allows participants to request joining and the host to manage those requests.
     */
    match /meetings/{meetingId}/joinRequests/{requestId} {
      // isSignedIn helper function
      function isSignedIn() {
        return request.auth != null;
      }

      // isOwner helper function
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // isExistingOwner helper function
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      // ✅ participant can create their own request
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // ✅ host can read/update (approve/deny)
      allow read, update, delete: if isSignedIn() &&
          get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    /**
     * @description Rules for the /meetings/{meetingId}/participants/{userId} subcollection.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (read, write) The host and the participant can read/write the participant data.
     *        Example: The host "host123" can `read()` participant data.
     *        Example: The participant "participant456" can `read()` their own participant data.
     * @deny (read, write) Other users cannot read/write participant data.
     *       Example: User "other789" cannot `read()` participant data of "participant456" without being the host.
     * @principle  Allows the host and the participant themself to manage participant data.
     */
    match /meetings/{meetingId}/participants/{participantId} {
      // isSignedIn helper function
      function isSignedIn() {
        return request.auth != null;
      }

      // isOwner helper function
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // isExistingOwner helper function
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow read, write: if isSignedIn() &&
          (
            // host
            get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid ||
            // participant editing their own record
            request.auth.uid == participantId
          );
    }
    /**
     * @description Rules for the /classrooms/{classroomId}/joinRequests/{userId} subcollection.
     * @path /classrooms/{classroomId}/joinRequests/{userId}
     * @allow (create) Signed-in user can create a join request with their UID as the `userId`.
     *        Example: User "participant456" can `create()` a join request document where `request.resource.data.userId == 'participant456'`.
     * @allow (read, update, delete) The meeting host can read, update, and delete join requests.
     *        Example: User "host123" (the host) can `read()` a join request under their meeting.
     * @deny (read, update, delete) Non-hosts cannot read, update, or delete join requests.
     *       Example: User "participant456" cannot `read()` a join request under a meeting they don't host.
     * @principle  Allows participants to request joining and the host to manage those requests.
     */
    match /classrooms/{classroomId}/joinRequests/{userId} {
      // isSignedIn helper function
      function isSignedIn() {
        return request.auth != null;
      }

      // isOwner helper function
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // isExistingOwner helper function
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      // ✅ participant can create their own request
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // ✅ host can read/update (approve/deny)
      allow read, update, delete: if isSignedIn() &&
          get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId == request.auth.uid;
    }
    /**
     * @description Rules for the /classrooms/{classroomId}/participants/{userId} subcollection.
     * @path /classrooms/{classroomId}/participants/{userId}
     * @allow (read, write) The host and the participant can read/write the participant data.
     *        Example: The host "host123" can `read()` participant data.
     *        Example: The participant "participant456" can `read()` their own participant data.
     * @deny (read, write) Other users cannot read/write participant data.
     *       Example: User "other789" cannot `read()` participant data of "participant456" without being the host.
     * @principle  Allows the host and the participant themself to manage participant data.
     */
    match /classrooms/{classroomId}/participants/{participantId} {
      // isSignedIn helper function
      function isSignedIn() {
        return request.auth != null;
      }

      // isOwner helper function
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // isExistingOwner helper function
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow read, write: if isSignedIn() &&
          (
            // host
            get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId == request.auth.uid ||
            // participant editing their own record
            request.auth.uid == participantId
          );
    }
  }
}