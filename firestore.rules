/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for meetings and their related subcollections.
 *
 * Data Structure:
 * - /meetings/{meetingId}: Stores meeting metadata, including the creatorId.
 * - /meetings/{meetingId}/joinRequests/{userId}: Stores requests to join a meeting.
 * - /meetings/{meetingId}/participants/{userId}: Stores participant profiles for a meeting.
 *
 * Key Security Decisions:
 * - Users can only create meetings where they are the creator (creatorId matches auth.uid).
 * - Only the meeting creator can manage join requests (approve/deny).
 * - Only authenticated users can read meeting and participant data.
 * - Data validation is minimal in this prototype, focusing on authorization.
 *
 * Denormalization for Authorization:
 * - The `Meeting` document stores the `creatorId` to enable ownership-based access control for updates and deletes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Secure access to the /meetings collection.
     * @path /meetings/{meetingId}
     * @allow (create) - User with auth.uid can create a meeting with creatorId set to their UID.
     * @allow (get, list) - Anyone can read meeting details.
     * @allow (update, delete) - Only the meeting creator (creatorId) can update or delete the meeting.
     * @deny (create) - User tries to create a meeting with a creatorId that doesn't match their UID.
     * @principle Enforces document ownership for writes.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.creatorId);
    }

    /**
     * @description Secure access to the /meetings/{meetingId}/joinRequests collection.
     * @path /meetings/{meetingId}/joinRequests/{userId}
     * @allow (create) - User with auth.uid can create a join request with userId set to their UID.
     * @allow (get, list) - Only the meeting creator can list/get join requests.
     * @allow (update, delete) - Only the meeting creator can update/delete join requests.
     * @deny (create) - User tries to create a join request with a userId that doesn't match their UID.
     * @principle Enforces document ownership and creator control for join requests.
     */
    match /meetings/{meetingId}/joinRequests/{userId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
    }

    /**
     * @description Secure access to the /meetings/{meetingId}/participants collection.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (create, update) - Only the meeting creator can add/update participants.
     * @allow (get, list) - Any authenticated user can view the participants.
     * @deny (create, update) - Non-creator tries to add/update a participant.
     * @principle Restricts participant management to the meeting creator.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      allow delete: if false;
    }
  }
}