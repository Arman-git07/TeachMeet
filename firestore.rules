rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isClassroomOwner(classroomId) {
      return get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
    }

    function isTeacher(classroomId) {
      return isClassroomOwner(classroomId) || exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid));
    }
    
    function isParticipant(classroomId) {
      return exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid));
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && isClassroomOwner(classroomId);

      match /joinRequests/{userId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow read, update, delete: if request.auth != null && (
          request.auth.uid == userId || isClassroomOwner(classroomId)
        );
      }

      match /participants/{userId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && isClassroomOwner(classroomId);
      }
      
      match /teachers/{teacherId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && isClassroomOwner(classroomId);
      }

      match /announcements/{announcementId} {
        allow read: if request.auth != null && isParticipant(classroomId);
        allow create: if request.auth != null && isTeacher(classroomId);
        allow update, delete: if request.auth != null && (isClassroomOwner(classroomId) || request.auth.uid == resource.data.creatorId);
      }
      
      match /assignments/{assignmentId} {
        allow read: if request.auth != null && isParticipant(classroomId);
        allow create, update, delete: if request.auth != null && isTeacher(classroomId);

        match /submissions/{submissionId} {
            allow read: if request.auth != null && isParticipant(classroomId);
            allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
            allow update: if request.auth != null && isTeacher(classroomId); // For grading
            allow delete: if request.auth != null && (isClassroomOwner(classroomId) || request.auth.uid == resource.data.studentId);
        }
      }

      match /materials/{materialId} {
          allow read: if request.auth != null && isParticipant(classroomId);
          allow create: if request.auth != null; // Allow any authenticated user to share
          allow delete: if request.auth != null && (isClassroomOwner(classroomId) || request.auth.uid == resource.data.uploaderId);
      }

      match /exams/{examId} {
          allow read: if request.auth != null && isParticipant(classroomId);
          allow create, update, delete: if request.auth != null && isTeacher(classroomId);
      }
    }

    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /meetings/{meetingId} {
        // Anyone authenticated can create a meeting room document when they start as host
        allow create: if request.auth != null && request.auth.uid == request.resource.data.creatorId;
        // Anyone authenticated can read meeting details
        allow read: if request.auth != null;

        // Subcollections
        match /participants/{participantId} {
            // The host can add themselves, anyone can be added if the meeting exists
            allow create: if request.auth != null; 
            // Anyone can read the participant list
            allow read: if request.auth != null;
            // Only participants themselves or the meeting host can update their state (e.g. mute, hand-raise)
            allow update: if request.auth != null && (request.auth.uid == participantId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
            // Host can remove people, or people can remove themselves
            allow delete: if request.auth != null && (request.auth.uid == participantId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
        }

        match /joinRequests/{userId} {
            // Anyone authenticated can request to join
            allow create: if request.auth != null && request.auth.uid == userId;
            // The host can read and delete join requests
            allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
        }
    }
  }
}
