rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check for authentication
    function signedIn() {
      return request.auth != null;
    }

    // Meetings Collection
    match /meetings/{meetingId} {
      // Any authenticated user can create a meeting document.
      allow create: if signedIn();
      
      // Any authenticated user can read meeting details (e.g., to find the hostId).
      allow read: if signedIn();
      
      // Only the host can update or delete the meeting document.
      allow update, delete: if signedIn() && request.auth.uid == resource.data.hostId;
      
      // Participants subcollection
      match /participants/{participantId} {
        // Any signed-in user can add themselves. The host can remove others.
        allow read, write: if signedIn();
      }
      
      // Join Requests subcollection
      match /joinRequests/{userId} {
        // A user can create their own join request.
        allow create: if signedIn() && request.auth.uid == userId;
        
        // The user who made the request can read/delete it (cancel).
        // The host can read/update/delete requests (accept/deny).
        allow read, update, delete: if signedIn(); 
      }
    }

    // Users Collection (for user profiles, etc.)
    match /users/{userId} {
      allow read;
      allow write: if signedIn() && request.auth.uid == userId;
      
      // Subcollections for user-specific data
      match /{subcollection}/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }
    
    // Classrooms Collection
    match /classrooms/{classroomId} {
        allow read: if true; // Public classrooms can be read by anyone
        allow create: if signedIn();
        allow update: if signedIn(); // More specific rules needed here in a real app

        match /{subcollection}/{docId} {
            allow read, write: if signedIn();
        }
    }

    // Documents and Recordings (public/private files)
    match /documents/{docId} {
        allow read: if resource.data.isPrivate == false || (signedIn() && request.auth.uid == resource.data.uploaderId);
        allow create: if signedIn();
        allow delete: if signedIn() && request.auth.uid == resource.data.uploaderId;
    }
     match /recordings/{docId} {
        allow read: if resource.data.isPrivate == false || (signedIn() && request.auth.uid == resource.data.uploaderId);
        allow create: if signedIn();
        allow delete: if signedIn() && request.auth.uid == resource.data.uploaderId;
    }
     match /fcmTokens/{userId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
