rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Meetings collection
    match /meetings/{meetingId} {
      // Anyone can read meetings
      allow read: if true;

      // Allow only authenticated users to create meetings
      allow create: if request.auth != null;

      // Only the meeting host can update or delete
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Participants sub-collection
      match /participants/{participantId} {
        // Anyone in the meeting can see who else is there
        allow read: if request.auth != null;
        // A user can only add/remove themselves to the participant list
        allow write: if request.auth != null && request.auth.uid == participantId;
      }
    }

    // Classroom-related rules
    match /classrooms/{classroomId} {
      allow read: if true; // Let anyone read basic classroom info to discover/join
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.teacherId; // Only original teacher
    }

    match /classrooms/{classroomId}/{document=**} {
        allow read, write: if request.auth != null && (
            (exists(/databases/$(database)/documents/classrooms/$(classroomId)) && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) ||
            (exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)))
        );
    }

    // Documents and Recordings (example rules, might need adjustment)
    match /{collection}/{docId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow write: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
  }
}
