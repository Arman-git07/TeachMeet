
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if a user is a member of a group (like a meeting or teaching)
    function isMember(collectionName, resourceId) {
      return get(/databases/$(database)/documents/$(collectionName)/$(resourceId)).data.members.hasAny([request.auth.uid]);
    }
    
    // =============================================
    // Meetings Collection Rules
    // =============================================
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      
      // Allow creation only if the creator is the current user.
      allow create: if isAuthenticated() && isOwner(request.resource.data.creatorId);

      // Allow updates for managing participants.
      allow update: if isAuthenticated() && (
        // The host can update any part of the meeting document
        isOwner(resource.data.creatorId) ||
        // An authenticated user can add THEIR OWN ID to the pendingRequests array
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );

      // =============================================
      // Participants Sub-collection Rules
      // =============================================
      match /participants/{userId} {
        // Any authenticated user can create their OWN participant document.
        allow create: if isAuthenticated() && isOwner(userId);
        
        // A user can only read their own participant data, or if they are a member of the meeting.
        allow read: if isAuthenticated() && (isOwner(userId) || isMember('meetings', meetingId));

        // A user can only update their OWN participant document.
        allow update: if isAuthenticated() && isOwner(userId);
        
        // A user can only delete their OWN participant document. The host can also delete participants (implicit in app logic, not direct rule).
        allow delete: if isAuthenticated() && isOwner(userId);
      }
    }
    
    // =============================================
    // Teachings Collection Rules
    // =============================================
    match /teachings/{teachingId} {
      // Allow read access to public teachings, or if the user is a member.
      allow read: if isAuthenticated() && (resource.data.isPublic == true || isMember('teachings', teachingId));
      
      // Allow creation if the user is authenticated and is the creator.
      allow create: if isAuthenticated() && isOwner(request.resource.data.creatorId);
      
      // Allow updates by the creator or for join requests.
      allow update: if isAuthenticated() && (
        // The creator can update the title, description, and isPublic status.
        (isOwner(resource.data.creatorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'isPublic', 'pendingRequests', 'members'])) ||
        // Any authenticated user can add themselves to the pendingRequests list.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );
      
      // Only the creator can delete the teaching.
      allow delete: if isAuthenticated() && isOwner(resource.data.creatorId);
    }

    // =============================================
    // Documents and Recordings Collection Rules
    // =============================================
    match /{collectionName}/{docId} where collectionName in ['documents', 'recordings'] {
      // Allow read access if the document is public or if the user is the owner.
      allow read: if isAuthenticated() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));

      // Allow creation only if the uploader is the current user.
      allow create: if isAuthenticated() && isOwner(request.resource.data.uploaderId);
      
      // Only the owner can update or delete their documents/recordings.
      allow update, delete: if isAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    // =============================================
    // FCM Tokens Collection Rules
    // =============================================
    match /fcmTokens/{userId} {
      // Users can only create, read, update, or delete their own FCM token document.
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
  }
}
