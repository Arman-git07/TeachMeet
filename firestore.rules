/**
 * @file Firestore Security Rules
 * @core-philosophy This ruleset enforces a user-ownership model for meetings and controls access to join requests.
 *   Meetings can only be created by authenticated users. Join requests can only be created for existing meetings,
 *   and their status can only be modified by the meeting host.  Participants are managed within a meeting document.
 * @data-structure
 *   - /meetings/{meetingId}: Contains meeting metadata, creator information, and status.
 *   - /meetings/{meetingId}/joinRequests/{userId}: Stores join requests associated with a meeting, keyed by the user's ID.
 *   - /meetings/{meetingId}/participants/{userId}: Stores profiles of meeting participants.
 * @key-security-decisions
 *   - Users can only list meetings they own.
 *   - Join requests can only be created by authenticated users and are scoped to a specific meeting.
 *   - The meeting host (creator) is the only one who can approve or deny join requests.
 *   - Listing of join requests is disallowed to prevent information leakage.
 * @denormalization-for-authorization
 *   - The `Meeting` entity includes a `creatorId` field to easily identify the meeting host, enabling owner-based access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /meetings collection.
     * @path /meetings/{meetingId}
     * @allow (create) - User with auth can create a meeting.
     * @allow (get, list) - Anyone can read meeting details.
     * @allow (update, delete) - Only the meeting creator can update or delete the meeting.
     * @deny (create) - User without auth cannot create a meeting.
     * @deny (update, delete) - User who is not the meeting creator cannot update or delete the meeting.
     * @principle Enforces ownership for meeting modifications, allows public reads.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.creatorId);
    }

    /**
     * @description Controls access to the /meetings/{meetingId}/joinRequests collection.
     * @path /meetings/{meetingId}/joinRequests/{userId}
     * @allow (create) - Authenticated user can request to join a meeting.
     * @allow (update) - Only the meeting creator can approve or deny join requests.
     * @deny (list, get, delete) - No one can list, get or delete join requests.
     * @deny (create) - User without auth cannot create a join request.
     * @deny (update) - User who is not the meeting creator cannot update join requests.
     * @principle Limits join request management to the meeting host.
     */
    match /meetings/{meetingId}/joinRequests/{userId} {
      allow get, list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/meetings/{meetingId}).data.creatorId);
      allow delete: if false;
    }

    /**
     * @description Controls access to the /meetings/{meetingId}/participants collection.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (create, update) - The meeting host can add or update participants.
     * @allow (get, list) - Anyone can read the list of participants.
     * @deny (delete) - Participants can only be removed by the host.
     * @principle Manages participants through host control.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list: if true;
      allow create: if isExistingOwner(get(/databases/$(database)/documents/meetings/{meetingId}).data.creatorId);
      allow update: if isExistingOwner(get(/databases/$(database)/documents/meetings/{meetingId}).data.creatorId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/meetings/{meetingId}).data.creatorId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}