rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // All users can update their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Users can manage their own enrolled classrooms list
      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Allow authenticated users to read/write their own documents and recordings, and view public ones
    match /documents/{documentId} {
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    // Rules for classrooms and their subcollections
    match /classrooms/{classroomId} {
      // Any authenticated user can read public classrooms, but only enrolled students/teacher can read private ones.
      allow read: if request.auth != null && (resource.data.isPublic == true || request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.students);
      // Only authenticated users can create classrooms
      allow create: if request.auth != null;
      // Only the teacher can update or delete the classroom
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Join requests for a classroom
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;
        // Only the teacher of the classroom can read or delete requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // Rules for meetings and their subcollections
    match /meetings/{meetingId} {
      // Any authenticated user can read or create a meeting document
      allow read, write: if request.auth != null;

      // Join requests for a meeting
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request
        allow create: if request.auth != null;
        // The host can read and delete requests
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
      }

      // Participants in a meeting
      match /participants/{userId} {
        // Any authenticated user can read the participants list
        allow read: if request.auth != null;
        // A user can only write to their own participant document
        allow write: if request.auth != null && request.auth.uid == userId;
        // The host can also remove (delete) participants
        allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
    }
    
    // Rules for FCM tokens used for push notifications
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
