rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Meetings collection
    match /meetings/{meetingId} {
      // Host can create/update the meeting document
      allow create, update: if request.auth != null
                            && request.auth.uid == request.resource.data.hostId;

      // Anyone signed in can read meeting
      allow read: if request.auth != null;

      // Only host can delete the meeting
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.hostId;

      // Participants subcollection
      match /participants/{participantId} {
        // A user can create their own participant entry
        allow create: if request.auth != null
                      && request.auth.uid == participantId;

        // Signed-in users can read participants
        allow read: if request.auth != null;

        // User can update/delete only their own participant doc
        allow update, delete: if request.auth != null
                              && request.auth.uid == participantId;
      }
    }

    // Classrooms collection
    match /classrooms/{classroomId} {
      // Public classrooms are readable by anyone, private only by members
      allow read: if resource.data.isPublic == true || request.auth.uid in resource.data.students || request.auth.uid == resource.data.teacherId;

      // Only the teacher can create/update/delete
      allow create, update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
      
      // Subcollections within a classroom
      match /{subcollection}/{docId} {
        // Teachers can do anything
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
      match /joinRequests/{requestId} {
        // Allow any authenticated user to create a join request
        allow create: if request.auth != null;
        // Allow teacher to read/delete requests
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
    }
    
    // User-specific data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny all other collections
    // Note: this block is commented out as the final user-provided rules did not have it.
    // match /{path=**}/documents/{docId} {
    //   allow read, write: if false;
    // }
  }
}