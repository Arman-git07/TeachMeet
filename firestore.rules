
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User data is private
    match /users/{userId}/{allSubcollections=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classrooms can be public or private
    match /classrooms/{classroomId} {
      // Anyone can read public classrooms to discover them
      allow read: if resource.data.isPublic == true;
      // Authenticated users can create classrooms
      allow create: if request.auth != null;
      // Only the teacher can update or delete their own classroom
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Join requests can be created by any authenticated user.
      // Only the teacher can read/update/delete them.
      match /joinRequests/{studentId} {
        allow create: if request.auth != null && request.auth.uid == studentId;
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // Meeting documents
    match /meetings/{meetingId} {
      // Any authenticated user can create or read a meeting document.
      // In a real app, you might restrict this further.
      allow read, create: if request.auth != null;
      // Only the creator can update/delete the root meeting doc
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.creatorId;

      // Participants subcollection
      match /participants/{participantId} {
        // A user can only create/write/delete their own participant document.
        allow read, write, delete: if request.auth != null && request.auth.uid == participantId;
      }
    }
    
    // Documents and Recordings can be public or private
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
  }
}
