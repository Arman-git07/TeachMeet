/**
 * @description This ruleset enforces a strict authorization model for meetings, join requests, and participants.
 *   It prioritizes security by ensuring only the host can manage a meeting and only authenticated users can request to join.
 *   Data validation is relaxed for rapid prototyping but critical authorization fields are strictly enforced.
 * @dataStructure
 *   /meetings/{meetingId}: Contains meeting metadata.
 *   /meetings/{meetingId}/joinRequests/{requestId}: Contains requests to join a specific meeting.
 *   /meetings/{meetingId}/participants/{userId}: Contains participant profiles for a specific meeting.
 * @keySecurityDecisions
 *   - Only authenticated users can create meetings.
 *   - Only the host of a meeting can manage join requests.
 *   - Only the host can add participants.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the meetings collection.
     * @path /meetings/{meetingId}
     * @allow (create) - Authenticated user can create a meeting, hostId is validated against request.auth.uid.
     * @allow (get, list) - Anyone can read meeting details.
     * @allow (update, delete) - Only the host of the meeting can update or delete it.
     * @deny (create) - Non-authenticated user can not create a meeting.
     * @deny (update, delete) - Non-host user can not update or delete a meeting.
     * @principle Enforces meeting ownership for writes. Allows public reads.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isSignedIn() && isExistingOwner(meetingId, request.auth.uid);
    }

    /**
     * @description Controls access to the joinRequests subcollection for a specific meeting.
     * @path /meetings/{meetingId}/joinRequests/{requestId}
     * @allow (create) - Authenticated user can create a join request with userId matching request.auth.uid.
     * @allow (get, list) - Only the host of the meeting can list join requests.
     * @allow (update, delete) - Only the host of the meeting can update or delete join requests.
     * @deny (create) - Non-authenticated user or mismatched userId cannot create a join request.
     * @deny (update, delete) - Non-host user cannot update or delete join requests.
     * @principle Enforces meeting host control over join requests.
     */
    match /meetings/{meetingId}/joinRequests/{requestId} {
      allow get, list: if isSignedIn() && isOwner(meetingId, request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isOwner(meetingId, request.auth.uid) && resource != null;
    }

    /**
     * @description Controls access to the participants subcollection for a specific meeting.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (create) - Only the host of the meeting can add participants.
     * @allow (get, list) - Only the host of the meeting can read participants.
     * @allow (update, delete) - Only the host of the meeting can update/delete participants.
     * @deny (create) - Non-host user cannot add participants.
     * @deny (update, delete) - Non-host user cannot update/delete participants.
     * @principle Enforces meeting host control over participants.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list, create, update, delete: if isSignedIn() && isOwner(meetingId, request.auth.uid);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // isOwner checks if the current user is the host of the meeting.
    function isOwner(meetingId, userId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == userId;
    }

    // isExistingOwner checks if the document exists and the current user is the host of the meeting.
    function isExistingOwner(meetingId, userId) {
      return resource != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == userId;
    }
  }
}