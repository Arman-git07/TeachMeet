rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user document and subcollections.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'classrooms' collection
    match /classrooms/{classroomId} {
      // Anyone can read a public classroom's main document.
      allow get: if resource.data.isPublic == true;
      
      // Authenticated users can list public classrooms.
      allow list: if request.auth != null && resource.data.isPublic == true;

      // The teacher of the class can read all data, update, and delete the classroom.
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Any authenticated user can create a classroom. The rule ensures they set themselves as the teacher.
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      
      // Rules for 'joinRequests' subcollection within a classroom
      match /joinRequests/{requestUserId} {
         // Any authenticated user can create a request for themselves.
        allow create: if request.auth != null && request.auth.uid == requestUserId;
        
        // Only the teacher of the classroom or the user who made the request can read it.
        allow read: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId || request.auth.uid == requestUserId);
        
        // Only the teacher can delete (approve/deny) a join request.
        allow delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
      
      // Other subcollections (announcements, materials, etc.) can only be accessed by the teacher
      // or enrolled students (future implementation). For now, lock to teacher.
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }
    
    // Rules for other collections
    match /documents/{docId} {
        // Allow create if user is authenticated and is the owner
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        // Allow read if the doc is public, or if the user is the owner
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        // Allow delete only by the owner
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recId} {
        // Allow create if user is authenticated and is the owner
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        // Allow read if the doc is public, or if the user is the owner
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        // Allow delete only by the owner
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny for any other path.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
