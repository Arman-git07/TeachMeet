rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return request.auth.uid == userId;
    }

    // Teachings Collection
    match /teachings/{teachingId} {
      allow read: if isAuthenticated() && (resource.data.isPublic == true || request.auth.uid in resource.data.members);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isUser(resource.data.creatorId);
      allow delete: if isAuthenticated() && isUser(resource.data.creatorId);
    }
    
    // Meetings Collection
    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting.
      allow create: if isAuthenticated();
      
      // Anyone authenticated can read meeting details (like creatorId to check if they are host)
      allow read: if isAuthenticated();
      
      // Update is tricky. We need to allow participants to request to join.
      allow update: if isAuthenticated() &&
                     // Allow a user to add themselves to the pendingRequests list.
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                     request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]);

      // Only the host can manage participants and other meeting details
      match /participants/{participantId} {
        allow read: if isAuthenticated();
        // The user themselves can join, or the host can add them.
        allow create: if isAuthenticated() && isUser(participantId);
        // Only the user can update their own status (mute, camera, etc.) or delete themselves.
        allow update, delete: if isAuthenticated() && isUser(participantId);
      }
    }
    
    // Documents & Recordings Collections
    match /{collection}/{docId} {
      // Applies to 'documents' and 'recordings'
      
      // Allow read if the document is public, or if the user is the owner.
      allow read: if resource.data.isPrivate == false || (isAuthenticated() && isUser(resource.data.uploaderId));
      
      // Allow creation for any authenticated user.
      allow create: if isAuthenticated();
      
      // Allow update and delete only for the user who uploaded the item.
      allow update, delete: if isAuthenticated() && isUser(resource.data.uploaderId);
    }

    // FCM Tokens
    match /fcmTokens/{userId} {
      // A user can only manage their own FCM token.
      allow read, write: if isAuthenticated() && isUser(userId);
    }
  }
}
