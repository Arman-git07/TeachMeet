rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can manage their own data and FCM tokens.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'classrooms' collection
    match /classrooms/{classroomId} {
      // Allow any authenticated user to create a classroom.
      allow create: if request.auth != null;

      // Allow reads if the classroom is public, or if the user is the teacher,
      // or if the user is enrolled in the classroom.
      allow read: if (resource.data.isPublic == true) || 
                     (request.auth != null && resource.data.teacherId == request.auth.uid) ||
                     (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrolled/$(classroomId)));
      
      // Allow updates/deletes only by the teacher.
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;

      // Rules for the 'joinRequests' subcollection
      match /joinRequests/{userId} {
        // Any authenticated user can create a request for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // Only the teacher of the classroom can read/list join requests.
        allow read, list: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        
        // The teacher can delete (approve/deny) requests, and a user can delete their own request.
        allow delete: if request.auth != null && (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid || request.auth.uid == userId);
      }
      
      // Rules for 'announcements', 'materials', and 'assignments' subcollections
      match /{subcollection}/{docId} {
        // Teacher can create/update/delete.
        allow write: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        
        // Enrolled users and the teacher can read.
        allow read: if request.auth != null && (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid || exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrolled/$(classroomId)));
      }
    }

    // Rules for 'meetings' collection
    match /meetings/{meetingId} {
        // Authenticated users can create/update meetings they own.
        allow write: if request.auth != null && request.auth.uid == request.resource.data.creatorId;
        // The host can delete their own meeting document.
        allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;

        // Any authenticated user can read the meeting document to get creatorId etc.
        allow read: if request.auth != null;

        // Rules for 'participants' subcollection
        match /participants/{userId} {
            // A user can join (write their own doc) or update their own status.
            allow write: if request.auth != null && request.auth.uid == userId;
            // A user can leave (delete their own doc). The host can also kick users.
            allow delete: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
            // Any authenticated user in the meeting can read the participants list.
            allow read: if request.auth != null;
        }

        // Rules for 'joinRequests' subcollection for meetings
        match /joinRequests/{userId} {
            // Any authenticated user can request to join.
            allow create, read: if request.auth != null && request.auth.uid == userId;
            // The host can read and delete (approve/deny) requests.
            allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
        }
    }
    
    // Rules for 'documents' and 'recordings' collections
    match /{collection}/{docId} {
      // Allow create if user is authenticated
      allow create: if request.auth != null;

      // Allow read if the document/recording is public, or if the user is the owner.
      allow read: if resource.data.isPrivate == false || (request.auth != null && resource.data.uploaderId == request.auth.uid);
      
      // Allow update/delete only if the user is the owner.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
  }
}
