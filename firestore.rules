rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Meetings collection
    match /meetings/{meetingId} {
      // Host can create/update the meeting document
      allow create, update: if request.auth != null
                          && request.auth.uid == request.resource.data.hostId;

      // Anyone signed in can read meeting
      allow read: if request.auth != null;

      // Only host can delete the meeting
      allow delete: if request.auth != null
                  && request.auth.uid == resource.data.hostId;

      // Participants subcollection
      match /participants/{participantId} {
        // A user can create their own participant entry
        allow create: if request.auth != null
                      && request.auth.uid == participantId;

        // Signed-in users can read participants
        allow read: if request.auth != null;

        // User can update/delete only their own participant doc
        allow update, delete: if request.auth != null
                              && request.auth.uid == participantId;
      }
    }
    
    // Classrooms Collection
    match /classrooms/{classroomId} {
        allow read: if true; // Public classrooms are readable
        allow create: if request.auth != null && request.auth.uid == request.resource.data.teacherId;
        allow update: if request.auth != null && request.auth.uid == resource.data.teacherId;
        
        match /announcements/{announcementId} {
          allow read: if true;
          allow create: if request.auth.uid == request.resource.data.authorId;
          allow delete: if request.auth.uid == resource.data.authorId;
        }

        match /materials/{materialId} {
          allow read: if true;
          allow create: if request.auth.uid == request.resource.data.uploaderId;
          allow delete: if request.auth.uid == resource.data.uploaderId;
        }
        
        match /exams/{examId} {
          allow read: if true;
          allow create: if request.auth.uid == request.resource.data.authorId;
          allow delete: if request.auth.uid == resource.data.authorId;
        }
        
         match /assignments/{assignmentId} {
          allow read: if true;
          allow create: if request.auth.uid == request.resource.data.creatorId;
          allow delete: if request.auth.uid == resource.data.creatorId;
           match /submissions/{submissionId} {
             allow read: if true; // or check if user is teacher/student
             allow create, update: if request.auth != null; // a student can submit
           }
        }
        
        match /joinRequests/{requestId} {
            allow create: if request.auth != null && request.auth.uid == requestId;
            allow read, delete: if request.auth.uid == resource.data.studentId || exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid));
        }

        match /participants/{participantId} {
            allow read: if true;
            allow create, delete: if request.auth.uid == resource.data.uid || exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid));
        }
        
        match /teachers/{teacherId} {
            allow read, write: if request.auth != null;
        }
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
       match /enrolled/{classroomId} {
          allow read, write, delete: if request.auth.uid == userId;
        }
       match /pendingJoinRequests/{classroomId} {
          allow read, write, delete: if request.auth.uid == userId;
        }
    }
    
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
      allow create: if request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
      allow create: if request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth.uid == resource.data.uploaderId;
    }

    match /fcmTokens/{userId} {
        allow read, write: if request.auth.uid == userId;
    }
  }
}
