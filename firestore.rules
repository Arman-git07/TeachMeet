
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if a user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to get classroom data
    function getClassroom(classroomId) {
      return get(/databases/$(database)/documents/classrooms/$(classroomId)).data;
    }
    
    // Helper function to check if a user is the creator of a classroom
    function isClassroomCreator(classroomId) {
      let classroom = getClassroom(classroomId);
      // Support multiple potential creator fields for legacy compatibility
      return isOwner(classroom.teacherId) || isOwner(classroom.createdBy) || isOwner(classroom.creatorId);
    }
    
    // Helper function to check if user is an enrolled participant (student or teacher)
    function isEnrolled(classroomId) {
      return exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid));
    }

    // Helper function to check if user is a creator OR a teacher in the classroom
    function canManage(classroomId) {
       let classroom = getClassroom(classroomId);
       // The 'teachers' field is an array of objects {uid: ..., name: ...}
       return isClassroomCreator(classroomId) || request.auth.uid in classroom.teachers.map(t => t.uid);
    }

    // Users can read/write their own profile data.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/{subcollection}/{docId} {
        allow read, write: if isOwner(userId);
    }

    // Rules for the main classrooms collection
    match /classrooms/{classroomId} {
      // Anyone signed in can view public classrooms
      allow get: if isSignedIn() && (resource.data.isPublic == true || isEnrolled(classroomId));
      allow list: if isSignedIn() && resource.data.isPublic == true;
      
      // Only signed-in users can create classrooms
      allow create: if isSignedIn();
      
      // Only the creator can update the main classroom document
      allow update: if isSignedIn() && isClassroomCreator(classroomId);

      // Only the creator can delete their own classroom
      allow delete: if isSignedIn() && isClassroomCreator(classroomId);
    }

    // Rules for subcollections within a classroom
    match /classrooms/{classroomId}/{subcollection}/{docId} {
      // Allow read for any enrolled member
      allow get, list: if isSignedIn() && isEnrolled(classroomId);
      
      // Allow create/update/delete for creators and teachers
      allow write: if isSignedIn() && canManage(classroomId);
    }
    
    // Special rule for joinRequests: any signed-in user can create one for themselves
    match /classrooms/{classroomId}/joinRequests/{userId} {
       allow create: if isSignedIn() && request.auth.uid == userId;
       // Only creator/manager can read/delete requests
       allow read, delete: if isSignedIn() && canManage(classroomId);
    }

    // Documents & Recordings: Users can manage their own, and read public ones.
    match /documents/{docId} {
      allow read: if isSignedIn() && resource.data.isPrivate == false;
      allow get, create, update, delete: if isSignedIn() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{docId} {
      allow read: if isSignedIn() && resource.data.isPrivate == false;
      allow get, create, update, delete: if isSignedIn() && isOwner(resource.data.uploaderId);
    }
    
    // Meetings: Authenticated users can create meetings. Participants can update their own status.
    match /meetings/{meetingId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.creatorId);
      
      match /participants/{participantId} {
         allow read, write: if isSignedIn() && (isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId));
      }
    }

    // FCM Tokens: Users can only write their own token.
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
