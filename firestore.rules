rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }
    
    function isMeetingCreator(meetingId, userId) {
      let meetingDoc = getDoc('meetings/' + meetingId);
      return meetingDoc != null && meetingDoc.data.creatorId == userId;
    }

    function isMeetingParticipant(meetingId, userId) {
      return exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(userId));
    }
    
    function isTeachingCreator(teachingId) {
      return getDoc('teachings/' + teachingId).data.creatorId == request.auth.uid;
    }
    
    function isStudent(teachingId) {
      return getDoc('teachings/' + teachingId).data.allowedStudents.hasAny([request.auth.uid]);
    }


    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      allow update, delete: if isUserAuthenticated() && isMeetingCreator(meetingId, request.auth.uid);

      // --- Participants ---
      match /participants/{participantId} {
        allow list, read: if isUserAuthenticated();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid);
      }

      // --- Join Requests ---
      match /joinRequests/{userId} {
        allow create: if isUserAuthenticated() && isOwner(userId);
        allow read: if isMeetingCreator(meetingId, request.auth.uid) || isOwner(userId);
        allow delete: if isMeetingCreator(meetingId, request.auth.uid) || isOwner(userId);
      }
    }


    // ===== TEACHINGS =====
    // This model uses a single 'teachings' collection and user subcollections for relationships.
    match /teachings/{teachingId} {
      // Allow reads if the teaching is public OR the user is the creator OR is in the allowedStudents list.
      allow read: if resource.data.isPublic == true || (isUserAuthenticated() && (resource.data.creatorId == request.auth.uid || resource.data.allowedStudents.hasAny([request.auth.uid])));
      
      // Allow creation only if the creatorId in the new document matches the user making the request.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      
      // Allow updates/deletes only by the original creator.
      // This also covers a teacher adding/removing students from `allowedStudents`.
      // It also covers a student adding/removing themselves from `pendingRequests`.
      allow update: if isUserAuthenticated() && (
        (resource.data.creatorId == request.auth.uid) || 
        (request.resource.data.pendingRequests.hasAll(resource.data.pendingRequests) && request.resource.data.pendingRequests.size() == resource.data.pendingRequests.size() + 1)
      );

      allow delete: if isUserAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // ===== USERS =====
    // User-specific subcollections for tracking their created/enrolled teachings.
    match /users/{userId} {
      allow read, write: if isOwner(userId); // Protect user document itself.

      match /myTeachings/{teachingId} {
        allow read, list, write, delete: if isOwner(userId);
      }
      
      match /enrolledTeachings/{teachingId} {
        allow read, list, write, delete: if isOwner(userId);
      }
    }


    // ===== DOCUMENTS & RECORDINGS =====
    // Generic rules for user-uploaded content in Storage-mirroring collections.
    match /documents/{docId} {
        allow read: if isUserAuthenticated() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
        allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recId} {
        allow read: if isUserAuthenticated() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
        allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
  }
}
