rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings collection
    match /meetings/{meetingId} {
      // Host can create the meeting document
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.hostId;

      // Host can update the meeting document
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.hostId;

      // Anyone signed in can read the meeting
      allow read: if request.auth != null;

      // Only host can delete
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.hostId;

      // Participants subcollection
      match /participants/{participantId} {
        // A user can create their own participant entry
        allow create: if request.auth != null
                      && request.auth.uid == participantId;

        // Signed-in users can read participants
        allow read: if request.auth != null;

        // A user can update/delete only their own participant doc
        allow update, delete: if request.auth != null
                              && request.auth.uid == participantId;
      }
    }

    // Join requests subcollection inside meetings
    match /meetings/{meetingId}/joinRequests/{requestId} {
      // Any signed-in user can send a join request
      allow create: if request.auth != null;
      // Only the host can read/delete join requests
      allow read, delete: if request.auth != null
                           && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }
    
    // Classrooms Collection
    match /classrooms/{classroomId} {
       allow read, create: if request.auth != null;
       allow update, delete: if request.auth.uid == resource.data.teacherId;
       
       match /announcements/{announcementId} {
         allow read: if true;
         allow create, update, delete: if request.auth.uid == resource.data.authorId;
       }

       match /materials/{materialId} {
         allow read: if true;
         allow create: if request.auth != null;
         allow delete: if request.auth.uid == resource.data.uploaderId;
       }
       
       match /exams/{examId} {
         allow read: if true;
         allow create, update, delete: if request.auth.uid == resource.data.authorId;
       }

       match /assignments/{assignmentId} {
          allow read: if true;
          allow create, update, delete: if request.auth.uid == resource.data.creatorId;

          match /submissions/{submissionId} {
            allow read: if request.auth != null;
            allow create: if request.auth.uid == submissionId;
            allow update: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
          }
       }
       
       match /joinRequests/{userId} {
         allow read, write: if request.auth != null;
       }

       match /participants/{userId} {
         allow read, write: if request.auth != null;
       }
       
       match /teachers/{userId} {
          allow read, write: if request.auth != null;
       }
    }

    // User-specific subcollections
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /enrolled/{classroomId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /pendingJoinRequests/{classroomId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
      allow create: if request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
      allow create: if request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth.uid == resource.data.uploaderId;
    }
    
     match /fcmTokens/{userId} {
        allow read, write: if request.auth.uid == userId;
     }

    // Default deny all other paths
    match /{path=**} {
        allow read, write: if false;
    }
  }
}
