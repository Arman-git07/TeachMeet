rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper to check if the user is the owner of the file path.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Avatars: Anyone can view, but only the owner can upload/update.
    match /avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if isOwner(userId);
    }

    // Class Thumbnails: Anyone can view, only the owner (teacher) can upload/update.
    match /class_thumbnails/{userId}/{allPaths=**} {
      allow read;
      allow write: if isOwner(userId);
    }

    // Teacher-Uploaded Content (Materials, Assignment Papers, Exam Papers):
    // Anyone can read, only the teacher can write/delete.
    match /class_materials/{classId}/{teacherId}/{allPaths=**} {
      allow read;
      allow write, delete: if isOwner(teacherId);
    }
    match /class_assignments/{classId}/{teacherId}/{allPaths=**} {
      allow read;
      allow write, delete: if isOwner(teacherId);
    }
    match /exam_papers/{teacherId}/{examId}/{allPaths=**} {
      allow read;
      allow write, delete: if isOwner(teacherId);
    }
    
    // Student Submissions:
    // Only the student themselves can upload, read, or delete their own submission files.
    // Teachers will gain read access via secure download URLs, validated by Firestore rules.
    match /class_submissions/{classId}/{assignmentId}/{studentId}/{allPaths=**} {
      allow read, write, delete: if isOwner(studentId);
    }
    match /exam_submissions/{examId}/{studentId}/{allPaths=**} {
      allow read, write, delete: if isOwner(studentId);
    }
  }
}
    