
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Generic Helper Functions ---
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- Meetings ---
    match /meetings/{meetingId} {
      allow read: if isAuth();

      // CREATION: Any authenticated user can create a meeting room.
      allow create: if isAuth() && isOwner(request.resource.data.creatorId) && request.resource.data.pendingRequests == [];

      // UPDATE: More granular update rules.
      allow update: if isAuth() && (
        // Case 1: Host wants to approve a pending request.
        (isOwner(resource.data.creatorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests', 'members'])) ||
        // Case 2: Host wants to deny a pending request.
        (isOwner(resource.data.creatorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests'])) ||
        // Case 3: A participant wants to request to join.
        // They can only add their OWN uid to the pendingRequests array.
        (request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );
      
      // DELETION: Only the meeting creator can delete the meeting room. (FUTURE)
      // allow delete: if isAuth() && isOwner(resource.data.creatorId);

      // --- Subcollection: Participants ---
      match /participants/{userId} {
        // CREATION/JOIN: Any authenticated user can add themselves as a participant.
        allow create: if isAuth() && isOwner(userId);
        
        // READ: Any authenticated user can see who is in the meeting.
        allow read: if isAuth();
        
        // UPDATE/DELETE: A user can only update or remove themselves from the meeting.
        allow update, delete: if isAuth() && isOwner(userId);
      }
    }
    
    // --- FCM Tokens ---
    match /fcmTokens/{userId} {
        allow read, write: if isAuth() && isOwner(userId);
    }
    
    // --- Documents ---
    match /documents/{documentId} {
      // READ: Allow reads if the document is public OR if the user is the owner.
      allow read: if isAuth() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      
      // WRITE (Create, Update): Only the owner can write.
      allow write: if isAuth() && isOwner(request.resource.data.uploaderId);
      
      // DELETE: Only the owner can delete.
      allow delete: if isAuth() && isOwner(resource.data.uploaderId);
    }
    
    // --- Recordings ---
    match /recordings/{recordingId} {
      // READ: Allow reads if the recording is public OR if the user is the owner.
      allow read: if isAuth() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      
      // WRITE (Create, Update): Only the owner can write.
      allow write: if isAuth() && isOwner(request.resource.data.uploaderId);
      
      // DELETE: Only the owner can delete.
      allow delete: if isAuth() && isOwner(resource.data.uploaderId);
    }
    
    // --- Teachings ---
    match /teachings/{teachingId} {
      // READ: Anyone can read public teachings, members can read private ones they are in.
      allow read: if isAuth() && (resource.data.isPublic == true || request.auth.uid in resource.data.members);
      
      // CREATE: Any authenticated user can create a teaching, making themselves the creator and a member.
      allow create: if isAuth() 
                    && isOwner(request.resource.data.creatorId) 
                    && request.resource.data.members == [request.auth.uid]
                    && request.resource.data.pendingRequests == [];

      // UPDATE: Granular update rules for teachings.
      allow update: if isAuth() && (
        // Case 1: The owner is updating the title, description, or public status.
        (isOwner(resource.data.creatorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'isPublic'])) ||
        // Case 2: The owner is approving/denying requests.
        (isOwner(resource.data.creatorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests', 'members'])) ||
        // Case 3: A non-member wants to request to join.
        (!(request.auth.uid in resource.data.members) && request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );
      
      // DELETE: Only the owner can delete a teaching.
      allow delete: if isAuth() && isOwner(resource.data.creatorId);
    }
  }
}
