rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    // ===== USER DATA =====
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);

      // Only the creator can update the main meeting document (e.g., pendingRequests)
      allow update: if isUserAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      
      allow delete: if isUserAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;

      match /participants/{participantId} {
        allow read: if isUserAuthenticated();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }

    // ===== TEACHINGS (CLASSROOMS) =====
    match /teachings/{teachingId} {
      allow read, list: if isUserAuthenticated();

      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;

      // Update rule:
      // - The creator can update any field.
      // - Any authenticated user can add themselves to 'pendingRequests', but cannot modify other fields or other users' requests.
      allow update: if (isUserAuthenticated() && 
                      (request.resource.data.creatorId == request.auth.uid || 
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])))
                      );

      allow delete: if isUserAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // ===== DOCUMENTS & RECORDINGS (LIBRARY) =====
    // These rules apply to both 'documents' and 'recordings' collections.
    match /{collectionName}/{fileId}
    where collectionName in ['documents', 'recordings'] {
      // Allow read if the document is public OR if the user is the owner.
      allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
      
      // Allow list only for a user's own items or public items. This is handled by queries in the app.
      allow list: if isUserAuthenticated();

      // Allow create if the user is authenticated and is the owner of the new document.
      allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;

      // Allow update only by the owner (e.g., to change public/private status).
      allow update: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
      
      // Allow delete only by the owner.
      allow delete: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
  }
}
