rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is the host of a meeting
    function isMeetingHost(meetingId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    // Rules for the meetings collection
    match /meetings/{meetingId} {
      allow read: if true; // Anyone can read meeting details to join
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid; // Only signed-in users can create a meeting for themselves
      allow update: if request.auth != null && isMeetingHost(meetingId); // Only the host can update meeting details

      // Rules for the joinRequests subcollection
      match /joinRequests/{userId} {
        allow create: if request.auth != null && request.auth.uid == userId; // A user can only create their own join request
        allow read, update, delete: if request.auth != null && isMeetingHost(meetingId); // Only the host can read, update (approve/deny), or delete requests
      }

      // Rules for the participants subcollection
      match /participants/{participantId} {
        allow read: if true; // Anyone in the meeting can see other participants
        allow create: if request.auth != null && isMeetingHost(meetingId); // Only the host can add participants (by approving requests)
        allow delete: if request.auth != null && (isMeetingHost(meetingId) || request.auth.uid == participantId); // Host can remove, or user can leave
      }
    }

    // Rules for the global joinRequests collection (if used as a fallback)
    // This provides broader access but is less secure. The subcollection method is preferred.
    match /joinRequests/{requestId} {
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(request.resource.data.meetingId)).data.hostId == request.auth.uid;
    }
  }
}
