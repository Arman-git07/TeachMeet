
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // For development, allow read/write access to all authenticated users.
    // In production, you MUST secure your data properly.
    // Example: allow read, write: if request.auth.uid == resource.data.authorId;
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
