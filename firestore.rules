rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /enrolled/{classroomId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.teacherId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
      
      match /joinRequests/{userId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null; // Teachers need to read this
        allow delete: if request.auth != null; // Creator or user can delete
      }

      match /participants/{userId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
      match /teachers/{teacherId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }

      match /announcements/{announcementId} {
        allow read: if request.auth != null;
        // Allow create if the user is a participant with the role 'teacher'
        allow create: if request.auth != null && 
          exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
      }

      match /assignments/{assignmentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
          exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
        
        match /submissions/{submissionId} {
            allow read: if request.auth != null;
            allow create: if request.auth != null;
            allow update: if request.auth != null && 
              exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
        }
      }

       match /materials/{materialId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
          exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
      }

      match /exams/{examId} {
         allow read: if request.auth != null;
         allow create: if request.auth != null && 
          exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
      }

    }
    
    match /documents/{documentId} {
       allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
       allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
       allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recordingId} {
       allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
       allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
       allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
    
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
      
      match /joinRequests/{userId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null; // Host will delete this
      }
    }
    
     match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
