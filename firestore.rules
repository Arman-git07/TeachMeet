
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if a user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // FCM Tokens: Allow users to manage their own push notification tokens.
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Teachings Collection
    match /teachings/{teachingId} {
      // READ:
      // - Any authenticated user can read any public teaching.
      // - A member of a teaching can read it, even if private.
      allow read: if isAuthenticated() && (resource.data.isPublic == true || request.auth.uid in resource.data.members);
      
      // CREATE:
      // - An authenticated user can create a teaching.
      // - They must set themselves as the creatorId.
      // - They must include themselves in the members list.
      allow create: if isAuthenticated()
                    && request.resource.data.creatorId == request.auth.uid
                    && request.auth.uid in request.resource.data.members;

      // UPDATE:
      // - Only the creator can update the teaching details (title, description, isPublic).
      // - Any authenticated user can add themselves to the pendingRequests.
      // - The creator can add or remove members (approving/denying requests).
      allow update: if isAuthenticated() && (
        // Creator can update core fields
        (isOwner(resource.data.creatorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'isPublic', 'pendingRequests', 'members'])) ||
        // Any authenticated user can request to join
        (request.resource.data.pendingRequests == resource.data.pendingRequests.union([request.auth.uid]))
      );
      
      // DELETE:
      // - Only the creator can delete the teaching.
      allow delete: if isAuthenticated() && isOwner(resource.data.creatorId);
    }

    // Documents and Recordings (Shared Rules)
    match /{collection}/{docId} where collection in ['documents', 'recordings'] {
      // READ:
      // - Any authenticated user can read public documents/recordings.
      // - The owner can read their own private documents/recordings.
      allow read: if isAuthenticated() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      
      // CREATE:
      // - An authenticated user can create (upload) a document/recording.
      // - They must set themselves as the uploaderId.
      allow create: if isAuthenticated() && isOwner(request.resource.data.uploaderId);
      
      // UPDATE:
      // - The owner can update their own documents/recordings.
      allow update: if isAuthenticated() && isOwner(resource.data.uploaderId);
      
      // DELETE:
      // - The owner can delete their own documents/recordings.
      allow delete: if isAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    // Meetings Collection
    match /meetings/{meetingId} {
        // READ: 
        // - Any member of the meeting can read the meeting document.
        // - An authenticated user with a pending request can read it (to check status).
        allow read: if isAuthenticated() && (request.auth.uid in resource.data.members || request.auth.uid in resource.data.pendingRequests || isOwner(resource.data.creatorId));

        // CREATE:
        // - Any authenticated user can create a meeting document.
        // - They must set themselves as the creator.
        allow create: if isAuthenticated() && isOwner(request.resource.data.creatorId);

        // UPDATE:
        // - The creator can add members (approve requests).
        // - Any authenticated user can add themselves to pendingRequests.
        allow update: if isAuthenticated() && (
            (isOwner(resource.data.creatorId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingRequests'])) ||
            (request.resource.data.pendingRequests == resource.data.pendingRequests.union([request.auth.uid]))
        );
        
        // Participants Subcollection
        match /participants/{participantId} {
            // READ: Any member of the meeting can read participant data.
            allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/meetings/$(meetingId)).data.members;

            // CREATE & UPDATE: A user can only create or update their own participant document.
            allow create, update: if isOwner(participantId);

            // DELETE: A user can only delete their own participant document (on leaving).
            allow delete: if isOwner(participantId);
        }
    }
  }
}
