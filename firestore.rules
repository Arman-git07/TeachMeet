
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }
    
    function isMeetingCreator(meetingId, userId) {
      return getDoc('meetings/' + meetingId).data.creatorId == userId;
    }

    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      allow update, delete: if isMeetingCreator(meetingId, request.auth.uid);

      // --- Participants ---
      match /participants/{participantId} {
        allow read, list: if isUserAuthenticated();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid);
      }

      // --- Join Requests (NEW & CORRECTED) ---
      match /joinRequests/{userId} {
        // A user can create their own join request document.
        allow create: if isOwner(userId);
        
        // A user can read their own request, and the host can read all requests.
        allow read: if isOwner(userId) || isMeetingCreator(meetingId, request.auth.uid);
        
        // Only the host can delete (approve/deny) a request.
        allow delete: if isMeetingCreator(meetingId, request.auth.uid);
      }
    }
    
    // ===== TEACHINGS & USERS (NEW & CORRECTED) =====
    // This new structure aligns with the user's specification for a robust teaching model.
    
    // This is the global collection of all teachings, public or private.
    match /teachings/{teachingId} {
        // Anyone can discover public teachings.
        // A user can read a private teaching if they are the creator or in the `allowedStudents` list.
        allow read: if resource.data.isPublic == true 
                    || (isUserAuthenticated() && (
                        resource.data.creatorId == request.auth.uid 
                        || resource.data.allowedStudents.hasAny([request.auth.uid])
                    ));

        // Anyone authenticated can create a teaching, as long as they set themselves as the creator.
        allow create: if isUserAuthenticated() 
                      && request.resource.data.creatorId == request.auth.uid;
        
        // Only the creator can update or delete a teaching.
        // The update rule allows adding students to `allowedStudents` by the creator.
        allow update, delete: if isUserAuthenticated() 
                              && resource.data.creatorId == request.auth.uid;
    }
    
    // This protects user-specific data.
    match /users/{userId} {
      // Allow a user to read/write to their own user document.
      allow read, write: if isOwner(userId);

      // --- My Teachings Subcollection (Classes created by the user) ---
      match /myTeachings/{teachingId} {
        allow read, list, write, delete: if isOwner(userId);
      }

      // --- Enrolled Teachings Subcollection (Classes the user has joined) ---
      match /enrolledTeachings/{teachingId} {
        allow read, list, write, delete: if isOwner(userId);
      }
    }

    // ===== FILE STORAGE METADATA =====
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
      allow create: if isOwner(request.resource.data.uploaderId);
      allow delete: if isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recId} {
      allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
      allow create: if isOwner(request.resource.data.uploaderId);
      allow delete: if isOwner(resource.data.uploaderId);
    }
  }
}
