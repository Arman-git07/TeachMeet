rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Meetings collection
    match /meetings/{meetingId} {
      // allow anyone signed in to create a meeting if they are the host
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.hostId;
      // allow signed-in users to read
      allow read: if request.auth != null;
      // allow only host to update/delete
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.hostId;
    }

    // Join requests subcollection inside meetings
    match /meetings/{meetingId}/joinRequests/{requestId} {
      allow create: if request.auth != null; // any signed-in user can send a join request
      allow read, update, delete: if request.auth != null && exists(get(/databases/$(database)/documents/meetings/$(meetingId))) && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    // Participants subcollection inside meetings
    match /meetings/{meetingId}/participants/{participantId} {
      allow create: if request.auth != null
                    && (request.auth.uid == participantId || (exists(get(/databases/$(database)/documents/meetings/$(meetingId))) && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid));
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null
                            && (request.auth.uid == participantId || (exists(get(/databases/$(database)/documents/meetings/$(meetingId))) && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid));
    }

    // All other collections/documents
    match /{document=**} {
      // General user data - allow users to manage their own documents
      match /users/{userId}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Classrooms - detailed rules
      match /classrooms/{classroomId} {
        allow read: if request.auth != null; // Allow any signed-in user to read basic classroom details
        allow create: if request.auth != null; // Allow any signed-in user to create a classroom
        allow update: if request.auth != null && request.auth.uid == resource.data.teacherId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
      }
      
      match /classrooms/{classroomId}/{subcollection}/{documentId} {
         allow read, write: if request.auth != null; // Broad access for subcollections for now
      }

      // Recordings & Documents - allow read if public, owner can do anything
      match /recordings/{recordingId} {
        allow read: if request.auth != null && resource.data.isPrivate == false;
        allow get, delete, update: if request.auth != null && request.auth.uid == resource.data.uploaderId;
        allow create: if request.auth != null;
      }

      match /documents/{documentId} {
        allow read: if request.auth != null && resource.data.isPrivate == false;
        allow get, delete, update: if request.auth != null && request.auth.uid == resource.data.uploaderId;
        allow create: if request.auth != null;
      }

    }
  }
}
