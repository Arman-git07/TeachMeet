/**
 * @description This ruleset enforces a role-based access control model for meetings and join requests.
 *   Meetings can be created by any authenticated user. Only the host of a meeting can update or delete it.
 *   Users can create join requests for meetings, and hosts can manage these requests.
 *   Participants data is only writeable by the host
 * @dataStructure
 *   /meetings/{meetingId} - Contains meeting details, with 'hostId' indicating the meeting host.
 *   /meetings/{meetingId}/joinRequests/{requestId} - Contains join requests, with 'userId' indicating the requesting user.
 *   /meetings/{meetingId}/participants/{userId} - Contains participants in a specific meeting.
 * @keySecurityDecisions
 *   - Only authenticated users can create meetings or join requests.
 *   - Only the host can update or delete meetings.
 *   - Listing of meetings is allowed for all users (public read).
 *   - Participants data is only writeable by the host.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resourceOwnerId) {
      return isSignedIn() && request.auth.uid == resourceOwnerId;
    }

    function isExistingOwner(resourceOwnerId) {
        return isOwner(resourceOwnerId) && resource != null;
    }

    /**
     * @description Controls access to meeting documents.
     * @path /meetings/{meetingId}
     * @allow (create) Signed-in user creates a new meeting with themselves as the host.
     * @deny (update) User attempts to update a meeting where they are not the host.
     * @principle Enforces meeting ownership for updates and deletes. Allows public read access.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner(resource.data.hostId);
    }

    /**
     * @description Controls access to join requests for a specific meeting.
     * @path /meetings/{meetingId}/joinRequests/{requestId}
     * @allow (create) User creates their own join request.
     * @allow (read, update, delete) Host of the meeting manages join requests.
     * @deny (create) User attempts to create a join request for another user.
     * @principle Users can only create their own join requests, and hosts manage them.
     */
    match /meetings/{meetingId}/joinRequests/{requestId} {
      allow create: if isSignedIn() && request.auth.uid == requestId;
      allow get, list, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid);
    }

    /**
     * @description Controls access to participants in a specific meeting.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (create, update, delete) Host of the meeting manages participants.
     * @deny (create) Non-host attempts to add participants
     * @principle Only the host can add, update, or delete participants.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

        /**
     * @description Controls access to join requests for a specific classroom.
     * @path /classrooms/{classroomId}/joinRequests/{requestId}
     * @allow (create) User creates their own join request.
     * @allow (read, update, delete) Host of the classroom manages join requests.
     * @deny (create) User attempts to create a join request for another user.
     * @principle Users can only create their own join requests, and hosts manage them.
     */
    match /classrooms/{classroomId}/joinRequests/{requestId} {
      allow create: if isSignedIn() && request.auth.uid == requestId;
      allow get, list, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId == request.auth.uid);
    }

    /**
     * @description Controls access to participants in a specific classroom.
     * @path /classrooms/{classroomId}/participants/{userId}
     * @allow (create, update, delete) Host of the classroom manages participants.
     * @deny (create) Non-host attempts to add participants
     * @principle Only the host can add, update, or delete participants.
     */
    match /classrooms/{classroomId}/participants/{userId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId == request.auth.uid;
    }
  }
}