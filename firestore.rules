
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function isMeetingCreator(meetingId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
    }

    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);

      // Allow creator to update everything.
      // Allow any authenticated user to add themselves to pendingRequests.
      allow update: if isMeetingCreator(meetingId) || 
                      (isUserAuthenticated() && request.resource.data.diff(request.resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                       request.resource.data.pendingRequests == request.resource.data.pendingRequests.remove(request.auth.uid).add(request.auth.uid));
      
      allow delete: if isMeetingCreator(meetingId);

      match /participants/{participantId} {
        allow list, read: if isUserAuthenticated();
        allow create, update: if isOwner(participantId) || isMeetingCreator(meetingId);
        allow delete: if isOwner(participantId) || isMeetingCreator(meetingId);
      }
    }

    // ===== USERS, DOCUMENTS, RECORDINGS =====
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if isOwner(request.resource.data.uploaderId);
      allow update, delete: if isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if isOwner(request.resource.data.uploaderId);
      allow update, delete: if isOwner(resource.data.uploaderId);
    }

    // ===== TEACHINGS =====
    match /teachings/{teachingId} {
      // Allow reads if public or if the user is in the allowedStudents list.
      allow read, list: if resource.data.isPublic == true || (isUserAuthenticated() && resource.data.allowedStudents.hasAny([request.auth.uid]));

      // Allow creation if the creatorId matches the user's uid.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      
      // Allow updates/deletes only by the original creator.
      allow update, delete: if isUserAuthenticated() && get(/databases/$(database)/documents/teachings/$(teachingId)).data.creatorId == request.auth.uid;
    }

    // ===== FCM TOKENS & MISC =====
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
