rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      // Anyone authenticated can read meeting details to check validity.
      allow read: if isUserAuthenticated();

      // Only the user creating the meeting can create it, and they must be the creator.
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.creatorId;

      // The creator can update/delete the meeting.
      // Participants can update the list of pending requests (to add themselves).
      allow update: if (isUserAuthenticated() && request.auth.uid == resource.data.creatorId) ||
                       (isUserAuthenticated() && request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]));

      allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.creatorId;

      match /participants/{participantId} {
        allow read, list: if isUserAuthenticated();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
      }
    }

    // ===== TEACHINGS (CLASSROOMS) =====
    match /teachings/{teachingId} {
      allow list, read: if isUserAuthenticated();
      
      // Allow creation if the user is authenticated and sets themselves as the creator.
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.creatorId;

      // Allow updates by the creator OR if a user is adding themselves to pendingRequests.
      allow update: if (isUserAuthenticated() && request.auth.uid == resource.data.creatorId) ||
                       (isUserAuthenticated() && request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]));

      // Allow deletion only by the creator.
      allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.creatorId;
    }
    
    // ===== DOCUMENTS & RECORDINGS =====
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
        allow list: if isUserAuthenticated();
        allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
        allow list: if isUserAuthenticated();
        allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }

    // ===== FCM TOKENS =====
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
