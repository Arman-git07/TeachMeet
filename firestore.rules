/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model for meetings and join requests.
 * All data is nested under /meetings/{meetingId} or /classrooms/{classroomId}.
 *
 * Key Security Decisions:
 * - Users can request to join a meeting.
 * - The meeting host can approve or deny join requests.
 * - Participants can be listed, but this feature is implicitly disabled due to lack of front-end code.
 * - The schema is not strictly enforced to allow for rapid prototyping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read and write access to meeting documents. Write access is only permitted for meeting creators.
     * @path /meetings/{meetingId}
     * @allow (get, list): if true;
     * @allow (create): if request.auth.uid != null && request.resource.data.hostId == request.auth.uid;
     * @allow (update, delete): if resource.data.hostId == request.auth.uid && resource != null;
     * @deny create: if request.auth.uid == null;
     * @deny update: if resource == null;
     * @deny delete: if resource == null;
     * @principle Enforces creator-only write access for meetings. Allows public reads.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.hostId);
      allow delete: if isExistingOwner(resource.data.hostId);
    }

    /**
     * @description Allows participants to request to join a meeting, and the host to approve or deny those requests.
     * @path /meetings/{meetingId}/joinRequests/{participantId}
     * @allow (create): if request.auth.uid == request.resource.data.userId;
     * @allow (update): if get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
     * @allow (get): if request.auth.uid == resource.data.userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
     * @allow (list): if get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
     * @allow (delete): if false;
     * @deny create: if request.auth.uid != request.resource.data.userId;
     * @deny update: if get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId != request.auth.uid;
     * @deny get: if request.auth.uid != resource.data.userId && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId != request.auth.uid;
     * @principle Enforces ownership for creating join requests and host-only approval/denial.
     */
    match /meetings/{meetingId}/joinRequests/{participantId} {
      allow get: if isJoinRequestReader(meetingId, participantId);
      allow list: if isMeetingHost(meetingId);
      allow create: if isSignedIn() && request.auth.uid == participantId && request.resource.data.userId == request.auth.uid;
      allow update: if isMeetingHost(meetingId) && resource != null;
      allow delete: if false;
    }

    /**
     * @description Allows read and write access to participant documents. Write access is restricted to the host of the meeting.
     * @path /meetings/{meetingId}/participants/{userId}
     */
    match /meetings/{meetingId}/participants/{userId} {
          allow get: if true;
          allow list: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if false;
    }

    /**
     * @description Allows read and write access to classroom documents. Write access is only permitted for classroom creators.
     * @path /classrooms/{classroomId}
     */
    match /classrooms/{classroomId} {
          allow get: if true;
          allow list: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if false;
    }

    /**
     * @description Allows participants to request to join a classroom, and the host to approve or deny those requests.
     * @path /classrooms/{classroomId}/joinRequests/{participantId}
     */
    match /classrooms/{classroomId}/joinRequests/{participantId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows read and write access to participant documents. Write access is restricted to the host of the classroom.
     * @path /classrooms/{classroomId}/participants/{userId}
     */
    match /classrooms/{classroomId}/participants/{userId} {
          allow get: if true;
          allow list: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isMeetingHost(meetingId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    function isJoinRequestReader(meetingId, participantId) {
        return request.auth.uid == participantId || isMeetingHost(meetingId);
    }
  }
}