
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to manage their own FCM tokens
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for meetings
    match /meetings/{meetingId} {
      // Anyone authenticated can read the meeting details to check for the host, etc.
      allow read: if request.auth != null;

      // Only authenticated users can create a meeting, and they must be the creator.
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // Allow authenticated users to add themselves to pendingRequests.
      // Allow the host to add/remove members.
      allow update: if request.auth != null && (
        (request.resource.data.pendingRequests == request.data.pendingRequests.diff(request.resource.data.pendingRequests).added() &&
         request.data.pendingRequests.diff(request.resource.data.pendingRequests).added().size() == 1 &&
         request.data.pendingRequests.diff(request.resource.data.pendingRequests).added()[0] == request.auth.uid) ||
        (request.auth.uid == resource.data.creatorId)
      );

      // Rules for participants subcollection
      match /participants/{participantId} {
        // Any authenticated user can join a meeting (create their participant doc)
        allow create: if request.auth != null && request.auth.uid == participantId;
        
        // A participant can only read their own document or the host can read any.
        allow read: if request.auth != null && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
        
        // A participant can only update or delete their own document.
        allow update, delete: if request.auth != null && request.auth.uid == participantId;
      }
    }

    // Rules for documents and recordings
    match /{collection}/{docId} {
      // Allow read access to any document/recording that is not private.
      allow read: if resource.data.isPrivate == false;
      
      // Allow read/delete access if the user is the one who uploaded it.
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;

      // Allow any authenticated user to create a document/recording.
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
    }

    // Rules for teachings
    match /teachings/{teachingId} {
      // Any authenticated user can see public teachings or teachings they are a member of.
      allow read: if request.auth != null && (resource.data.isPublic == true || request.auth.uid in resource.data.members);

      // Any authenticated user can create a teaching, but must be the creator and an initial member.
      allow create: if request.auth != null 
                    && request.resource.data.creatorId == request.auth.uid
                    && request.auth.uid in request.resource.data.members;

      // Only the creator can update/delete their teaching.
      // Any authenticated user can request to join (add themselves to pendingRequests).
      allow update: if request.auth != null && (
        // Creator can edit title, desc, isPublic, members, and pending requests
        (request.auth.uid == resource.data.creatorId) ||
        // Any user can add themselves to pending requests
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );

      // Only the creator can delete a teaching.
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }
  }
}
