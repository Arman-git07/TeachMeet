rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Allow anyone to read public documents and recordings.
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false;
      allow get, list, create, update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false;
        allow get, list, create, update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // Allow user to add themselves to pendingRequests
      allow update: if request.auth != null && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                       request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]);
      
      // Allow host to manage members and requests
      allow update: if request.auth != null && request.auth.uid == resource.data.creatorId;

      match /participants/{participantId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == participantId;
        allow list: if request.auth != null;
      }
    }
    
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /teachings/{teachingId} {
      // Allow anyone to read public teachings
      allow read: if resource.data.isPublic == true;
      // Allow members to read private teachings they are part of
      allow read: if request.auth != null && request.auth.uid in resource.data.members;

      // Allow creating a teaching if the user is authenticated and sets themselves as creator and member.
      // This is the definitive fix for the saving issue.
      allow create: if request.auth != null 
                    && request.resource.data.creatorId == request.auth.uid
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members.size() == 1
                    && request.resource.data.pendingRequests.size() == 0
                    && request.resource.data.title is string
                    && request.resource.data.description is string
                    && request.resource.data.isPublic is bool
                    && request.resource.data.creatorName is string;

      // Allow a user to add their own ID to the pendingRequests array (request to join)
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests'])
                    && request.resource.data.pendingRequests == resource.data.pendingRequests.union([request.auth.uid]);
                      
      // Allow the creator to update the teaching (title, description, isPublic)
      // and manage members/requests.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }
  }
}
