rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check for authentication
    function signedIn() {
      return request.auth != null;
    }

    // Rules for the 'meetings' collection
    match /meetings/{meetingId} {
      // Any signed-in user can create a meeting document.
      allow create: if signedIn();
      
      // Any signed-in user can read meeting details (e.g., to find the hostId).
      allow read: if signedIn();
      
      // Only the user whose UID matches the 'hostId' in the document can update or delete it.
      allow update, delete: if signedIn() && request.auth.uid == resource.data.hostId;

      // Rules for subcollections within a meeting
      match /{subcollection}/{docId} {
        // Any signed-in user can create documents in subcollections (e.g., joinRequests, participants).
        allow create, read, update, delete: if signedIn();
      }
    }

    // Rules for the 'users' collection
    match /users/{userId}/{document=**} {
      // Users can read and write to their own documents.
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Rules for the 'classrooms' collection
    match /classrooms/{classroomId} {
        // Public classrooms can be read by anyone, private ones require authentication.
        allow read: if resource.data.isPublic == true || signedIn();
        
        // Only authenticated users can create classrooms.
        allow create: if signedIn();

        // Only the teacher/creator can update or delete the classroom.
        allow update, delete: if signedIn() && request.auth.uid == resource.data.teacherId;

        // Subcollection rules
        match /{subcollection}/{docId} {
            allow read, write: if signedIn();
        }
    }
    
    // Rules for the 'documents' collection
    match /documents/{docId} {
        // Allow read if the document is not private, or if the user is the uploader.
        allow read: if resource.data.isPrivate == false || (signedIn() && request.auth.uid == resource.data.uploaderId);
        
        // Allow create for any signed-in user.
        allow create: if signedIn();
        
        // Allow delete only for the user who uploaded the document.
        allow delete: if signedIn() && request.auth.uid == resource.data.uploaderId;
    }

    // Rules for the 'recordings' collection
    match /recordings/{recId} {
        // Allow read if the recording is not private, or if the user is the uploader.
        allow read: if resource.data.isPrivate == false || (signedIn() && request.auth.uid == resource.data.uploaderId);
        
        // Allow create for any signed-in user.
        allow create: if signedIn();
        
        // Allow delete only for the user who uploaded the recording.
        allow delete: if signedIn() && request.auth.uid == resource.data.uploaderId;
    }
    
    // Rules for FCM tokens
    match /fcmTokens/{userId} {
        // Allow users to write their own FCM token.
        allow write: if signedIn() && request.auth.uid == userId;
    }
  }
}
