rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /classrooms/{classroomId} {
      // Allow authenticated users to read classroom data
      allow read: if request.auth != null;

      // Only the classroom owner (teacherId) can update the main classroom document
      allow write: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Announcements subcollection
      match /announcements/{announcementId} {
        // Anyone authenticated can read announcements
        allow read: if request.auth != null;

        // Only authorized participants (teachers/creator) can create announcements
        allow create: if request.auth != null &&
                      exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
                      get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';

        // Only the creator of the announcement can delete it.
        allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
      }

      // Participants subcollection
      match /participants/{participantId} {
        // Allow classroom owner to add/remove participants. Allow participants to view others.
        allow read, write: if request.auth != null &&
                       (request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId ||
                        participantId == request.auth.uid);
      }
      
      // Teachers subcollection (for subject teachers)
       match /teachers/{teacherId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && 
                      get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }

      // Join requests subcollection
      match /joinRequests/{userId} {
        // Logged-in users can create their own join request.
        allow create: if request.auth != null && request.auth.uid == userId;

        // Classroom owner can read/delete requests. User can delete their own request.
        allow read, delete: if request.auth != null &&
                      (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid ||
                       userId == request.auth.uid);
      }

      // Assignments subcollection
      match /assignments/{assignmentId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null &&
                                     exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
                                     get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
        
        // Submissions for an assignment
        match /submissions/{submissionId} {
            allow read: if request.auth != null;
            // Student can create, teacher can update (grade)
            allow create: if request.auth != null && resource.data.studentId == request.auth.uid;
            allow update: if request.auth != null &&
                        exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
                        get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
        }
      }
      
      // Materials subcollection
      match /materials/{materialId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null &&
                                exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
                                get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
      }
      
      // Exams subcollection
       match /exams/{examId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null &&
                                exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)) &&
                                get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role == 'teacher';
      }
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
       match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Rules for top-level collections like documents and recordings
    match /documents/{documentId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && resource.data.uploaderId == request.auth.uid);
       allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
       allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && resource.data.uploaderId == request.auth.uid);
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

     match /meetings/{meetingId} {
      allow read, write: if request.auth != null;
      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }
       match /joinRequests/{userId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && (get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid || userId == request.auth.uid);
        allow read: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }
    
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
