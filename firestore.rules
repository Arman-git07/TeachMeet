/**
 * @file Overview
 * This ruleset enforces a role-based access control model for meetings and their associated data.
 *
 * Data Structure:
 * - /meetings/{meetingId}: Contains meeting metadata, including the host's user ID.
 * - /meetings/{meetingId}/joinRequests/{requestId}: Contains requests from users to join a meeting.
 * - /meetings/{meetingId}/participants/{userId}: Contains a list of participants for a given meeting.
 *
 * Key Security Decisions:
 * - Public read access to meeting metadata is permitted.
 * - Only the meeting host can modify or delete meeting documents.
 * - Any authenticated user can create a join request.
 * - The host can read, update, and delete join requests.
 * - Participants can read their own join request.
 * - Authenticated users can read the list of participants.
 * - Only the meeting host can add or remove participants.
 *
 * Denormalization for Authorization:
 * - The `Meeting` document contains the `creatorId` (host ID), enabling direct ownership checks without additional reads.
 *
 * Structural Segregation:
 * - Join requests and participants are stored in subcollections to maintain a clear separation of concerns.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    /**
     * @description Controls access to meeting documents.
     * @path /meetings/{meetingId}
     * @allow (get, list): Any user can read meeting info.
     * @allow (create, update, delete): Only the meeting host can modify meeting details.
     * @deny (create, update, delete): Non-authenticated users cannot create, update, or delete meetings.
     * @principle Public read access with owner-only writes.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthenticated() && isOwner(request.resource.data.creatorId);

      /**
       * @description Controls access to join requests for a meeting.
       * @path /meetings/{meetingId}/joinRequests/{requestId}
       * @allow (create): Any authenticated user can create a join request.
       * @allow (read, update, delete): Only the host can read, update, or delete join requests, and the request creator can read their own request.
       * @deny (create): Non-authenticated users cannot create join requests.
       * @deny (update, delete): Non-hosts and non-requesters cannot update/delete join requests.
       * @principle Limits access to join requests to the host and the requesting user.
       */
      match /joinRequests/{requestId} {
        allow create: if isAuthenticated();
        allow read, update, delete: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
        allow read: if isAuthenticated() && isOwner(resource.data.userId);
        allow list: if false;
      }

      /**
       * @description Controls access to the list of participants for a meeting.
       * @path /meetings/{meetingId}/participants/{userId}
       * @allow (read): Any authenticated user can read the list of participants.
       * @allow (write): Only the meeting host can add or remove participants.
       * @deny (write): Non-hosts cannot add/remove participants.
       * @principle Restricts participant management to the meeting host.
       */
      match /participants/{userId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
        allow list: if false;
      }
    }
  }
}