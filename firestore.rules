rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Other rules...
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /classrooms/{classroomId} {
      allow read: if true; // Public read for discovery
      allow create: if request.auth != null; // Anyone can create, UI should control
      allow update: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      
      // Subcollections
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
      }
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if request.auth != null;
        match /submissions/{submissionId} {
           allow read, create, update, delete: if true; // Allow all for now
        }
      }
      match /materials/{materialId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
       match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
       match /participants/{participantId} {
        allow read, create, update, delete: if true; // Open for now
      }
       match /joinRequests/{requestId} {
        allow read, create, update, delete: if true; // Open for now
      }
       match /teachers/{teacherId} {
        allow read, create, update, delete: if true; // Open for now
      }
    }
  }
}
