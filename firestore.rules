
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if isOwner(request.resource.data.uploaderId);
      allow delete: if isOwner(resource.data.uploaderId);
    }

    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if isOwner(request.resource.data.uploaderId);
      allow delete: if isOwner(resource.data.uploaderId);
    }

    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == request.resource.data.teacherId;
      allow update, delete: if isOwner(resource.data.teacherId);
      
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if signedIn() && (isOwner(request.resource.data.authorId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId));
        allow delete: if isOwner(resource.data.authorId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

      match /materials/{materialId} {
        allow read: if true;
        allow create: if signedIn() && (isOwner(request.resource.data.uploaderId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId));
        allow delete: if isOwner(resource.data.uploaderId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /joinRequests/{requestId} {
        allow create: if signedIn() && (request.auth.uid == request.resource.data.requesterId);
        allow read: if signedIn();
        allow delete: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId || request.auth.uid == requestId;
        allow update: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /participants/{participantId} {
        allow read: if true;
        allow create, update: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        allow delete: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || isOwner(participantId);
      }
      
      match /teachers/{teacherId} {
        allow read: if true;
        allow create, update, delete: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        allow delete: if isOwner(resource.data.creatorId);

        match /submissions/{submissionId} {
            allow read: if true;
            allow create, update: if isOwner(submissionId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
            allow delete: if isOwner(submissionId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        }
      }

      match /exams/{examId} {
        allow read: if true;
        allow create: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        allow delete: if isOwner(resource.data.authorId);
      }
    }
    
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.hostId);
      allow update: if isOwner(resource.data.hostId);

      match /joinRequests/{requestId} {
        allow create: if signedIn();
        allow read, update, delete: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId) || isOwner(resource.data.userId);
      }

      match /participants/{participantId} {
        allow read: if true;
        allow create, delete: if isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
        allow update: if isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }
    }
  }
}
