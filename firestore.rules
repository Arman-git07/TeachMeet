
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow read/write to subcollections
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Classroom documents
    match /classrooms/{classroomId} {
      // Public classrooms can be read by any authenticated user
      allow read: if request.auth != null && (resource.data.isPublic == true || request.auth.uid == resource.data.teacherId);
      
      // Only the teacher who created the classroom can update or delete it
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
      
      // Subcollection rules
      match /{subcollection}/{docId} {
        // Teacher has full access
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        
        // Enrolled students can read content
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students;
      }
      
      // Specific rule for join requests
      match /joinRequests/{userId} {
        // Any authenticated user can create their own join request
        allow create: if request.auth != null && request.auth.uid == userId;
        // Host can read/delete
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
    }

    // Meeting documents
    match /meetings/{meetingId} {
        // Any authenticated user can read meeting details (like topic, host)
        allow read: if request.auth != null;
        
        // Only the host can create the meeting document
        allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
        
        // Only the host can update or delete the meeting
        allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;

        // Rules for subcollections within a meeting
        match /{subcollection}/{docId} {
            // The host has full read/write access to all subcollections
            allow read, write: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        }

        // Specific rule for join requests
        match /joinRequests/{userId} {
            // Any authenticated user can create their OWN join request.
            allow create: if request.auth != null && request.auth.uid == userId;
        }
        
        // Specific rule for participants list
        match /participants/{userId} {
            // Allow participants to read their own entry and other participant entries
            allow read: if request.auth != null;
            // A user can remove themselves (leave the meeting)
            allow delete: if request.auth != null && request.auth.uid == userId;
        }
    }

    // Document and Recording collections
    match /(documents|recordings)/{docId} {
      // Allow create for any authenticated user
      allow create: if request.auth != null;
      
      // Allow read if the document is public OR if the user is the one who uploaded it
      allow read: if request.auth != null && (resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId);
      
      // Allow update/delete only for the user who uploaded it
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
