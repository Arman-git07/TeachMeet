rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      
      // Anyone can read a user's public subcollections, but only owner can write
      match /enrolled/{classroomId} {
        allow read: if isAuthenticated();
        allow write: if request.auth.uid == userId;
      }
    }
    
    match /fcmTokens/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /classrooms/{classroomId} {
      // Allow authenticated users to create classrooms
      allow create: if isAuthenticated();
      
      // Allow anyone to read public classrooms, and authenticated users to read private ones they are a member of (future)
      allow read: if resource.data.isPublic == true || 
                    (isAuthenticated() && exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid))); // Example for enrolled students
      
      // Only the teacher can update or delete the classroom
      allow update, delete: if resource.data.teacherId == request.auth.uid;

      // Rules for classroom subcollections
      match /joinRequests/{userId} {
        // Any authenticated user can create a request for themselves
        allow create: if isAuthenticated() && request.auth.uid == userId;
        // Only the classroom teacher can read/delete requests
        allow read, delete: if get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }

      match /{subcollection}/{docId} {
        // Teacher has full access
        allow read, write: if get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        
        // Enrolled students can read certain subcollections
        allow read: if (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrolled/$(classroomId))) &&
                       (subcollection == 'announcements' || subcollection == 'materials' || subcollection == 'assignments');
      }
    }
    
    match /meetings/{meetingId} {
      // Allow authenticated users to create (start) meetings
      allow create: if isAuthenticated();

      // The creator can read and delete their own meeting document
      allow read, delete: if resource.data.creatorId == request.auth.uid;

      match /participants/{userId} {
        // A user can add themselves to the participants list.
        allow create: if request.auth.uid == userId;
        
        // Any authenticated user in the meeting can read the participants list.
        allow read: if isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));

        // A user can only update or delete their own participant document.
        allow update, delete: if request.auth.uid == userId;
      }
      
      match /joinRequests/{userId} {
         // Any authenticated user can request to join.
         allow create: if request.auth.uid == userId;
         // Only the meeting creator (host) can read/delete requests.
         allow read, delete: if get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }
    
    match /documents/{documentId} {
      // Allow create for any authenticated user
      allow create: if isAuthenticated();
      // Allow read if the document is not private OR if the user is the owner
      allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
      // Allow update/delete only for the user who uploaded it
      allow update, delete: if resource.data.uploaderId == request.auth.uid;
    }
    
    match /recordings/{recordingId} {
       // Allow create for any authenticated user
      allow create: if isAuthenticated();
      // Allow read if the recording is not private OR if the user is the owner
      allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
      // Allow update/delete only for the user who uploaded it
      allow update, delete: if resource.data.uploaderId == request.auth.uid;
    }
  }
}
