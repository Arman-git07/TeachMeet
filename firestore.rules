rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for user profiles
    match /users/{userId} {
      allow read: if true;
      // Allow users to create their own profile and update it.
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Subcollections for user-specific data
      match /enrolled/{classroomId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /pendingJoinRequests/{classroomId} {
         allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rules for classrooms
    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Only the original creator of the classroom can update or delete it.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Announcements: can be deleted by the person who posted it (authorId) or the classroom creator.
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
      }

      // Materials: can be deleted by the uploader or the classroom creator.
      match /materials/{materialId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
      }
      
      // Assignments: can be deleted by the uploader or the classroom creator.
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
         match /submissions/{submissionId} {
           allow read, create, update: if request.auth != null;
         }
      }
      
      // Exams: can be deleted by the uploader or the classroom creator.
      match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
      }

      // Join Requests: any authenticated user can request to join, only creator can manage.
      match /joinRequests/{requestId} {
        allow read, delete: if request.auth != null && (
          request.auth.uid == requestId || 
          get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid
        );
        allow create: if request.auth != null;
      }
      
      // Participants & Teachers subcollections managed by classroom creator
      match /participants/{participantId} {
          allow read: if true;
          allow write, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }
       match /teachers/{teacherId} {
          allow read: if true;
          allow write, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }
    }
    
    // Meetings
    match /meetings/{meetingId} {
      allow read, write, delete: if request.auth != null;
      match /participants/{participantId} {
        allow read, write, delete: if request.auth != null;
      }
       match /joinRequests/{requestId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null && (
            request.auth.uid == requestId ||
            get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid
        );
      }
    }
    
     // Documents
    match /documents/{documentId} {
       allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
       allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
       allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
     // Recordings
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
       allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
       allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
  }
}
