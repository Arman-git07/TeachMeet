rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isClassroomCreator(classroomId) {
      return get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
    }
    function isTeacher(classroomId) {
      // Check if user is in the teachers subcollection
      return exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid));
    }
    function isEnrolled(classroomId) {
      // User is enrolled if they are the creator, a teacher, or a student.
      return isClassroomCreator(classroomId) || isTeacher(classroomId) || exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid));
    }

    // USERS: Allow users to manage their own data and see public profiles
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);

      // Subcollections for user-specific data
      match /enrolled/{classroomId} {
        allow read, write: if isOwner(userId);
      }
      match /pendingJoinRequests/{classroomId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // FCM TOKENS: Allow users to write their own token
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // CLASSROOMS: Rules for creating, viewing, and managing classrooms
    match /classrooms/{classroomId} {
      allow read: if isAuth(); // Allow any authenticated user to discover classrooms
      allow create: if isAuth(); // Any authenticated user can create a classroom
      allow update, delete: if isClassroomCreator(classroomId);

      // Classroom Subcollections
      
      // ANNOUNCEMENTS, MATERIALS, ASSIGNMENTS, EXAMS
      match /{subcollection=**} {
         // Default deny all
      }

      match /announcements/{announcementId} {
        allow read: if isEnrolled(classroomId);
        allow create, delete: if isClassroomCreator(classroomId) || isTeacher(classroomId);
      }
      match /materials/{materialId} {
        allow read: if isEnrolled(classroomId);
        allow create, delete: if isClassroomCreator(classroomId) || isTeacher(classroomId);
      }
      match /assignments/{assignmentId} {
        allow read: if isEnrolled(classroomId);
        allow create, delete: if isClassroomCreator(classroomId) || isTeacher(classroomId);
        
        // Submissions for an assignment
        match /submissions/{studentId} {
          allow read: if isOwner(studentId) || isClassroomCreator(classroomId) || isTeacher(classroomId);
          allow create, update: if isOwner(studentId); // Students can submit/update
          allow update: if isClassroomCreator(classroomId) || isTeacher(classroomId); // Teachers can grade
        }
      }
      match /exams/{examId} {
        allow read: if isEnrolled(classroomId);
        allow create, delete: if isClassroomCreator(classroomId) || isTeacher(classroomId);
      }

      // PARTICIPANTS & TEACHERS (Management)
      match /participants/{participantId} {
        allow read: if isEnrolled(classroomId);
        allow create, delete: if isClassroomCreator(classroomId);
      }
      match /teachers/{teacherId} {
        allow read: if isEnrolled(classroomId);
        allow create, delete: if isClassroomCreator(classroomId);
      }

      // JOIN REQUESTS
      match /joinRequests/{userId} {
        allow create: if isAuth() && isOwner(userId); // Users can create their own request
        allow read, delete: if isClassroomCreator(classroomId);
      }
    }

    // DOCUMENTS & RECORDINGS: Public/Private access control
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (isAuth() && resource.data.uploaderId == request.auth.uid);
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.uploaderId == request.auth.uid;
    }
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (isAuth() && resource.data.uploaderId == request.auth.uid);
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.uploaderId == request.auth.uid;
    }
    
    // MEETINGS: Logic for real-time meeting state
    match /meetings/{meetingId} {
      allow read: if isAuth();
      allow create: if isAuth(); // Anyone can create a meeting doc
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid; // Only creator can delete meeting
      
      match /participants/{participantId} {
        allow read: if isAuth();
        allow create, update: if isAuth() && request.auth.uid == participantId; // Participants can only manage their own status
        allow delete: if isAuth() && (request.auth.uid == participantId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid); // Self or host can remove
      }
    }
  }
}
