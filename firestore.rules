
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function cls(path) {
      return get(/databases/$(database)/documents/$(path)).data;
    }
    function isCreator(classId) {
      let c = cls("classrooms/" + classId);
      return request.auth != null && (
        c.createdBy == request.auth.uid ||
        c.creatorId == request.auth.uid ||
        c.ownerId == request.auth.uid ||
        c.teacherId == request.auth.uid  // legacy
      );
    }
    function isSubjectTeacher(classId) {
      let c = cls("classrooms/" + classId);
      let teacherList = c.teachers; // new shape is array of objects
      return request.auth != null && (
        (c.subjectTeachers is list && request.auth.uid in c.subjectTeachers) ||
        (c.teachers is list && (request.auth.uid in c.teachers || (teacherList[0].uid is string && request.auth.uid in teacherList.map(t => t.uid)))) ||
        exists(/databases/$(database)/documents/classrooms/$(classId)/teachers/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/classrooms/$(classId)/subjectTeachers/$(request.auth.uid))
      );
    }
    function isStudent(classId) {
      let c = cls("classrooms/" + classId);
      return request.auth != null && (
        (c.students is list && request.auth.uid in c.students) ||
        (c.members is list && request.auth.uid in c.members) ||
        (c.enrolled is list && request.auth.uid in c.enrolled) ||
        exists(/databases/$(database)/documents/classrooms/$(classId)/students/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid))
      );
    }
    function canPost(classId) { return isCreator(classId) || isSubjectTeacher(classId); }

    match /classrooms/{classId} {
      allow read: if true; // or restrict as you need
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid; // Check legacy teacherId on creation
      allow update, delete: if isCreator(classId);

      // joinRequests
      match /joinRequests/{userId} {
        allow create: if request.auth.uid == userId;
        allow read, delete: if isCreator(classId);
      }

      // Teachers subcollection
      match /teachers/{teacherId} {
        allow read: if true;
        allow create, delete: if isCreator(classId);
      }

      // Participants subcollection
      match /participants/{participantId} {
        allow read: if true;
        allow create, delete: if isCreator(classId);
      }

      match /announcements/{annId} {
        allow read: if true;
        allow create: if canPost(classId) && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if canPost(classId);
      }

      match /materials/{matId} {
        allow read: if true;
        allow create, update, delete: if canPost(classId);
      }

      match /assignments/{assId} {
        allow read: if isCreator(classId) || isSubjectTeacher(classId) || isStudent(classId);
        allow create, update, delete: if canPost(classId);
        
        match /submissions/{studentId} {
            allow read: if isCreator(classId) || isSubjectTeacher(classId) || request.auth.uid == studentId;
            allow create, update: if request.auth.uid == studentId;
            allow delete: if isCreator(classId) || isSubjectTeacher(classId);
        }
      }

      match /exams/{examId} {
        allow read: if isCreator(classId) || isSubjectTeacher(classId) || isStudent(classId);
        allow create, update, delete: if canPost(classId);
      }
    }

     // User-specific subcollections
    match /users/{userId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
