
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);

      // Only the creator can change the topic or officially delete the meeting room.
      allow update: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      allow delete: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);

      // Rules for participants in a meeting
      match /participants/{participantId} {
        allow read, list: if isUserAuthenticated();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
    }
    
    // ===== TEACHINGS (CLASSROOMS) =====
    match /teachings/{teachingId} {
      // Allow any authenticated user to see the list of teachings and read public ones.
      allow list, read: if isUserAuthenticated();
      
      // Allow creation if the user is authenticated and sets themselves as the creator.
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.creatorId;

      // Allow updates only by the creator, OR for a user to add THEMSELVES to pendingRequests.
      allow update: if (isUserAuthenticated() && request.auth.uid == resource.data.creatorId) ||
                     (isUserAuthenticated() && request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]));

      // Allow deletion only by the creator.
      allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.creatorId;
    }

    // ===== USER DATA (DOCUMENTS & RECORDINGS) =====
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && request.auth.uid == resource.data.uploaderId);
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && request.auth.uid == resource.data.uploaderId);
       allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.uploaderId;
       allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.uploaderId;
    }

    // ===== FCM TOKENS =====
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
    