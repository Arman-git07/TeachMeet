rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read/write their own user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to manage their own enrolled classes subcollection
      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rules for classrooms
    match /classrooms/{classroomId} {
      // Anyone can read public classrooms, only the teacher can read their own private ones.
      allow read: if resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.teacherId);
      
      // Only authenticated users can create classrooms
      allow create: if request.auth != null;
      
      // Only the teacher who created the classroom can update it.
      allow update: if request.auth != null && request.auth.uid == resource.data.teacherId;
      
      // Only the teacher who created the classroom can delete it.
      allow delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
      
      // Join requests subcollection
      match /joinRequests/{studentId} {
        // Any authenticated user can create a request for themselves.
        allow create: if request.auth != null && request.auth.uid == studentId;
        
        // Only the teacher can read or delete requests for their classroom.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // Rules for meetings
    match /meetings/{meetingId} {
      // Allow any authenticated user to create a meeting document.
      allow create: if request.auth != null;
      
      // Anyone can read meeting details (like the topic or creator).
      allow read: if true;
      
      // Only the creator can update or delete the main meeting document.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.creatorId;

      // Participants subcollection
      match /participants/{userId} {
        // Anyone can read the participant list.
        allow read: if true;
        
        // A user can only create/update their own participant document. This is key.
        allow create, update: if request.auth != null && request.auth.uid == userId;

        // A user can delete their own participant document (i.e., leave the meeting).
        // The host can also remove other participants.
        allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
      
      // Join requests subcollection for meetings
      match /joinRequests/{userId} {
         // An authenticated user can create a request to join a meeting.
        allow create: if request.auth != null && request.auth.uid == userId;

        // The meeting host can read and delete join requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
      }
    }
    
    // Allow reads for public documents and for the uploader of private documents.
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // Allow reads for public recordings and for the uploader of private recordings.
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    // Allow users to write their own FCM token for push notifications
    match /fcmTokens/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
