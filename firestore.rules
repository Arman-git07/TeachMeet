
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isTeacher(classroomId) {
      return resource.data.teacherId == request.auth.uid;
    }
    
    // Classroom Rules
    match /classrooms/{classroomId} {
      // Anyone signed in can see public classrooms
      allow read: if isSignedIn() && resource.data.isPublic == true;
      // Only the teacher can read their own private classroom details directly
      allow get: if isSignedIn() && (resource.data.isPublic == true || isTeacher(classroomId));
      // Any signed in user can create a classroom, becoming its teacher
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      // Only the teacher can update or delete their classroom
      allow update, delete: if isTeacher(classroomId);

      // Subcollection Rules
      match /joinRequests/{userId} {
        // Any signed-in user can create a request for themselves
        allow create: if isUser(userId);
        // Teacher can read/delete any request for their class
        allow read, delete: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }

      // Optimized Rule for collectionGroup query on 'joinRequests'
      // This is a global rule for the 'joinRequests' collection group
      match /{path=**}/joinRequests/{requestId} {
        // A user can read a join request if the request's studentId matches their own uid.
        allow get, list: if isSignedIn() && resource.data.studentId == request.auth.uid;
      }
      
      match /announcements/{announcementId} {
        // Teacher can create announcements
        allow create: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        // Authenticated users can read announcements (assuming they have access to the classroom)
        allow read: if isSignedIn();
        // Only teacher can delete
        allow delete, update: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
      match /materials/{materialId} {
        // Teacher can create materials
        allow create: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        // Authenticated users can read materials
        allow read: if isSignedIn();
        // Only teacher can delete
        allow delete, update: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
      match /assignments/{assignmentId} {
         // Teacher can create, update, delete
        allow create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        // Authenticated users can read assignments
        allow read: if isSignedIn();
      }
    }

    // User Data Rules
    match /users/{userId} {
      // Users can only access their own data
      allow read, update, delete, create: if isUser(userId);

      // Enrolled subcollection
      match /enrolled/{classroomId} {
        allow read, create, delete: if isUser(userId);
      }
      // FCM Tokens subcollection
      match /fcmTokens/{token} {
        allow read, write: if isUser(userId);
      }
    }
    
    // Documents Rules
    match /documents/{docId} {
      // Read access: if it's public, or if you are the uploader
      allow read: if isSignedIn() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      // Write access: only the uploader can update or delete
      allow update, delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
      // Create access: any signed in user can create a document
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
    }
    
    // Recordings Rules
    match /recordings/{recId} {
      allow read: if isSignedIn() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow update, delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
    }

    // Meeting Rules
    match /meetings/{meetingId} {
        // Allow create if user is signed in. The creator is set in the document data.
        allow create: if isSignedIn();
        // Allow read if user is signed in (to check for meeting existence).
        allow read: if isSignedIn();
        // Allow delete only if the user is the meeting creator.
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;

        // Participants subcollection
        match /participants/{userId} {
            // A user can join/update their own status
            allow read, write: if isUser(userId);
            // The host can read any participant document to manage the meeting
            allow get: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
        }

        // Join Requests subcollection
        match /joinRequests/{userId} {
            // A user can create their own join request
            allow create: if isUser(userId);
            // Only the host can read and delete join requests
            allow read, delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
        }
    }
  }
}
