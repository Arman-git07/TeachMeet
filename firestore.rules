rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /enrolled/{classroomId} {
        // A teacher can enroll a student, or a user can leave a class (delete)
        allow read, write, delete: if signedIn(); 
      }
      match /pendingJoinRequests/{classroomId} {
        // A teacher can add this when approving, a user can delete it when canceling
        allow read, write, delete: if signedIn();
      }
    }

    match /classrooms/{classroomId} {
      // Allow authenticated users to query for classrooms (client-side filters will apply)
      allow list, get: if signedIn();

      // Only the teacherId can update or delete a classroom document
      allow update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      
      // Anyone authenticated can create a classroom, as long as they set themselves as the teacher
      allow create: if signedIn() && isOwner(request.resource.data.teacherId);

      match /announcements/{announcementId} {
        allow read: if signedIn();
        allow create, delete, update: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || isOwner(request.resource.data.authorId);
      }
      
      match /materials/{materialId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow delete: if signedIn() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || isOwner(resource.data.uploaderId));
      }

      match /assignments/{assignmentId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        
        match /submissions/{submissionId} {
           allow read, write: if signedIn();
        }
      }

      match /exams/{examId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

      match /teachers/{teacherId} {
        allow read: if signedIn();
        allow create, write, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /joinRequests/{requestId} {
        // A user can create a join request for themselves
        allow create: if signedIn() && request.auth.uid == request.resource.data.requesterId;
        
        // A user can read or cancel their own request. The creator can read all requests.
        allow read: if signedIn() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || isOwner(requestId));
        allow delete: if signedIn() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || isOwner(requestId));

        // Only the creator can approve/deny (update) requests
        allow update: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

      match /participants/{participantId} {
        allow read: if signedIn();
        allow create, write, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
    }

    match /documents/{documentId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
        allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
        allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }

    match /meetings/{meetingId} {
      allow read: if true;
      allow create, update: if signedIn() && isOwner(request.resource.data.hostId);
      allow delete: if signedIn() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);

      match /joinRequests/{userId} {
        allow create: if signedIn() && request.auth.uid == userId;
        allow read: if signedIn() && (isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId) || isOwner(userId));
        allow update, delete: if signedIn() && (isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId));
      }

      match /participants/{userId} {
        allow read: if true;
        allow write, delete: if signedIn() && (isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId) || isOwner(userId));
      }
    }
  }
}
