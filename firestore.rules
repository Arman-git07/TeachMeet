
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Classes collection rules
    match /classes/{classId} {
      // ANY authenticated user can read the list of classes.
      // (This could be further restricted if needed, e.g., to class members only)
      allow list; 
      // ONLY authenticated users can create a new class document.
      // The `hostId` of the new class MUST match the UID of the user creating it.
      allow create: if isUserAuthenticated() && request.resource.data.hostId == request.auth.uid;
      // Allow reading, updating, and deleting a specific class document
      // only if the user is authenticated and is the owner (host) of the class.
      allow read, update, delete: if isUserAuthenticated() && isOwner(resource.data.hostId);
    }
    
    // Documents collection rules
    match /documents/{documentId} {
      // Allow creating documents for any authenticated user, ensuring they own the document.
      allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
      
      // Public documents can be read by any authenticated user.
      // Private documents can only be read by the owner.
      allow read: if isUserAuthenticated() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      
      // Documents can only be updated or deleted by the owner.
      allow update, delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    // Recordings collection rules
    match /recordings/{recordingId} {
      // Allow creating recordings for any authenticated user, ensuring they own the recording.
      allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
      
      // Public recordings can be read by any authenticated user.
      // Private recordings can only be read by the owner.
      allow read: if isUserAuthenticated() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      
      // Recordings can only be updated or deleted by the owner.
      allow update, delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    // Meeting rules
    match /meetings/{meetingId} {
      // Any authenticated user can create (implicitly start) a meeting document.
      // The creator must set themselves as the creatorId.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      
      // Any authenticated user can read the main meeting document (to get topic, creatorId, etc.).
      allow read: if isUserAuthenticated();
      
      // Only the creator of the meeting can update or delete the main meeting document.
      allow update, delete: if isUserAuthenticated() && isOwner(resource.data.creatorId);

      // Sub-collection for participants within a meeting
      match /participants/{participantId} {
        // A user can only create a participant document for themselves.
        allow create: if isUserAuthenticated() && request.auth.uid == participantId;
        
        // Anyone in the meeting (authenticated user) can see who else is in the meeting.
        allow list, read: if isUserAuthenticated();
        
        // A user can only update or delete their own participant document.
        allow update, delete: if isUserAuthenticated() && request.auth.uid == participantId;
      }
    }
    
    // Default deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
