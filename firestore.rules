
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default deny all reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow users to manage their own FCM tokens
    match /fcmTokens/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
    
    // Rules for meetings
    match /meetings/{meetingId} {
      allow read: if request.auth != null; // Any authenticated user can read meeting details (like creatorId)
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid; // Must be authenticated and creator
      
      // Allow authenticated users to add themselves to the pendingRequests array
      allow update: if request.auth != null 
                     && request.resource.data.creatorId == resource.data.creatorId // Cannot change creatorId
                     && (
                        // Case 1: Host managing requests
                        (request.auth.uid == resource.data.creatorId && 
                         request.resource.data.pendingRequests diff resource.data.pendingRequests).size() > 0
                        ) ||
                        // Case 2: A user requesting to join
                        (request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
                     );
                     
      match /participants/{participantId} {
        allow read: if request.auth != null; // All authenticated users can see participants
        allow create, update: if request.auth.uid == participantId; // Only the participant can add/update their own status
        allow delete: if request.auth.uid == participantId; // Only the participant can remove themselves
      }
    }

    // Rules for teachings
    match /teachings/{teachingId} {
      // Any authenticated user can create a teaching.
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;

      // Anyone can read a public teaching.
      // Members (including creator) can read private teachings.
      allow read: if request.auth != null && 
                     (resource.data.isPublic == true || request.auth.uid in resource.data.members);
      
      // Only the creator can update fields. Students can request to join.
      allow update: if request.auth != null && (
                      // Case 1: Creator updating the document
                      (request.auth.uid == resource.data.creatorId) ||
                      // Case 2: User requesting to join
                      (request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
                    );

      // Only the creator can delete a teaching.
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }
    
    // Rules for documents & recordings (shared structure)
    function canAccessMedia(collectionName) {
      match /{collectionName}/{mediaId} {
        // Any authenticated user can create media.
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;

        // Anyone can read public media.
        // The uploader can read their own private media.
        allow read: if request.auth != null && 
                      (resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId);
                      
        // Only the uploader can update or delete their media.
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
      }
    }

    call canAccessMedia("documents");
    call canAccessMedia("recordings");
  }
}
