rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is the creator of a resource
    function isCreator(resourceId, collectionName) {
      return get(/databases/$(database)/documents/$(collectionName)/$(resourceId)).data.creatorId == request.auth.uid;
    }
    
    // Helper function to check if a user is a member of a resource
    function isMember(resourceId, collectionName) {
      return request.auth.uid in get(/databases/$(database)/documents/$(collectionName)/$(resourceId)).data.members;
    }

    // Meetings Collection
    match /meetings/{meetingId} {
      // ANY authenticated user can CREATE a meeting.
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // ANY authenticated user can READ a meeting document.
      allow read: if request.auth != null;

      // Rules for UPDATING a meeting document. This is critical for join requests.
      allow update: if request.auth != null && (
        // The HOST can update any field they need to.
        isCreator(meetingId, 'meetings') ||
        // ANY authenticated user can add THEIR OWN uid to the pendingRequests list.
        // This is the key fix: it allows users to "Ask to Join".
        (request.resource.data.pendingRequests == resource.data.pendingRequests.diff(request.resource.data.members).concat([request.auth.uid]))
      );
      
      // ONLY the host can DELETE a meeting.
      allow delete: if request.auth != null && isCreator(meetingId, 'meetings');

      // Participants Subcollection
      match /participants/{userId} {
        // A user can only create/delete/update their OWN participant document.
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Teachings Collection
    match /teachings/{teachingId} {
      // ANY authenticated user can CREATE a teaching, ensuring they are the creator.
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;

      // ANY authenticated user can READ public teachings or teachings they are a member of.
      allow read: if request.auth != null && (resource.data.isPublic == true || isMember(teachingId, 'teachings'));
      
      // UPDATE rules for teachings
      allow update: if request.auth != null && (
          // The HOST can update the core details or manage members.
          isCreator(teachingId, 'teachings') ||
          // ANY authenticated user can add THEIR OWN uid to the pendingRequests list.
          (request.resource.data.pendingRequests == resource.data.pendingRequests.diff(request.resource.data.members).concat([request.auth.uid]))
      );
      
      // ONLY the host can DELETE a teaching.
      allow delete: if request.auth != null && isCreator(teachingId, 'teachings');
    }

    // Documents and Recordings (Simplified Rules)
    function canAccessMedia(collectionName) {
      let mediaDoc = get(/databases/$(database)/documents/$(collectionName)/$(request.resource.id));
      return mediaDoc.data.isPrivate == false || mediaDoc.data.uploaderId == request.auth.uid;
    }

    match /documents/{docId} {
      allow read: if request.auth != null && canAccessMedia('documents');
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recId} {
      allow read: if request.auth != null && canAccessMedia('recordings');
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
      // A user can only manage their own FCM token.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
