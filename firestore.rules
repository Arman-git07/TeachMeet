rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isMeetingHost(meetingId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isUser(userId);
    }

    match /classrooms/{classroomId} {
      allow read: if isAuthenticated();
      allow create: if isUser(request.resource.data.teacherId);
      allow update, delete: if isUser(resource.data.teacherId);

      match /joinRequests/{userId} {
        allow create, read, delete: if isAuthenticated();
      }

      match /{subcollection}/{docId} {
        allow read, list: if isAuthenticated(); // More open for simplicity in this prototype
        allow create, update, delete: if isMeetingHost(classroomId); // Simplified rule for subcollections
      }
    }
    
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
      allow create: if isUser(request.resource.data.uploaderId);
      allow delete: if isUser(resource.data.uploaderId);
    }
    
    match /recordings/{docId} {
      allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
      allow create: if isUser(request.resource.data.uploaderId);
      allow delete: if isUser(resource.data.uploaderId);
    }
    
    match /fcmTokens/{userId} {
        allow read, write: if isUser(userId);
    }

    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting if they are the creator
      allow create: if isUser(request.resource.data.creatorId);

      // Only host can update or delete the meeting document
      allow update, delete: if isMeetingHost(meetingId);

      // A user can read a meeting document if they are a participant
      allow read: if isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));

      match /participants/{participantId} {
        // The host can add anyone. A user can add themselves.
        allow create: if isMeetingHost(meetingId) || isUser(participantId);

        // A participant can update their own status (e.g. mic mute)
        // The host can also update participant status (e.g. mute all)
        allow update: if isUser(participantId) || isMeetingHost(meetingId);
        
        // Host can remove a participant. A participant can remove themselves (leave).
        allow delete: if isMeetingHost(meetingId) || isUser(participantId);

        // Any authenticated user can list participants to see who is in the meeting.
        allow list, read: if isAuthenticated();
      }

      match /joinRequests/{userId} {
        // Any user can create their own join request
        allow create: if isUser(userId);

        // Only the host can read and delete join requests
        allow read, delete: if isMeetingHost(meetingId);
      }
    }
  }
}
