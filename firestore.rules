rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users Collection ---
    // Allow users to read their own profile and create it.
    // Deny updates to prevent users from changing roles.
    match /users/{userId} {
      allow read, create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;

       // Allow users to manage their own subcollections
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Classrooms Collection ---
    match /classrooms/{classroomId} {
      // Anyone can read a public classroom, but only members can read private ones.
      allow read: if resource.data.isPublic == true || request.auth.uid in resource.data.students || request.auth.uid == resource.data.teacherId;

      // Only the teacher who created the class can update or delete it.
      allow update, delete: if request.auth.uid == resource.data.teacherId;
      
      // Any authenticated user can create a classroom.
      allow create: if request.auth != null;

      // --- Classroom Subcollections ---
      match /{subcollection}/{docId} {
        // Teacher has full access. Students can read.
        allow read: if request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.students;
        allow write: if request.auth.uid == resource.data.teacherId;
      }
      
      // --- Join Requests ---
      match /joinRequests/{userId} {
        // A user can create their own join request.
        allow create: if request.auth.uid == userId;
        // The classroom teacher can read, update (approve/deny), or delete requests.
        allow read, update, delete: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // --- Meetings Collection ---
    match /meetings/{meetingId} {
      // Any signed-in user can create or update a meeting document
      allow create, update, read: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // --- Participants Subcollection ---
      match /participants/{participantId} {
        // Only the signed-in user can create/update their own participant doc
        allow create, update, read, delete: if request.auth != null
          && request.auth.uid == participantId;
      }
      
      // --- Join Requests (for meetings) ---
       match /joinRequests/{userId} {
        allow create: if request.auth.uid == userId;
        allow read, delete: if request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }
    }

    // --- Documents & Recordings Collections ---
    match /(documents|recordings)/{docId} {
      // Allow read if the document is not private
      allow read: if resource.data.isPrivate == false;
      // Allow read, update, delete if the user is the owner
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
      // Allow any authenticated user to create
      allow create: if request.auth != null;
    }
    
    // --- FCM Tokens Collection ---
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}