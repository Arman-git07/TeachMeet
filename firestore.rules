rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /classrooms/{classId} {
      allow read: if true;

      // Classroom creator can always manage their class
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;

      // Materials subcollection
      match /materials/{materialId} {
        allow read: if true;

        // Create: any signed-in user can post (you can restrict later if needed)
        allow create: if request.auth != null;

        // ✅ Delete allowed if:
        // 1. The material was uploaded by the user (uploaderId)
        // 2. The classroom was created by the user (createdBy in parent doc)
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      // Announcements subcollection
      match /announcements/{announcementId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy ||
          request.auth.uid == resource.data.creatorId
        );
      }

      // Assignments subcollection
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy ||
          request.auth.uid == resource.data.creatorId
        );

        // Submissions nested under assignments
        match /submissions/{submissionId} {
            allow read, create, update: if request.auth != null; // Allow students to submit
            allow delete: if request.auth != null && (
                request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy ||
                request.auth.uid == resource.data.studentId
            );
        }
      }
      
       // Exams subcollection
      match /exams/{examId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy ||
          request.auth.uid == resource.data.creatorId
        );
      }
      
      // Join Requests subcollection
      match /joinRequests/{requestId} {
        allow create: if request.auth != null;
        allow read, delete: if request.auth != null && (
            request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy ||
            request.auth.uid == requestId // User can see their own request
        );
      }
    }

    match /users/{userId} {
        allow read, create, update: if request.auth != null && request.auth.uid == userId;

        match /enrolled/{classroomId} {
            allow read, create: if request.auth != null && request.auth.uid == userId;
            allow delete: if request.auth != null && request.auth.uid == userId;
        }
        match /pendingJoinRequests/{classroomId} {
            allow read, create: if request.auth != null && request.auth.uid == userId;
            allow delete: if request.auth != null && request.auth.uid == userId;
        }
    }

    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
     match /meetings/{meetingId} {
        allow read, create, update: if request.auth != null;
        
        match /participants/{participantId} {
            allow read, create, update, delete: if request.auth != null;
        }
        match /joinRequests/{requestId} {
            allow read, create, update, delete: if request.auth != null;
        }
    }
    
    match /fcmTokens/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
