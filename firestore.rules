rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users can read their own data
    match /users/{userId} {
      allow read, write: if isUser(userId);
      // Public profiles can be read by anyone signed in
      allow read: if isSignedIn();
      
      // Subcollections under user
      match /enrolled/{classroomId} {
        allow read: if isUser(userId);
      }
      match /pendingJoinRequests/{classroomId} {
         allow read: if isUser(userId);
      }
    }

    // Classroom creator can do anything.
    // Enrolled teachers can manage content.
    // Enrolled students can read.
    match /classrooms/{classroomId} {
      allow read: if true; // Public classrooms should be readable
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.teacherId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.teacherId;

      // Subcollections
      match /{subcollection}/{docId} {
        allow read: if isSignedIn(); // General read access for signed-in users for subcollections
        allow write: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
      
      // More specific subcollection rules
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isUser(participantId) || isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /joinRequests/{requestId} {
        allow create: if isSignedIn() && request.auth.uid == requestId; // User can request to join
        allow read, delete: if isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId); // Teacher can manage requests
      }
      
      match /assignments/{assignmentId}/submissions/{submissionId} {
        allow create: if isSignedIn() && request.auth.uid == submissionId; // Students can submit
        allow read, update: if isSignedIn() && (isUser(submissionId) || isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId)); // Student and teacher can access
      }
    }

    // Meetings
    match /meetings/{meetingId} {
      // Anyone can read meeting info (to check if it exists)
      allow read: if true;
      // Any authenticated user can create a meeting document
      allow create: if isSignedIn();
      // Only the creator can update or delete the meeting
      allow update, delete: if isSignedIn() && isUser(resource.data.creatorId);

      // Participants in a meeting
      match /participants/{participantId} {
        // Any authenticated user can read the participant list
        allow read: if isSignedIn();
        // A user can only write to their own participant document
        allow write: if isUser(participantId);
      }
    }
    
    // Documents and Recordings
    match /{collection=documents,recordings}/{docId} {
       allow read: if resource.data.isPrivate == false || (isSignedIn() && isUser(resource.data.uploaderId));
       allow create: if isSignedIn() && isUser(request.resource.data.uploaderId);
       allow delete: if isSignedIn() && isUser(resource.data.uploaderId);
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
        allow write: if isUser(userId);
    }
  }
}
