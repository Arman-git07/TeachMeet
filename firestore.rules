rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Classroom Rules
    match /classrooms/{classroomId} {
      // Allow read access to public classrooms for any authenticated user.
      allow read: if request.auth != null && resource.data.isPublic == true;
      
      // Allow create only if the teacherId matches the user creating it.
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      
      // Allow update/delete only by the teacher who owns the classroom.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Join Requests subcollection
      match /joinRequests/{userId} {
        // Any authenticated user can create a request for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;
        // Only the teacher of the classroom can read/delete requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // User Data Rules
    match /users/{userId} {
      // Users can only read/write their own data.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Enrolled subcollection
      match /enrolled/{classroomId} {
        // Users can only manage their own enrollment documents.
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Meeting Rules
    match /meetings/{meetingId} {
      // Any authenticated user can create or read a meeting document.
      allow read, create: if request.auth != null;
      // Only the meeting creator can update/delete it.
      allow update, delete: if request.auth != null && resource.data.creatorId == request.auth.uid;

      // Meeting Participants subcollection
      match /participants/{userId} {
        // Authenticated users can join (write) or leave (delete) a meeting.
        // Anyone in the meeting can see other participants.
        allow read, write, delete: if request.auth != null;
      }
    }
    
    // Documents Rules
    match /documents/{documentId} {
        // Read is allowed if the document is not private, or if the user is the uploader.
        allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
        // Create is allowed for any authenticated user.
        allow create: if request.auth != null;
        // Update/delete is only allowed for the original uploader.
        allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    // Recordings Rules
    match /recordings/{recordingId} {
        // Read is allowed if the recording is not private, or if the user is the uploader.
        allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
        // Create is allowed for any authenticated user.
        allow create: if request.auth != null;
        // Update/delete is only allowed for the original uploader.
        allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    // FCM Tokens Rules
    match /fcmTokens/{userId} {
        // Users can only manage their own FCM token.
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
