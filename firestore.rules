rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isClassroomCreator(classroomId) {
      return isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy);
    }
    
    function isClassroomTeacher(classroomId) {
      let classroomData = get(/databases/$(database)/documents/classrooms/$(classroomId)).data;
      // Legacy check on top-level array
      let isTeacherInArray = request.auth.uid in classroomData.get('teachers', []);
      // Check in subcollection
      let isTeacherInSubcollection = exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid));
      return isClassroomCreator(classroomId) || isTeacherInArray || isTeacherInSubcollection;
    }

    // General user profiles, readable by anyone, writable only by the user themselves
    match /users/{userId} {
      allow read: if true;
      allow write: if isUser(userId);
      // Allow users to view their own subcollections
      match /{allChildren=**} {
        allow read, write: if isUser(userId);
      }
    }

    // Public documents are readable by anyone, private ones only by the owner.
    // All users can create documents. Only owners can delete.
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
      allow create: if isAuth();
      allow update, delete: if isUser(resource.data.uploaderId);
    }
    
    // Public recordings are readable by anyone, private ones only by the owner.
    // All users can create recordings. Only owners can delete.
    match /recordings/{recId} {
      allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
      allow create: if isAuth();
      allow update, delete: if isUser(resource.data.uploaderId);
    }

    // Public classrooms are readable by anyone.
    // Authenticated users can create classrooms.
    // Classroom creators can update/delete their classrooms.
    match /classrooms/{classroomId} {
      allow read: if resource.data.isPublic == true || isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
      allow create: if isAuth();
      allow update, delete: if isClassroomCreator(classroomId);

      // Join requests can be created by any authenticated user.
      // They can be read or deleted by the classroom creator/teacher.
      match /joinRequests/{userId} {
        allow create: if isAuth();
        allow read, delete: if isClassroomTeacher(classroomId);
      }
      
      // Classroom creator/teacher can manage all subcollections.
      match /announcements/{announcementId} {
        allow read, write: if isClassroomTeacher(classroomId);
      }
      match /materials/{materialId} {
        allow read, write: if isClassroomTeacher(classroomId);
      }
       match /assignments/{assignmentId} {
        allow read, write: if isClassroomTeacher(classroomId);
         // Students can submit to assignments. Teachers can grade.
        match /submissions/{submissionId} {
            allow create: if isAuth();
            allow read, update: if isClassroomTeacher(classroomId) || isUser(submissionId);
        }
      }
      match /exams/{examId} {
        allow read, write: if isClassroomTeacher(classroomId);
      }
       match /participants/{participantId} {
        allow read, write: if isClassroomTeacher(classroomId) || isUser(participantId);
      }
       match /teachers/{teacherId} {
        allow read, write: if isClassroomTeacher(classroomId);
      }
    }
    
    // Meetings can be created by any authenticated user.
    // Meeting documents are readable by anyone authenticated.
    // The creator of the meeting can update/delete it.
    match /meetings/{meetingId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isUser(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);

      // Any authenticated user can join a meeting (create their participant document).
      // A user can only update their own participant document (e.g., for raising hand).
      match /participants/{userId} {
        allow read: if isAuth();
        allow create, update: if isUser(userId);
        // Only the meeting creator can remove a participant
        allow delete: if isUser(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
    }
  }
}
