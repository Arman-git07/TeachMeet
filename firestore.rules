rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in
    function signedIn() {
      return request.auth != null;
    }

    // Rules for the 'meetings' collection
    match /meetings/{meetingId} {
      // ANY signed-in user can CREATE a new meeting document.
      // The `hostId` must be set to their own user ID.
      allow create: if signedIn() && request.resource.data.hostId == request.auth.uid;

      // ANYONE can READ a meeting document (e.g., to get the topic).
      allow read: if true;

      // ONLY the user whose UID matches the `hostId` can UPDATE or DELETE the meeting.
      allow update, delete: if signedIn() && resource.data.hostId == request.auth.uid;

      // Rules for participants and join requests subcollections
      match /{subcollection}/{documentId} {
        // ANY signed-in user can create a document (e.g., a joinRequest or add themselves as a participant).
        allow create: if signedIn();
        
        // ONLY the meeting host can update or delete these subcollection documents (e.g., accept/deny requests).
        allow update, delete: if signedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        
        // Allow anyone to read subcollection documents.
        allow read: if true;
      }
    }
    
    // Rules for the 'classrooms' collection
    match /classrooms/{classroomId} {
        allow read, list: if true;
        allow create: if signedIn();
        allow update, delete: if signedIn() && (
            resource.data.teacherId == request.auth.uid || 
            (exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid)))
        );

        match /{subcollection}/{documentId} {
            allow read, list: if true;
            allow create: if signedIn();
            // More granular control can be added here based on roles (creator, teacher, student)
            allow update, delete: if signedIn() && (
                get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid ||
                (exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid))) ||
                (resource.data.authorId == request.auth.uid) || // The creator of the item
                (resource.data.creatorId == request.auth.uid) ||
                (resource.data.uploaderId == request.auth.uid)
            );
        }
    }

    // Public user profiles
    match /users/{userId} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == userId;
      
       match /{subcollection}/{documentId} {
          allow read: if true;
          allow create, update, delete: if signedIn() && request.auth.uid == userId;
       }
    }

    // Documents collection
    match /documents/{documentId} {
      allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow read: if resource.data.isPrivate == false || (signedIn() && resource.data.uploaderId == request.auth.uid);
      allow delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }
    
    // Recordings collection
    match /recordings/{recordingId} {
      allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow read: if resource.data.isPrivate == false || (signedIn() && resource.data.uploaderId == request.auth.uid);
      allow delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }
    
    // FCM Tokens for notifications
    match /fcmTokens/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

  }
}
