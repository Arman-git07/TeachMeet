
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isMemberOf(resourceId, collectionName) {
      return get(/databases/$(database)/documents/$(collectionName)/$(resourceId)).data.members.hasAny([request.auth.uid]);
    }

    // Teachings
    match /teachings/{teachingId} {
      allow read: if request.auth != null && (
        resource.data.isPublic == true || isMemberOf(teachingId, 'teachings')
      );
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null && (
        // Creator can update
        resource.data.creatorId == request.auth.uid ||
        // Authenticated user can add themselves to pending requests if it's public
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
          request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]) &&
          resource.data.isPublic == true
        )
      );
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }

    // Meetings
    match /meetings/{meetingId} {
      // Anyone authenticated can read meeting details to check for creator, etc.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null && (
        // The creator of the meeting can update it (e.g., to add members, remove requests).
        resource.data.creatorId == request.auth.uid ||
        // An authenticated user can add themselves to the pendingRequests list.
        (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
            request.resource.data.pendingRequests.hasAll(resource.data.pendingRequests) &&
            request.resource.data.pendingRequests.size() == resource.data.pendingRequests.size() + 1 &&
            request.resource.data.pendingRequests[-1] == request.auth.uid
        )
      );
      
      match /participants/{participantId} {
        allow read: if request.auth != null;
        // The user themselves, or the meeting host, can create the participant doc.
        allow create: if request.auth != null && (
          isOwner(participantId) || 
          get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid
        );
        // Only the participant can update their own status, or the host can remove them (delete).
        allow update: if request.auth != null && isOwner(participantId);
        allow delete: if request.auth != null && (
          isOwner(participantId) ||
          get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid
        );
      }
    }

    // Documents
    match /documents/{documentId} {
      allow read: if request.auth != null && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      allow create: if request.auth != null && isOwner(request.resource.data.uploaderId);
      allow delete: if request.auth != null && isOwner(resource.data.uploaderId);
    }
    
    // Recordings
    match /recordings/{recordingId} {
       allow read: if request.auth != null && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
       allow create: if request.auth != null && isOwner(request.resource.data.uploaderId);
       allow delete: if request.auth != null && isOwner(resource.data.uploaderId);
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && isOwner(userId);
    }
  }
}
