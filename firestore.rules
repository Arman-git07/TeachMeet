rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the creator of a document
    function isCreator(resourceId) {
      return request.auth.uid == get(/databases/$(database)/documents/teachings/$(resourceId)).data.creatorId;
    }
    
    // Helper function to check if the user is a member of a teaching
    function isMember(resourceId) {
      return request.auth.uid in get(/databases/$(database)/documents/teachings/$(resourceId)).data.members;
    }

    match /teachings/{teachingId} {
      // Allow any authenticated user to create a teaching
      allow create: if isAuthenticated();

      // Allow reads for public teachings or if the user is a member
      allow read: if isAuthenticated() && (resource.data.isPublic == true || isMember(teachingId));
      
      // Allow updates/deletes only for the creator
      allow update, delete: if isAuthenticated() && isCreator(teachingId);
    }
    
    match /meetings/{meetingId} {
      // Any authenticated user can create a meeting document
      allow create: if isAuthenticated();
      
      // Any authenticated user can read a meeting document (to check creator, etc.)
      allow read: if isAuthenticated();
      
      // Let host manage pending requests (add/remove)
      allow update: if isAuthenticated() && (
        // Allow a user to add themselves to pendingRequests.
        // request.resource.data.diff(resource.data).affectedKeys() checks which fields are being changed.
        // .hasOnly(['pendingRequests']) ensures ONLY pendingRequests is being modified.
        // request.resource.data.pendingRequests.hasAll(resource.data.pendingRequests) ensures it's an addition.
        // request.auth.uid in request.resource.data.pendingRequests ensures they are adding themselves.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests.hasAll(resource.data.pendingRequests) &&
         request.auth.uid in request.resource.data.pendingRequests)
        ||
        // Allow the creator of the meeting to manage the document (e.g., approve/deny requests)
        (request.auth.uid == resource.data.creatorId)
      );
    }

    match /meetings/{meetingId}/participants/{participantId} {
      // The user can add themselves as a participant (join) if they are the creator
      // Or if the host is adding them (logic handled in cloud functions/backend for approval)
      allow create: if isAuthenticated() && (request.auth.uid == participantId);
      
      // A participant can update their own status (mute, camera, etc.)
      // Or the host can update participants
      allow update: if isAuthenticated() && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      
      // A participant can remove themselves (leave meeting)
      // Or the host can remove a participant
      allow delete: if isAuthenticated() && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      
      // Any participant in the meeting can read the list of other participants
      allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/meetings/$(meetingId)).data.participants);
    }

    // Rules for user-generated content (documents, recordings)
    match /{collection}/{docId} where collection in ['documents', 'recordings'] {
      // Any authenticated user can create a document or recording.
      allow create: if isAuthenticated();
      
      // Users can read if it's public, or if they are the uploader.
      allow read: if isAuthenticated() && (resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId);
      
      // Users can only update or delete their own content.
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.uploaderId;
    }
    
    // Rules for FCM tokens
    match /fcmTokens/{userId} {
      // Users can only read, create, or update their own FCM token document.
      allow read, create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
