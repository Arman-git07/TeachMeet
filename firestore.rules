rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rules for user-specific data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Rules for classrooms
    match /classrooms/{classroomId} {
      // Allow anyone to read a classroom document if it is public.
      // Allow the teacher to read it regardless of public status.
      allow get: if (resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.teacherId));

      // Allow anyone to list (query for) public classrooms.
      allow list: if resource.data.isPublic == true;
      
      // Allow authenticated users to create a classroom if they are the teacher.
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;

      // Allow the teacher to update or delete their own classroom.
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;

      // Rules for classroom subcollections
      match /{subcollection}/{docId} {
        // Allow enrolled students and the teacher to read/write.
        // Specific create/update/delete can be refined here later if needed.
        allow read, write: if request.auth != null && (request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.students);
      }
    }

    // Rules for meetings
    match /meetings/{meetingId}/{document=**} {
      // Allow any authenticated user to interact with meetings.
      // In a production app, this would be locked down to meeting members.
      allow read, write: if request.auth != null;
    }

    // Rules for documents and recordings
    match /documents/{docId} {
        allow get: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow list: if request.auth != null; // Allow authenticated users to list documents they have access to
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recId} {
        allow get: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow list: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
  }
}
