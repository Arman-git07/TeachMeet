rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Meetings collection
    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting, but only if they set themselves as the host.
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      
      // Anyone authenticated can read meeting details (to join, etc.)
      allow read: if isAuthenticated();

      // Only the host can update or delete the meeting document.
      allow update, delete: if isAuthenticated() && resource.data.hostId == request.auth.uid;

      // Rules for participants subcollection
      match /participants/{participantId} {
        // A user can add themselves to the participants list.
        allow create: if isAuthenticated() && participantId == request.auth.uid;
        // The host can remove anyone. A user can remove themselves.
        allow delete: if isAuthenticated() && (participantId == request.auth.uid || get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid);
        allow read: if isAuthenticated();
      }

      // Rules for join requests subcollection
      match /joinRequests/{userId} {
        // A user can create a request to join for themselves.
        allow create: if isAuthenticated() && userId == request.auth.uid;
        // The host can update (accept/reject) or delete requests.
        allow write: if isAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        allow read: if isAuthenticated();
      }
    }

    // Users collection
    match /users/{userId} {
      // A user can create their own user document.
      allow create: if isAuthenticated() && userId == request.auth.uid;
      // A user can read/update their own document.
      allow read, update: if isAuthenticated() && userId == request.auth.uid;

      // Subcollections for user's enrolled classes and pending requests
      match /{subcollection}/{docId} {
        allow read, write, delete: if isAuthenticated() && userId == request.auth.uid;
      }
    }

    // Classrooms collection
    match /classrooms/{classroomId} {
      // Anyone authenticated can view public classrooms.
      // Participants (creator, teachers, students) can view private classrooms.
      allow read: if isAuthenticated() && (resource.data.isPublic == true || request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.students || request.auth.uid in resource.data.teachers);

      // Only the creator of the classroom can update or delete it.
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.teacherId;

      // Any authenticated user can create a classroom.
      allow create: if isAuthenticated() && request.resource.data.teacherId == request.auth.uid;
      
      // Subcollections within a classroom
      match /{subcollection}/{docId} {
        // The classroom creator can do anything.
        // Let's be more specific for other roles.
        allow read, write, delete: if isAuthenticated() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        
        // Allow participants to read content
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students || request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers);
        
        // Allow authenticated users to create join requests.
        allow create: if subcollection == 'joinRequests' && isAuthenticated() && docId == request.auth.uid;
      }
    }

    // Documents & Recordings collections
    match /(documents|recordings)/{docId} {
      // Allow read if the doc is public, or if the user is the uploader.
      allow read: if isAuthenticated() && (resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId);
      // Allow create for any authenticated user.
      allow create: if isAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
      // Allow update/delete only for the uploader.
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.uploaderId;
    }

    // Fallback rule for any other path - deny all access.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
