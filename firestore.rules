/**
 * @fileoverview Firestore Security Rules for the meeting application.
 *
 * Core Philosophy:
 * This ruleset enforces a combination of ownership-based and role-based access control.
 * Meetings are created by users, who become the owners. Only the owner can modify a meeting.
 * Join requests are associated with specific meetings and users.
 *
 * Data Structure:
 * - /meetings/{meetingId}: Contains meeting metadata, including the creatorId.
 * - /meetings/{meetingId}/joinRequests/{userId}: Contains join requests from users to a meeting.
 * - /meetings/{meetingId}/participants/{userId}: Contains participant profiles for a meeting.
 *
 * Key Security Decisions:
 * - Users can only create meetings.
 * - Only the meeting creator can update or delete a meeting.
 * - Anyone can read a meeting.
 * - Users can only create join requests for themselves.
 * - Only the meeting creator can approve or deny join requests.
 * - Participants' profiles can only be created by the system when a join request is approved.
 * - Listing of joinRequests is restricted to the meeting creator.
 *
 * Denormalization for Authorization:
 * The `Meeting` document includes a `creatorId` field, which is used to quickly authorize meeting updates and deletes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Controls access to the /meetings collection.
     * @path /meetings/{meetingId}
     * @allow (get, list): Anyone can read meeting details and list meetings.
     * @allow (create): Only authenticated users can create meetings, with creatorId matching auth UID.
     * @deny (update, delete): Only the meeting creator can update or delete.
     * @principle Enforces document ownership for writes.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId);
      allow delete: if isExistingOwner(resource.data.creatorId);
    }

    /**
     * @description Controls access to the /meetings/{meetingId}/joinRequests/{userId} subcollection.
     * @path /meetings/{meetingId}/joinRequests/{userId}
     * @allow (get): Only the meeting creator can get a join request.
     * @allow (list): Only the meeting creator can list join requests.
     * @allow (create): Only the user themselves can create a join request (userId in path must match auth.uid).
     * @allow (update): Only the meeting creator can update a join request's status.
     * @deny (delete): No one can delete a join request directly.
     * @principle Enforces that only the meeting creator can manage join requests, and users can only create their own.
     */
    match /meetings/{meetingId}/joinRequests/{userId} {
      allow get, list: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      allow delete: if false;
    }

    /**
     * @description Controls access to the /meetings/{meetingId}/participants/{userId} subcollection.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (get, list): Any authenticated user can read participants.
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Restricts participant creation, updates, and deletes.
     */
    match /meetings/{meetingId}/participants/{userId} {
       allow get, list: if isSignedIn();
       allow create: if false;
       allow update: if false;
       allow delete: if false;
    }
  }
}