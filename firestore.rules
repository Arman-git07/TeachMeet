rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Meetings collection
    match /meetings/{meetingId} {
      // Host can create the meeting document
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
      
      // Anyone signed in can read the meeting details
      allow read: if request.auth != null;

      // Only the host can update or delete the meeting document
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;

      // Participants subcollection
      match /participants/{participantId} {
        // A user can create their OWN participant document. The host can add themselves.
        allow create: if request.auth != null && request.auth.uid == participantId;

        // Anyone signed in to the meeting can see who else is in it
        allow read: if request.auth != null;

        // A user can only update or delete their own participant document
        allow update, delete: if request.auth != null && request.auth.uid == participantId;
      }

      // Join Requests subcollection
      match /joinRequests/{userId} {
        // Any signed-in user can request to join
        allow create: if request.auth != null && request.auth.uid == userId;

        // The host can read and delete join requests
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
    }
    
    // Classrooms collection
    match /classrooms/{classroomId} {
        allow read, write: if true; // Keeping this open for now to avoid breaking other features
        match /{document=**} {
            allow read, write: if true;
        }
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
