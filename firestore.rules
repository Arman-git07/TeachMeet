rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Meetings can be read by anyone, but only created/updated by the owner.
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      // Join Requests can be created by any signed-in user.
      // Only the meeting host can read, update, or delete them.
      match /joinRequests/{userId} {
        allow read, update, delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
        allow create: if isSignedIn() && request.auth.uid == userId;
      }

      // Participants can be read by anyone in the meeting.
      // Only the host can add/remove participants.
      match /participants/{userId} {
        allow read: if true; // In a real app, you might restrict this further.
        allow create, delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
        allow update: if isOwner(userId); // Participants can update their own status (e.g., hand raise)
      }
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
