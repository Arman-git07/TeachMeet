rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read and write access to the entire database for any authenticated user.
    // This is suitable for development but should be replaced with more
    // restrictive rules before launching to production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
