
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    // Users can read their own profile, but not others.
    // Users can only create their own profile.
    // Users can only update their own profile.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // --- FCM Tokens ---
    // Allow authenticated users to write their own FCM token.
    match /fcmTokens/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Meetings Collection ---
    match /meetings/{meetingId} {
      // Allow any authenticated user to read a meeting's main document.
      allow read: if request.auth != null;
      
      // Allow creation only if the creatorId matches the user's ID.
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // Allow update only by the creator, or by a user adding themselves to pendingRequests.
      allow update: if request.auth != null && (
        // Case 1: The user is the creator of the meeting.
        resource.data.creatorId == request.auth.uid ||
        // Case 2: A user is requesting to join.
        // This rule allows a user to add their own UID to the pendingRequests array.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );

      // --- Participants Subcollection ---
      match /participants/{userId} {
        // Any authenticated user can create their own participant document.
        allow create: if request.auth != null && request.auth.uid == userId;
        // A user can read any participant document in a meeting they are a part of (or requesting to join).
        allow read: if request.auth != null;
        // A user can only update or delete their own participant document.
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // --- Teachings Collection ---
    match /teachings/{teachingId} {
      // Anyone authenticated can read any teaching document.
      allow read: if request.auth != null;

      // Allow creation if the user is authenticated and is the creator.
      // Ensure all required fields are present.
      allow create: if request.auth != null && 
                      request.resource.data.creatorId == request.auth.uid &&
                      'title' in request.resource.data &&
                      'description' in request.resource.data &&
                      'isPublic' in request.resource.data &&
                      'creatorName' in request.resource.data &&
                      request.resource.data.members == [request.auth.uid] &&
                      request.resource.data.pendingRequests == [];

      // Allow updates by the creator OR by a user requesting to join.
      allow update: if request.auth != null && (
        // Case 1: The user is the creator of the teaching.
        resource.data.creatorId == request.auth.uid ||
        // Case 2: A user is requesting to join (adding themselves to pendingRequests).
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );

      // Allow deletion only by the creator.
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }

    // --- Documents & Recordings Collections ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /(documents|recordings)/{fileId} {
      // Read access:
      // - The owner can always read.
      // - Any authenticated user can read if the file is NOT private.
      allow read: if request.auth != null && (isOwner(resource.data.uploaderId) || resource.data.isPrivate == false);

      // Create access:
      // - The user must be authenticated and be the uploader.
      allow create: if request.auth != null && isOwner(request.resource.data.uploaderId);
      
      // Update and Delete access:
      // - Only the owner can update or delete their own files.
      allow update, delete: if request.auth != null && isOwner(resource.data.uploaderId);
    }
  }
}
