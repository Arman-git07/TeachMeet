
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection:
    // Only the authenticated user can read or write to their own document.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }
    
    // FCM Tokens:
    // Only the user can create/update their own token document.
    match /fcmTokens/{userId} {
        allow write: if request.auth.uid == userId;
    }
    
    // Classrooms collection:
    // Allow any authenticated user to create a classroom.
    // Allow read access to public classrooms for any authenticated user.
    // Only the teacher can update or delete their own classroom.
    match /classrooms/{classroomId} {
      allow create: if request.auth != null;
      allow read: if resource.data.isPublic == true || request.auth.uid == resource.data.teacherId;
      allow update, delete: if request.auth.uid == resource.data.teacherId;
      
      // Join Requests subcollection:
      // Any authenticated user can create a join request for themselves.
      // Only the classroom teacher can list, read, or delete requests.
      match /joinRequests/{userId} {
        allow create: if request.auth.uid == userId;
        allow read, delete: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
      
      // Other classroom subcollections (materials, announcements, etc.):
      // The teacher can do anything.
      // Enrolled students (checked via their own user document) can read.
      match /{subcollection}/{docId} {
         allow read: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId ||
                       exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrolled/$(classroomId));
         allow write: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }
    
    // Meetings collection:
    // Any authenticated user can create a meeting.
    // The creator (host) can delete the meeting document.
    match /meetings/{meetingId} {
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.creatorId;
        allow read: if request.auth != null; // Allow any authenticated user to read meeting details
        
        // Join Requests for meetings:
        // Any authenticated user can create a request for themselves.
        // The host can list, read, and delete these requests.
        match /joinRequests/{userId} {
            allow create: if request.auth.uid == userId;
            allow read, delete: if request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
        }

        // Participants subcollection:
        // The host can create participant documents (i.e., approve requests).
        // Any participant can read their own document.
        // Any participant can update or delete their own document (to leave or update status).
        match /participants/{userId} {
            allow create: if request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
            allow read, update, delete: if request.auth.uid == userId;
            // Allow all authenticated participants in the meeting to list other participants.
            allow list: if exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
        }
    }
    
    // Documents collection:
    // Any authenticated user can create documents.
    // Users can only manage their own documents.
    // Public documents can be read by any authenticated user.
    match /documents/{docId} {
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
        allow update, delete: if request.auth.uid == resource.data.uploaderId;
    }
    
    // Recordings collection:
    // Any authenticated user can create recordings.
    // Users can only manage their own recordings.
    // Public recordings can be read by any authenticated user.
    match /recordings/{recId} {
        allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
        allow update, delete: if request.auth.uid == resource.data.uploaderId;
    }
  }
}
