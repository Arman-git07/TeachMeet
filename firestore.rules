rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is logged in
    function signedIn() {
      return request.auth != null;
    }

    // Helper function to check ownership
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // CLASSROOMS (root collection)
    match /classrooms/{classroomId} {

      // Read access: Allow signed-in users to query the collection.
      // Client-side queries are responsible for filtering (e.g., for public or user-owned classes).
      allow list, get: if signedIn();

      // Create classroom: User must be the teacherId.
      allow create: if isOwner(request.resource.data.teacherId);

      // Update/Delete classroom: Only the original teacher can.
      allow update, delete: if isOwner(resource.data.teacherId);

      // JOIN REQUESTS (for students asking to join)
      match /joinRequests/{requestId} {
        // Student can create their own join request.
        allow create: if isOwner(request.resource.data.requesterId);

        // Teacher can read all requests. Requester can read/delete their own.
        allow read, delete: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || isOwner(resource.data.requesterId);

        // Teacher can update requests (approve/deny).
        allow update: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

      // PARTICIPANTS
      match /participants/{participantId} {
        allow read: if signedIn();
        allow write: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      // Other subcollections
      match /announcements/{announcementId} {
        allow read: if signedIn();
        allow write: if isOwner(request.resource.data.authorId);
        allow delete: if isOwner(resource.data.authorId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      match /materials/{materialId} {
        allow read: if signedIn();
        allow write: if isOwner(request.resource.data.uploaderId);
        allow delete: if isOwner(resource.data.uploaderId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      match /assignments/{assignmentId} {
        allow read: if signedIn();
        allow write, delete: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        match /submissions/{submissionId} {
          allow read: if signedIn();
          allow write: if isOwner(submissionId);
        }
      }
      match /exams/{examId} {
         allow read: if signedIn();
         allow write: if isOwner(request.resource.data.authorId);
         allow delete: if isOwner(resource.data.authorId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      match /teachers/{teacherId} {
          allow read, write: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
    }

    // USERS collection
    match /users/{userId} {
      // User can read/write their own profile data.
      allow read, write: if isOwner(userId);

      // User can manage their own subcollections.
      match /enrolled/{docId} {
        allow read, write, delete: if isOwner(userId);
      }
      match /pendingJoinRequests/{docId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    // MEETINGS collection
    match /meetings/{meetingId} {
      allow read, list: if true;
      allow create, update, delete: if isOwner(request.resource.data.hostId);

      match /joinRequests/{userId} {
        allow create, read, update, delete: if signedIn();
      }
      
      match /participants/{userId} {
        allow read: if signedIn();
        allow write: if isOwner(userId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }
    }

    // DOCUMENTS collection
    match /documents/{documentId} {
      allow read: if signedIn() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      allow create: if isOwner(request.resource.data.uploaderId);
      allow delete: if isOwner(resource.data.uploaderId);
    }

    // RECORDINGS collection
    match /recordings/{recordingId} {
      allow read: if signedIn() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
      allow create: if isOwner(request.resource.data.uploaderId);
      allow delete: if isOwner(resource.data.uploaderId);
    }
  }
}
