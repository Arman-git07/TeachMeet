rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /pendingJoinRequests/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /meetings/{meetingId} {
        allow read, create, update: if request.auth != null;
        
        match /participants/{participantId} {
            allow read, write: if request.auth != null;
        }

        match /joinRequests/{requestId} {
            allow read, write: if request.auth != null;
        }
    }

    match /classrooms/{classroomId} {
      allow read: if true; 
      allow create, update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      match /participants/{participantId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }
      
      match /teachers/{teacherId} {
         allow read: if true;
         allow create, update, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }

      match /joinRequests/{requestId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == requestId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy);
      }
      
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
      }
      
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }
      
      match /materials/{materialId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }
      
      match /exams/{examId} {
         allow read: if true;
         allow create, update, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }
    }
  }
}
