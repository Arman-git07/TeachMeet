
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Teachings Collection
    match /teachings/{teachingId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null 
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.creatorName is string
                    && request.resource.data.title is string
                    && request.resource.data.members[0] == request.auth.uid
                    && request.resource.data.members.size() == 1
                    && request.resource.data.pendingRequests.size() == 0;
                    
      allow update: if request.auth != null && resource.data.creatorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }

    // Documents and Recordings Collections
    match /{collection}/{docId} where collection in ['documents', 'recordings'] {
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow create: if request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth.uid == resource.data.uploaderId;
    }

    // FCM Tokens Collection
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Meetings Collection
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // Allow host to update pending/approved members
      allow update: if request.auth != null && resource.data.creatorId == request.auth.uid;
      
      match /participants/{userId} {
        allow read: if request.auth != null;
        
        // Allow any authenticated user to create their OWN participant document
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // Allow users to update or delete only their OWN participant document
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
  }
}
