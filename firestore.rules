
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated.
    function signedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is the owner of a resource.
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Rules for the main collections in the app.

    // Meetings Collection
    match /meetings/{meetingId} {
      // Any signed-in user can create a meeting.
      allow create: if signedIn();
      
      // Any signed-in user can read meeting details.
      allow read: if signedIn();
      
      // Only the host of the meeting can update or delete it.
      allow update, delete: if isOwner(resource.data.hostId);
      
      // Subcollections for a meeting.
      match /{allPaths=**} {
        allow read, write: if signedIn();
      }
    }
    
    // Users Collection (for profile info, etc.)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
       match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Classrooms Collection
    match /classrooms/{classroomId} {
        allow read: if true; // Allow public read for discovery
        allow create: if signedIn();
        allow update: if isOwner(resource.data.teacherId); // Only original creator can update main details
        allow delete: if isOwner(resource.data.teacherId);
        
        match /{allPaths=**} {
            allow read, write: if signedIn();
        }
    }
    
    // Documents & Recordings (user-specific content)
    match /documents/{documentId} {
        // Can be read if public, or if the user is the owner.
        allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
        // Can be created by any signed-in user.
        allow create: if signedIn();
        // Can only be updated/deleted by the uploader.
        allow update, delete: if isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
        allow create: if signedIn();
        allow update, delete: if isOwner(resource.data.uploaderId);
    }
    
     match /fcmTokens/{userId} {
      allow write: if isOwner(userId);
      allow read: if isOwner(userId);
    }
  }
}
