
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // PUBLIC ACCESS FOR DEVELOPMENT
    // WARNING: This allows anyone to read and write to your entire database.
    // This is for development convenience ONLY.
    // You MUST secure this before deploying to production.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
