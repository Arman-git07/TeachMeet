rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function signedIn() {
      return request.auth != null;
    }

    function isClassCreator(classId) {
      let classroomDoc = get(/databases/$(database)/documents/classrooms/$(classId));
      return signedIn() && classroomDoc.data.createdBy == request.auth.uid;
    }

    function isClassTeacher(classId) {
      // Check if the user is in the 'teachers' subcollection or if they are the original creator
      return isClassCreator(classId) || 
             exists(/databases/$(database)/documents/classrooms/$(classId)/teachers/$(request.auth.uid));
    }
    
    function isClassParticipant(classId) {
       return signedIn() && exists(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid));
    }

    // Classroom Collection
    match /classrooms/{classId} {
      allow read: if isClassParticipant(classId) || isClassCreator(classId);
      allow create: if signedIn();
      allow update, delete: if isClassCreator(classId);
      
      // Participants Subcollection
      match /participants/{participantId} {
        allow read: if isClassParticipant(classId);
        allow create, update, delete: if isClassCreator(classId) || request.auth.uid == participantId;
      }
      
      // Teachers subcollection
      match /teachers/{teacherId} {
        allow read: if isClassParticipant(classId);
        allow create, update, delete: if isClassCreator(classId);
      }

      // Join Requests subcollection
      match /joinRequests/{userId} {
        allow read, delete: if isClassCreator(classId) || request.auth.uid == userId;
        allow create: if signedIn() && request.auth.uid == userId;
      }

      // Announcements Subcollection
      match /announcements/{announcementId} {
        allow read: if isClassParticipant(classId);
        allow create: if isClassTeacher(classId) && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isClassTeacher(classId) && resource.data.authorId == request.auth.uid;
      }
      
      // Other subcollections
      match /assignments/{assignmentId} {
        allow read: if isClassParticipant(classId);
        allow create, update, delete: if isClassTeacher(classId);

        match /submissions/{submissionId} {
          allow read: if isClassParticipant(classId);
          allow create: if signedIn();
          allow update: if isClassTeacher(classId); // Teacher can update with grade/feedback
        }
      }

      match /materials/{materialId} {
        allow read: if isClassParticipant(classId);
        allow create, update, delete: if isClassTeacher(classId);
      }
      
      match /exams/{examId} {
         allow read: if isClassParticipant(classId);
         allow create, update, delete: if isClassTeacher(classId);
      }
    }

    // Users Collection
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;

      match /enrolled/{classroomId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write, delete: if signedIn() && request.auth.uid == userId;
      }
      match /pendingJoinRequests/{classroomId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write, delete: if signedIn() && request.auth.uid == userId;
      }
    }

    // Meetings, Documents, Recordings collections
    match /{collection}/{docId} {
      allow read: if signedIn(); // General read rule for top-level collections
      allow write: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }
  }
}

    