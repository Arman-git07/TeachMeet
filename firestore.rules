
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    function isCreator(docPath, userId) {
      return get(docPath).data.creatorId == userId;
    }

    // ===== TEACHINGS =====
    match /teachings/{teachingId} {
      allow read, list: if isUserAuthenticated();

      // Create: User must be authenticated and set themselves as the creator.
      // They must also initialize members array with their own UID and an empty pendingRequests array.
      allow create: if isUserAuthenticated()
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.members == [request.auth.uid]
                    && request.resource.data.pendingRequests == [];

      // Update: Only the creator can update title, description, isPublic.
      // For updating members/pendingRequests, specific logic below applies.
      allow update: if isUserAuthenticated() && isCreator(/databases/$(database)/documents/teachings/$(teachingId), request.auth.uid)
                      && request.resource.data.keys().hasAll(['title', 'description', 'isPublic', 'members', 'pendingRequests'])
                      && request.resource.data.size() == 5; // Prevent changing creatorId, etc.
                    
                    // Allow any authenticated user to add themselves to the pendingRequests array.
                    // This is how a user requests to join.
                    // `arrayUnion` ensures they can't add anyone else or duplicates.
                    // Also check that the user is NOT already a member.
                    || isUserAuthenticated()
                      && !isCreator(/databases/$(database)/documents/teachings/$(teachingId), request.auth.uid)
                      && !(request.auth.uid in resource.data.members)
                      && request.resource.data.pendingRequests == resource.data.pendingRequests.union([request.auth.uid]);

      // Delete: Only the creator can delete.
      allow delete: if isUserAuthenticated() && isCreator(/databases/$(database)/documents/teachings/$(teachingId), request.auth.uid);
    }
    

    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read, list: if isUserAuthenticated();
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isUserAuthenticated() && isCreator(/databases/$(database)/documents/meetings/$(meetingId), request.auth.uid);
      allow delete: if isUserAuthenticated() && isCreator(/databases/$(database)/documents/meetings/$(meetingId), request.auth.uid);
      
      match /participants/{participantId} {
        allow read, list: if isUserAuthenticated(); // Allow reading participant list for meeting members
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isCreator(/databases/$(database)/documents/meetings/$(meetingId), request.auth.uid);
      }
    }


    // ===== USER-OWNED CONTENT (Documents, Recordings) =====
    match /documents/{docId} {
        // Read: Allow if document is public, or if user is the owner.
        allow read, list: if isUserAuthenticated() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
        // Create: Any authenticated user can create.
        allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
        // Delete: Only the owner can delete.
        allow delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }

    match /recordings/{recId} {
        // Read: Allow if recording is public, or if user is the owner.
        allow read, list: if isUserAuthenticated() && (resource.data.isPrivate == false || isOwner(resource.data.uploaderId));
        // Create: Any authenticated user can create.
        allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
        // Delete: Only the owner can delete.
        allow delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }

    // ===== MISC =====
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
