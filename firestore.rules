
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }
    
    function isTeachingCreator(teachingId) {
        return request.auth.uid == getDoc('teachings/' + teachingId).data.creatorId;
    }
    
    function isTeachingMember(teachingId) {
        let teaching = getDoc('teachings/' + teachingId).data;
        return request.auth.uid in teaching.members;
    }
    
    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      allow update: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      
      // A meeting document itself cannot be deleted while in progress, only its participants.
      // Logic for cleaning up old meetings would typically be handled by a server-side process.
      allow delete: if false;

      match /participants/{participantId} {
        allow list, read: if isUserAuthenticated(); // Simplified for now
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
    }

    // ===== TEACHINGS =====
    match /teachings/{teachingId} {
        // Anyone can see public teachings. Private ones are for members only.
        allow list: if isUserAuthenticated();
        allow read: if isUserAuthenticated() && (resource.data.isPublic == true || isTeachingMember(teachingId));
        
        // Anyone can create a teaching, but they must be the creator.
        allow create: if isUserAuthenticated() && isOwner(request.resource.data.creatorId);

        // Allow updates only by the creator, and only on specific fields.
        // Don't allow changing the creator or members directly here.
        allow update: if isTeachingCreator(teachingId) && request.resource.data.keys().hasOnly(['title', 'description', 'isPublic', 'pendingRequests', 'members']);

        // Allow deletion only by the creator.
        allow delete: if isTeachingCreator(teachingId);
    }
    
    // ===== DOCUMENTS & RECORDINGS (Shared Logic) =====
    match /{collection}/{docId} 
        where collection in ['documents', 'recordings'] {
        
        allow list: if isUserAuthenticated();
        
        // Allow reading if public or if the user is the uploader.
        allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
        
        // Allow creation if the user is the uploader.
        allow create: if isOwner(request.resource.data.uploaderId);
        
        // Allow deletion only by the uploader.
        allow delete: if isOwner(get(/databases/$(database)/documents/$(collection)/$(docId)).data.uploaderId);
        
        // Updates are not permitted to prevent metadata tampering.
        allow update: if false;
    }
    
    // ===== FCM TOKENS =====
    match /fcmTokens/{userId} {
      // Users can only create, read, or update their own FCM token document.
      allow read, write: if isOwner(userId);
    }
  }
}
