
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for Meetings
    match /meetings/{meetingId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;

      match /participants/{userId} {
        allow create: if isUser(userId) || (isAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
        allow read: if isUser(userId);
        allow list: if exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
        allow update, delete: if isUser(userId) || (isAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
      }

      match /joinRequests/{userId} {
        allow create: if isUser(userId);
        allow read, delete: if isAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }
    
    // Rules for Classrooms
    match /classrooms/{classroomId} {
      allow create: if isAuthenticated();
      allow read; 
      allow update, delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;

      // Subcollections for a classroom
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request for themselves.
        allow create: if isUser(userId) && request.resource.data.userId == request.auth.uid;
        // The teacher can read and delete requests.
        allow read, delete: if isAuthenticated() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
      // Allow any authenticated user to write to subcollections for classroom content.
      // More specific rules can be added here if needed (e.g., only teacher can create assignments).
      match /{subcollection}/{docId} {
          allow read, write: if isAuthenticated();
      }
    }
    
    // Rules for User-specific data
    match /users/{userId} {
        // A user can only access their own documents.
        allow read, write: if isUser(userId);

        // A user can manage their own enrolled classes and pending requests.
        match /enrolled/{classroomId} {
             allow read, write, delete: if isUser(userId);
        }
        match /pendingJoinRequests/{classroomId} {
             allow read, write, delete: if isUser(userId);
        }
    }

    // Rules for top-level Documents and Recordings collections
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
    
    match /recordings/{recId} {
        allow read: if resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid;
        allow create: if isAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }

    // Rules for FCM tokens
    match /fcmTokens/{userId} {
        allow write: if isUser(userId);
    }
  }
}
