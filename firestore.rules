rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Users Collection ---
    match /users/{userId} {
      allow read; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // --- Meetings Collection ---
    match /meetings/{meetingId} {
      // ANY signed-in user can CREATE a meeting document. This is critical.
      allow create: if request.auth != null;

      // Allow READ if the user is the host. We will add participant logic later.
      allow read: if request.auth != null && request.auth.uid == resource.data.hostId;
      
      // Allow UPDATE/DELETE only by the host.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostId;
      
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == participantId;
      }

      match /joinRequests/{requestId} {
         // ANY signed-in user can CREATE a join request for themselves.
         allow create: if request.auth != null && request.auth.uid == requestId;
         // Only the HOST can read/update/delete requests.
         allow read, update, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
    }

    // --- Classrooms Collection ---
    match /classrooms/{classroomId} {
      allow read: if true; // Public classrooms are readable
      allow create: if request.auth != null; // Teachers can create
      allow update: if request.auth != null && request.auth.uid == resource.data.teacherId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      match /announcements/{announcementId} {
        allow read;
        allow write: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /materials/{materialId} {
        allow read;
        allow write: if request.auth != null; // Simplified for now
      }

      match /assignments/{assignmentId} {
        allow read;
        allow write: if request.auth != null;
        match /submissions/{submissionId} {
            allow read, write: if request.auth != null;
        }
      }
      
       match /exams/{examId} {
        allow read;
        allow write: if request.auth != null;
      }

      match /joinRequests/{userId} {
        allow read, write: if request.auth.uid == userId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (resource.data.isPrivate == true && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (resource.data.isPrivate == true && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth.uid == resource.data.uploaderId;
    }
    
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
