rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions for auth checks
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Users collection can be read by anyone, but only the user can write to their own document.
    match /users/{userId} {
      allow read: if true;
      allow write: if isUser(userId);
      
      // Subcollections for user's enrolled classes and pending requests
      match /enrolled/{classroomId} {
        allow read, write, delete: if isUser(userId);
      }
      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if isUser(userId);
      }
    }

    // FCM tokens for push notifications, only writable by the user themselves.
    match /fcmTokens/{userId} {
        allow read, write: if isUser(userId);
    }
    
    // Meetings can be created by any signed-in user.
    // Reading meeting data is open to allow joining.
    // Only the creator can update/delete the meeting document itself.
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      // Participants subcollection:
      // Any signed-in user can create/update their OWN participant document.
      // This is the key rule to fix the "permission-denied" error on join.
      match /participants/{userId} {
        allow read: if isSignedIn();
        allow create, update: if isUser(userId);
        allow delete: if isUser(userId) || isUser(resource.data.creatorId); // User can leave, or host can remove.
      }
    }
    
    // Classrooms
    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;

      // Subcollections within a classroom
      match /{subcollection}/{documentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // More granular control might be needed here depending on the subcollection
        // For now, allow update/delete by the creator of the classroom for management purposes
        allow update, delete: if isSignedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
      
      // Special rule for submissions, allowing students to create them
      match /assignments/{assignmentId}/submissions/{studentId} {
          allow read: if isSignedIn();
          allow create, update: if isUser(studentId);
          allow delete: if isUser(studentId) || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
    }
    
    // Documents and Recordings: Readable by all if not private.
    // Writable/Deletable only by the uploader.
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
      allow create: if isSignedIn();
      allow update, delete: if isUser(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
       allow create: if isSignedIn();
       allow update, delete: if isUser(resource.data.uploaderId);
    }
  }
}
