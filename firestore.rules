
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for authentication
    function signedIn() {
      return request.auth != null;
    }
    
    // Helper function to check ownership of a document
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // A user can only access their own document
      allow read, update, delete: if isOwner(userId);
      // Anyone can create a user document during sign-up
      allow create: if signedIn();

      // User subcollections
      match /{subcollection}/{docId} {
        // A user can manage documents in their own subcollections
        allow read, write, delete: if isOwner(userId);
      }
    }
    
    // --- Meetings Collection ---
    match /meetings/{meetingId} {
      // Anyone can read meeting details to join
      allow get: if signedIn();
      // Only the host can create/update the meeting
      allow create: if isOwner(request.resource.data.hostId);
      allow update: if isOwner(resource.data.hostId);
      allow delete: if isOwner(resource.data.hostId);

      // --- Meeting Subcollections ---
      
      // Participants
      match /participants/{userId} {
        // Any signed-in user can join (create their participant doc)
        allow create: if signedIn();
        // Only the host or the participant themselves can update/delete their status
        allow read, update, delete: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId) || isOwner(userId);
      }

      // Join Requests
      match /joinRequests/{requestId} {
        // Anyone signed-in can read requests (though client logic may filter this)
        allow read: if signedIn();
        // A user can create a join request if the userId in the request matches their own
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        // The host can approve/deny (update), or the user can cancel (delete)
        allow update: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
        allow delete: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId) || isOwner(requestId);
      }
    }
    
    // --- Classrooms Collection ---
    match /classrooms/{classroomId} {
      // Public classrooms can be read by anyone, private ones require membership (simplified for now)
      allow get: if signedIn();
      allow list: if signedIn(); // Allow listing classrooms
      
      // Creating, updating, deleting classrooms
      allow create: if isOwner(request.resource.data.teacherId);
      allow update: if isOwner(resource.data.teacherId);
      allow delete: if isOwner(resource.data.teacherId);
      
      // --- Classroom Subcollections ---
      
      // Join Requests for Classrooms
      match /joinRequests/{requestId} {
          allow read: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
          allow create: if signedIn() && request.resource.data.requesterId == request.auth.uid;
          allow delete: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) || request.auth.uid == requestId;
      }
      
      // Other subcollections (materials, assignments, etc.)
      match /{subcollection}/{docId} {
        // Read access for everyone who can access the classroom
        allow read: if signedIn();
        // Write access for teachers/creators
        allow write: if isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
       // Submissions within assignments
      match /assignments/{assignmentId}/submissions/{submissionId} {
        allow read: if signedIn();
        allow write: if signedIn(); // Simplified: allow any signed in user to submit/be graded
      }
    }

    // --- Documents & Recordings Collections (Global) ---
    match /{collection}/{docId} {
      // Allow read if the document is not private
      allow read: if resource.data.isPrivate == false;
      // Allow read/write/delete if the user is the owner
      allow read, write, delete: if isOwner(resource.data.uploaderId);
      // Allow any signed-in user to create documents/recordings
      allow create: if signedIn();
    }
    
     match /fcmTokens/{userId} {
        allow read, write: if isOwner(userId);
    }
  }
}
