rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ Meetings collection
    match /meetings/{meetingId} {
      // Anyone logged in can read meeting info
      allow read: if true;

      // Only host (creator) can create/update/delete
      allow create, update, delete: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;

      // Make sure hostId cannot be changed by anyone else
      allow update: if request.auth != null
        && resource.data.hostId == request.auth.uid
        && request.resource.data.hostId == resource.data.hostId;
    }

    // ✅ Join requests collection
    match /meetings/{meetingId}/joinRequests/{requestId} {
      // Participants can create their own join request
      allow create: if request.auth != null
        && request.resource.data.participantId == request.auth.uid;

      // Host can read & update (accept/decline)
      allow read, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    // ✅ Participants collection
    match /meetings/{meetingId}/participants/{participantId} {
      // Only host can add participants
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;

      // Participant can read/remove themselves
      allow read, delete: if request.auth != null
        && request.auth.uid == participantId;

      // Host can read/remove anyone
      allow read, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }
  }
}
