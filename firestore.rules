
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }

    function isClassCreator(classId, userId) {
      return getDoc('classes/' + classId).data.creatorId == userId;
    }

    function isClassMember(classId, userId) {
      return exists(/databases/$(database)/documents/classes/$(classId)/members/$(userId));
    }

    function isMeetingCreator(meetingId, userId) {
      return getDoc('meetings/' + meetingId).data.creatorId == userId;
    }

    function isMeetingParticipant(meetingId, userId) {
      return exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(userId));
    }

    function isExamTeacher(examId, userId) {
      // This assumes an exam document has a `creatorId` field.
      return getDoc('exams/' + examId).data.creatorId == userId;
    }


    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      allow update, delete: if isUserAuthenticated() && isMeetingCreator(meetingId, request.auth.uid);

      match /participants/{participantId} {
        allow list, read: if isUserAuthenticated() && isMeetingParticipant(meetingId, request.auth.uid);
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid);
      }
    }


    // ===== CLASSES =====
    match /classes/{classId} {
      // Allow any authenticated user to list and read classes.
      // The query on the "My Classes" page (`where('creatorId', '==', user.uid)`) secures the list operation.
      allow list, read: if isUserAuthenticated();
      
      // Allow creation only if the user making the request is the creator listed in the new document.
      allow create: if isOwner(request.resource.data.creatorId);
      
      // Allow updates and deletes only for the user who created the class.
      allow update, delete: if isUserAuthenticated() && isClassCreator(classId, request.auth.uid);

      // --- Members Subcollection (Placeholder) ---
      match /members/{userId} {
        allow list: if isUserAuthenticated() && (isClassCreator(classId, request.auth.uid) || isClassMember(classId, request.auth.uid));
        allow read, write, delete: if isUserAuthenticated() && (isClassCreator(classId, request.auth.uid) || isOwner(userId));
      }

      // --- Other Classroom Subcollections (Placeholders) ---
      match /assignments/{docId} {
        allow list, read: if isUserAuthenticated();
        allow write, delete: if isUserAuthenticated() && isClassCreator(classId, request.auth.uid);
      }
      match /materials/{docId} {
        allow list, read: if isUserAuthenticated();
        allow write, delete: if isUserAuthenticated() && isClassCreator(classId, request.auth.uid);
      }
    }


    // ===== EXAMS (Placeholder) =====
    match /exams/{examId} {
      allow list, read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      allow update, delete: if isUserAuthenticated() && isExamTeacher(examId, request.auth.uid);

      match /submissions/{submissionUserId} {
        allow read: if isUserAuthenticated() && (isOwner(submissionUserId) || isExamTeacher(examId, request.auth.uid));
        allow create, update, delete: if isOwner(submissionUserId);
      }
    }
  }
}
