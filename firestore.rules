/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for meetings, with specific authorization
 * for managing join requests.  It prioritizes secure access to meeting data and
 * restricts unauthorized modifications.
 *
 * Data Structure:
 * - /meetings/{meetingId}: Stores meeting metadata, including creatorId.
 * - /meetings/{meetingId}/joinRequests/{userId}: Stores requests from users to join a meeting.
 * - /meetings/{meetingId}/participants/{userId}: Stores profile information for meeting participants.
 *
 * Key Security Decisions:
 * - Only the meeting creator can manage (approve/deny) join requests.
 * - Users can only create join requests for themselves.
 * - Listing meetings is allowed for all users.
 *
 * Denormalization for Authorization:
 * The `Meeting` document includes the `creatorId` field, enabling efficient
 * ownership checks without requiring additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /meetings collection.
     * @path /meetings/{meetingId}
     * @allow get, list: Anyone can read the meeting details.
     * @allow create: Any authenticated user can create a meeting.
     * @allow update, delete: Only the meeting creator can update or delete a meeting.
     * @principle Enforces document ownership for writes.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.creatorId);
    }

    /**
     * @description Rules for the /meetings/{meetingId}/joinRequests collection.
     * @path /meetings/{meetingId}/joinRequests/{userId}
     * @allow get, list: Only the meeting creator can read join requests.
     * @allow create: Any authenticated user can create a join request for themselves.
     * @allow update, delete: Only the meeting creator can update or delete join requests.
     * @principle Enforces meeting creator control over join requests.
     */
    match /meetings/{meetingId}/joinRequests/{userId} {
      allow get, list: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isExistingOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
    }

    /**
     * @description Rules for the /meetings/{meetingId}/participants collection.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow get, list: Only the meeting creator can read participants.
     * @allow create: No one should be able to directly create participants. Participants are added by the application logic.
     * @allow update, delete: No one should be able to directly update/delete participants. Participants are managed by the application logic.
     * @principle Restricts access to meeting participants.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the resource.
     * @param {string} userId The UID of the user to check against.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the existing owner of the resource and the resource exists.
     * @param {string} userId The UID of the user to check against.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}