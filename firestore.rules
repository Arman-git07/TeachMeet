rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Classrooms collection
    match /classrooms/{classId} {
      allow read: if true;

      // Only the classroom creator can update or delete the classroom
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;

      // Shared collections
      match /{collectionName}/{docId} where 
        collectionName in ['announcements', 'materials', 'assignments', 'exams'] {
        allow read: if true;
        allow create: if request.auth != null;
        
        // ✅ Delete allowed if:
        // 1. The item was uploaded by the user (uploaderId)
        // 2. The classroom was created by the user (createdBy in parent doc)
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      // Submissions subcollection
      match /assignments/{assignmentId}/submissions/{submissionId} {
         allow read, write: if request.auth != null;
      }
    }

    // Other top-level collections
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /documents/{docId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow write, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow write, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /meetings/{meetingId}/{allPaths=**} {
        allow read, write: if request.auth != null;
    }
  }
}
    