
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Meetings can be read by any authenticated user.
    // A meeting can be created by any authenticated user.
    // Only the creator of the meeting can update or delete it.
    match /meetings/{meetingId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.creatorId;

      // Participants can be read by any authenticated user.
      // A user can only add or remove themselves from the participants list.
      match /participants/{userId} {
        allow read, create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Allow users to manage their own documents.
    // Public documents can be read by anyone.
    match /documents/{documentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    // Allow users to manage their own recordings.
    // Public recordings can be read by anyone.
    match /recordings/{recordingId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
    
    // Allow users to manage their own FCM tokens for push notifications.
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
