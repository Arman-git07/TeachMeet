
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings Collection Rules
    match /meetings/{meetingId} {
      // Any authenticated user can read meeting details.
      allow read: if request.auth != null;

      // A user can create a meeting if they are setting themselves as the host.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.hostId;

      // The host of the meeting is allowed to update it.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.hostId;

      // The host of the meeting is allowed to delete it.
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.hostId;

      // --- Participants Subcollection ---
      match /participants/{participantId} {
        // A user can create their own participant document.
        // This is crucial for the host's batched write.
        allow create: if request.auth != null
                      && request.auth.uid == participantId;
        
        // A user can update or delete their own participant document.
        allow update, delete: if request.auth != null
                              && request.auth.uid == participantId;
        
        // Any authenticated user in the meeting can see other participants.
        allow read: if request.auth != null;
      }
      
      // --- Join Requests Subcollection ---
      match /joinRequests/{userId} {
        // Any authenticated user can create a request to join.
        allow create: if request.auth != null && request.auth.uid == userId;

        // The host of the meeting can read and delete join requests.
        allow read, delete: if request.auth != null 
                             && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }
    }

    // Classroom Collection Rules (safe default)
    match /classrooms/{classroomId} {
        allow read: if resource.data.isPublic == true || request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
      
        // Allow reads/writes to subcollections for authorized users.
        match /{subcollection}/{docId} {
           allow read, write: if request.auth != null;
        }
    }
    
    // User-specific collections
    match /users/{userId}/{document=**} {
      // A user can manage their own documents.
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    match /documents/{documentId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }
    
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
