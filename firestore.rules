rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions to check user roles based on classroom data
    function isCreator(classId, userId) {
      let classroomData = get(/databases/$(database)/documents/classrooms/$(classId)).data;
      // Check multiple possible fields for the creator's ID
      return userId == classroomData.get('createdBy', null) ||
             userId == classroomData.get('creatorId', null) ||
             userId == classroomData.get('ownerId', null) ||
             userId == classroomData.get('teacherId', null); // Legacy field
    }

    function isTeacher(classId, userId) {
      let classroomData = get(/databases/$(database)/documents/classrooms/$(classId)).data;
      // Check if user is in the 'teachers' array (either as string UID or object with UID)
      let teachersList = classroomData.get('teachers', []);
      return (teachersList is list && userId in teachersList) || 
             (teachersList is list && teachersList.hasAny([{'uid': userId}])) ||
             exists(/databases/$(database)/documents/classrooms/$(classId)/teachers/$(userId)); // Check subcollection
    }
    
    function isStudent(classId, userId) {
       let classroomData = get(/databases/$(database)/documents/classrooms/$(classId)).data;
       return userId in classroomData.get('students', []);
    }

    function canPost(classId, userId) {
      return isCreator(classId, userId) || isTeacher(classId, userId);
    }

    // Rules for classrooms collection
    match /classrooms/{classroomId} {
      allow read: if true; // Publicly readable, adjust if necessary
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isCreator(classroomId, request.auth.uid);

      // Rules for subcollections
      match /announcements/{announcementId} {
        allow read: if true;
        allow create, update, delete: if canPost(classroomId, request.auth.uid);
      }

      match /materials/{materialId} {
        allow read: if true;
        allow create, update: if canPost(classroomId, request.auth.uid);
        // Only the uploader or the classroom creator can delete
        allow delete: if request.auth != null && (request.auth.uid == resource.data.uploaderId || isCreator(classroomId, request.auth.uid));
      }
      
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create, update, delete: if canPost(classroomId, request.auth.uid);
        
        match /submissions/{submissionId} {
            allow create: if isStudent(classroomId, request.auth.uid) && request.auth.uid == request.resource.data.studentId;
            allow read, update: if canPost(classroomId, request.auth.uid) || request.auth.uid == resource.data.studentId;
            allow delete: if isCreator(classroomId, request.auth.uid) || request.auth.uid == resource.data.studentId;
        }
      }
      
      match /exams/{examId} {
        allow read: if true;
        allow create, update, delete: if canPost(classroomId, request.auth.uid);
      }
      
      match /participants/{participantId} {
        allow read: if true;
        allow create, update, delete: if canPost(classroomId, request.auth.uid);
      }
      
      match /joinRequests/{requestId} {
        allow read, delete: if canPost(classroomId, request.auth.uid) || request.auth.uid == requestId;
        allow create: if request.auth != null;
      }
      
      match /teachers/{teacherId} {
        allow read: if true;
        allow create, update, delete: if isCreator(classroomId, request.auth.uid);
      }
    }

    // Rules for top-level user collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /pendingJoinRequests/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
     match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
  }
}
