rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Is the user the original creator of the classroom?
    function isClassroomCreator(classroomId) {
      return isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
    }

    // Is the user listed as a teacher for the classroom?
    function isClassroomTeacher(classroomId) {
      let teachersList = get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers;
      // Handle both legacy array of UIDs and new array of objects
      return request.auth.uid in teachersList || request.auth.uid in teachersList.map(t => t.uid);
    }
    
    function isClassroomManager(classroomId) {
        return isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
    }

    // Is the user an enrolled student?
    function isClassroomStudent(classroomId) {
        let studentsList = get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students;
        return request.auth.uid in studentsList;
    }

    // Is the user a member (creator, teacher, or student)?
    function isClassroomMember(classroomId) {
        return isClassroomManager(classroomId) || isClassroomStudent(classroomId);
    }
    
    //----------------------------------------------------------------
    // Collections
    //----------------------------------------------------------------

    // Meetings
    match /meetings/{meetingId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.creatorId;

      // Meeting Participants
      match /participants/{userId} {
        // Any signed-in user can join a meeting (create their participant doc)
        allow create: if isSignedIn();
        // A user can only read/update/delete their own participant doc
        allow read, update, delete: if isUser(userId);
      }
    }

    // Classrooms
    match /classrooms/{classroomId} {
      // Public classrooms are readable by anyone, private ones only by members.
      allow read: if resource.data.isPublic == true || isClassroomMember(classroomId);
      allow create: if isSignedIn();
      // Only the creator can update top-level classroom details or delete it.
      allow update, delete: if isClassroomCreator(classroomId);

      // --- Subcollections of Classrooms ---

      match /announcements/{announcementId} {
        allow read: if isClassroomMember(classroomId);
        allow create: if isClassroomManager(classroomId);
        allow delete: if isClassroomManager(classroomId) || isUser(resource.data.creatorId);
      }

      match /materials/{materialId} {
        allow read: if isClassroomMember(classroomId);
        allow create: if isClassroomManager(classroomId);
        allow delete: if isClassroomManager(classroomId) || isUser(resource.data.uploaderId);
      }
      
      match /assignments/{assignmentId} {
        allow read: if isClassroomMember(classroomId);
        allow create: if isClassroomManager(classroomId);
        allow delete: if isClassroomManager(classroomId) || isUser(resource.data.creatorId);

        match /submissions/{submissionId} {
            allow read: if isClassroomManager(classroomId) || isUser(submissionId);
            allow create, update: if isUser(submissionId); // Student submits
            // Teachers can update for grading
            allow update: if isClassroomManager(classroomId);
        }
      }

      match /exams/{examId} {
        allow read: if isClassroomMember(classroomId);
        allow create: if isClassroomManager(classroomId);
        allow delete: if isClassroomManager(classroomId) || isUser(resource.data.authorId);
      }

      // Join requests can be read by managers, created by anyone signed in.
      match /joinRequests/{userId} {
        allow read, delete: if isClassroomManager(classroomId);
        allow create: if isSignedIn();
      }

      // Participant list is readable by members.
      match /participants/{userId} {
        allow read: if isClassroomMember(classroomId);
        // Only managers can add/remove participants directly.
        allow create, delete: if isClassroomManager(classroomId);
      }

      match /teachers/{userId} {
        allow read: if isClassroomMember(classroomId);
        allow create, delete, update: if isClassroomManager(classroomId);
      }
    }
    
    // User-specific data
    match /users/{userId} {
      allow read, create, update, delete: if isUser(userId);
      
      match /{subcollection}/{docId} {
         allow read, create, update, delete: if isUser(userId);
      }
    }

    // Documents & Recordings (simple owner-based rules)
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
        allow create: if isSignedIn();
        allow delete: if isUser(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || isUser(resource.data.uploaderId);
        allow create: if isSignedIn();
        allow delete: if isUser(resource.data.uploaderId);
    }
    
    // FCM Tokens for notifications
    match /fcmTokens/{userId} {
        allow read, write: if isUser(userId);
    }
  }
}
