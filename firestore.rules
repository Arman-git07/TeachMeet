
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return request.auth.uid == userId;
    }

    // Teachings Collection
    match /teachings/{teachingId} {
      // READ: 
      // - Anyone can read public teachings.
      // - Members and creators can read private teachings.
      allow read: if resource.data.isPublic == true || 
                     (isAuthenticated() && resource.data.members.hasAny([request.auth.uid]));

      // CREATE: Any authenticated user can create a teaching.
      allow create: if isAuthenticated() && isUser(request.resource.data.creatorId);

      // UPDATE:
      // - The creator can update any field.
      // - Any authenticated user can add themselves to the pendingRequests list.
      allow update: if isAuthenticated() && (
        isUser(resource.data.creatorId) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
          request.resource.data.pendingRequests == resource.data.pendingRequests.union([request.auth.uid])
        )
      );

      // DELETE: Only the creator can delete their teaching.
      allow delete: if isAuthenticated() && isUser(resource.data.creatorId);
    }
    
    // Meetings Collection
    match /meetings/{meetingId} {
      // READ: Any authenticated user can read a meeting document to check its details.
      allow read: if isAuthenticated();
      
      // CREATE: An authenticated user can create a meeting document.
      allow create: if isAuthenticated() && isUser(request.resource.data.creatorId);
      
      // UPDATE: 
      // - The host can update members.
      // - Any user can add themselves to pendingRequests.
      allow update: if isAuthenticated() && (
        isUser(resource.data.creatorId) ||
        (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
            request.resource.data.pendingRequests == resource.data.pendingRequests.union([request.auth.uid])
        )
      );
    }
    
    // Participants Sub-collection in Meetings
    match /meetings/{meetingId}/participants/{participantId} {
        // READ/LIST: Any authenticated user can see who is in a meeting.
        allow read: if isAuthenticated();
        
        // CREATE/UPDATE: A user can only create or update their OWN participant document.
        allow write: if isAuthenticated() && isUser(participantId);
    }

    // Documents Collection
    match /documents/{documentId} {
      // READ: 
      // - Anyone can read public documents.
      // - Only the owner can read their private documents.
      allow read: if resource.data.isPrivate == false ||
                     (isAuthenticated() && isUser(resource.data.uploaderId));

      // CREATE: An authenticated user can upload a document.
      allow create: if isAuthenticated() && isUser(request.resource.data.uploaderId);

      // DELETE: Only the uploader can delete their document.
      allow delete: if isAuthenticated() && isUser(resource.data.uploaderId);
    }

    // Recordings Collection
    match /recordings/{recordingId} {
      // READ:
      // - Anyone can read public recordings.
      // - Only the owner can read their private recordings.
      allow read: if resource.data.isPrivate == false ||
                     (isAuthenticated() && isUser(resource.data.uploaderId));

      // CREATE: An authenticated user can upload a recording.
      allow create: if isAuthenticated() && isUser(request.resource.data.uploaderId);

      // DELETE: Only the uploader can delete their recording.
      allow delete: if isAuthenticated() && isUser(resource.data.uploaderId);
    }
    
    // FCM Tokens Collection
    match /fcmTokens/{userId} {
      // WRITE: A user can only write to their own FCM token document.
      allow write: if isAuthenticated() && isUser(userId);
    }
  }
}

