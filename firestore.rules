
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function signedIn() {
      return request.auth != null;
    }

    // CLASSROOMS
    match /classrooms/{classroomId} {
      // Allow any signed-in user to query the collection.
      // Client-side queries MUST enforce visibility (e.g., where('isPublic', '==', true))
      allow list, get: if signedIn();

      // Only an authenticated user can create a classroom for themselves.
      allow create: if signedIn() && request.auth.uid == request.resource.data.teacherId;

      // Only the teacher who created the class can update or delete it.
      allow update, delete: if signedIn() && request.auth.uid == resource.data.teacherId;

      // JOIN REQUESTS Subcollection
      match /joinRequests/{requestId} {
        // A user can only create a join request for themselves.
        allow create: if signedIn() && request.auth.uid == request.resource.data.requesterId;
        
        // The classroom teacher can read/update/delete any request.
        // The user who made the request can read their own request.
        allow read, update, delete: if signedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId ||
          (request.auth.uid == resource.data.requesterId && request.method == 'read')
        );
      }

      // PARTICIPANTS Subcollection
      match /participants/{participantId} {
        allow read: if signedIn();
        allow write: if signedIn() && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
      
      // TEACHERS Subcollection
      match /teachers/{teacherId} {
         allow read: if signedIn();
         allow write: if signedIn() && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }

      // Other Subcollections (Materials, Assignments, Exams, etc.)
      match /{subcollection}/{docId} {
        allow read: if signedIn(); // Allow all participants to read materials/assignments
        allow write, delete: if signedIn() && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // USERS
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;

      // Subcollections under a user can only be modified by that user.
      // Allow the classroom teacher (creator) to write to the 'enrolled' collection of another user.
      match /enrolled/{classroomId} {
        allow read, delete: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn() && (
            request.auth.uid == userId ||
            request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId
        );
      }
      
      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if signedIn() && request.auth.uid == userId;
      }
    }

    // MEETINGS
    match /meetings/{meetingId} {
      allow read, list: if true;
      allow create, update, delete: if signedIn() && request.auth.uid == request.resource.data.hostId;

      match /joinRequests/{userId} {
        allow create: if signedIn() && request.auth.uid == request.resource.data.studentId;
        allow read, update, delete: if signedIn() && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }

      match /participants/{userId} {
        allow read: if signedIn();
        allow write: if signedIn() && (request.auth.uid == userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid);
      }
    }

    // DOCUMENTS
    match /documents/{documentId} {
      allow read: if signedIn() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }

    // RECORDINGS
    match /recordings/{recordingId} {
      allow read: if signedIn() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }
  }
}
