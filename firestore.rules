rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /classrooms/{classroomId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.teacherId;
      
      function isOwner(classDoc) {
        return request.auth.uid == classDoc.data.createdBy;
      }
      
      // Announcements
      match /announcements/{announcementId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId || 
          isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)))
        );
      }
      
      // Materials
      match /materials/{materialId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)))
        );
      }
      
      // Assignments
      match /assignments/{assignmentId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)))
        );
        
        match /submissions/{submissionId} {
          allow read, write: if request.auth != null;
        }
      }

      // Exams
      match /exams/{examId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)))
        );
      }

      // Other subcollections
      match /joinRequests/{requestId} {
        allow read, write: if request.auth != null;
      }
      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }
      match /teachers/{teacherId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /users/{userId} {
        allow read: if request.auth.uid == userId;
        allow write: if request.auth.uid == userId;

        match /enrolled/{classroomId} {
            allow read, write: if request.auth.uid == userId;
        }
        match /pendingJoinRequests/{classroomId} {
            allow read, write, delete: if request.auth.uid == userId;
        }
    }

    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
        allow create: if request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth.uid == resource.data.uploaderId;
    }
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
        allow create: if request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth.uid == resource.data.uploaderId;
    }
    match /fcmTokens/{userId} {
        allow read, write: if request.auth.uid == userId;
    }
    match /meetings/{meetingId} {
        allow read, write: if request.auth != null;

        match /participants/{participantId} {
            allow read, write, delete: if request.auth != null;
        }
        match /joinRequests/{requestId} {
            allow read, write, delete: if request.auth != null;
        }
    }
  }
}
