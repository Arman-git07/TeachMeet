rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow logged-in users to manage their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classroom rules
    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }

    match /classrooms/{classroomId}/{subcollection}/{documentId} {
      // Allow any authenticated user to send a join request
      allow create: if request.auth != null && subcollection == 'joinRequests';
      // Creator/teacher can read/write everything else
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
    }
    
    // Meeting rules
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      // Allow creation only if the creatorId in the new doc matches the user's ID
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }
    
    match /meetings/{meetingId}/{subcollection}/{documentId} {
       // Allow any authenticated user to create a join request
      allow create: if request.auth != null && subcollection == 'joinRequests';
      // The host can read/write everything in their meeting's subcollections
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
    }

    // Documents & Recordings rules
    match /documents/{docId} {
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      allow read: if request.resource.data.isPrivate == false || (request.auth != null && request.resource.data.uploaderId == request.auth.uid);
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    match /recordings/{recId} {
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      allow read: if request.resource.data.isPrivate == false || (request.auth != null && request.resource.data.uploaderId == request.auth.uid);
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
  }
}
