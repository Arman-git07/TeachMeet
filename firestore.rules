
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // FCM Tokens: Allow users to write their own token
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Teachings: Secure rules for creating, viewing, and managing teachings
    match /teachings/{teachingId} {
      // ANYONE can read a public teaching.
      // A MEMBER of a private teaching can read it.
      allow read: if resource.data.isPublic == true || request.auth.uid in resource.data.members;

      // ANY authenticated user can create a teaching.
      // Creator must be the authenticated user.
      // Creator must be in the members list.
      allow create: if isAuthenticated()
                    && request.resource.data.creatorId == request.auth.uid
                    && request.auth.uid in request.resource.data.members;
      
      // ONLY the creator can update the teaching document.
      allow update: if isOwner(resource.data.creatorId)
                    // Exception: Any authenticated user can add themselves to pendingRequests
                    || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']));
      
      // ONLY the creator can delete the teaching.
      allow delete: if isOwner(resource.data.creatorId);
    }

    // Documents and Recordings: Secure rules for file metadata
    match /{collection}/{docId} {
      // Collection can be 'documents' or 'recordings'
      
      // READ: Anyone can read public documents/recordings.
      // Only the owner can read their private documents/recordings.
      allow read: if resource.data.isPrivate == false || (isAuthenticated() && isOwner(resource.data.uploaderId));
      
      // CREATE: Any authenticated user can create a document/recording metadata entry.
      // The uploaderId must match the authenticated user's ID.
      allow create: if isAuthenticated() && isOwner(request.resource.data.uploaderId);
      
      // UPDATE, DELETE: Only the owner can update or delete their document/recording metadata.
      allow update, delete: if isAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    // Meetings: Secure rules for meeting rooms and participants
    match /meetings/{meetingId} {
        // READ: Any authenticated member can read the meeting document.
        allow read: if isAuthenticated() && request.auth.uid in resource.data.members;

        // CREATE: Any authenticated user can create a meeting room.
        // The creatorId must be the authenticated user's ID.
        allow create: if isAuthenticated() && isOwner(request.resource.data.creatorId);
        
        // UPDATE: Allow creator to update topic. Allow any auth user to add themselves to members or pendingRequests.
        allow update: if isAuthenticated() && 
                      (isOwner(resource.data.creatorId) || 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingRequests']));
        
        // DELETE: No one can delete a meeting document for now to preserve history.
        allow delete: if false;

        // Participants subcollection
        match /participants/{participantId} {
            // READ: Any authenticated user in the meeting can read participant list.
            // This relies on the parent read rule implicitly. A more secure rule would check parent `members` array.
            allow read: if isAuthenticated();

            // CREATE, UPDATE: Only the specific participant can write or update their own data.
            allow create, update: if isAuthenticated() && isOwner(participantId);

            // DELETE: A participant can remove themselves from the meeting.
            allow delete: if isAuthenticated() && isOwner(participantId);
        }
    }
  }
}
