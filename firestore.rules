rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isUser(userId) {
      return request.auth.uid == userId;
    }

    // FCM Tokens: Allow users to write their own token.
    match /fcmTokens/{userId} {
      allow read, write: if isUser(userId);
    }
    
    // Meetings
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.members ||
        // Allow adding self to members or pendingRequests
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingRequests']) &&
         (request.resource.data.members == resource.data.members.concat([request.auth.uid]) ||
          request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])))
      );
      
      // Participants subcollection
      match /participants/{userId} {
        allow read: if isSignedIn();
        // Allow user to create/update their own participant doc.
        // Allow host to manage participants (future-proofing).
        allow write: if isSignedIn() && (isUser(userId) || resource.data.creatorId == request.auth.uid);
        allow delete: if isSignedIn() && isUser(userId);
      }
    }

    // Teachings:
    // Any authenticated user can read all teachings.
    // Users can create/update/delete their own teachings.
    // Any user can request to join.
    match /teachings/{teachingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.isPublic is bool
                    && request.resource.data.creatorName is string
                    && request.resource.data.members == [request.auth.uid]
                    && request.resource.data.pendingRequests == [];

      allow update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    // Documents:
    // Allow read of public documents by any signed-in user.
    // Allow read of private documents only by the owner.
    // Allow create, update, delete only by the owner.
    match /documents/{documentId} {
      allow read: if isSignedIn() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow write: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }

    // Recordings:
    // Allow read of public recordings by any signed-in user.
    // Allow read of private recordings only by the owner.
    // Allow create, update, delete only by the owner.
    match /recordings/{recordingId} {
      allow read: if isSignedIn() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow write: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }
  }
}
