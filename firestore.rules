rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && isUser(resource.data.creatorId);
      
      // Meeting Participants
      match /participants/{userId} {
      	allow read: if isAuth();
        // Allow any authenticated user to add themselves, or the host to manage
        allow create, update: if isAuth() && (isUser(userId) || isUser(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId));
        allow delete: if isAuth() && (isUser(userId) || isUser(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId));
      }
    }
    
    // Classrooms
    match /classrooms/{classroomId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Only the original creator can update/delete the classroom settings
      allow update, delete: if isAuth() && isUser(resource.data.teacherId);
      
      match /announcements/{announcementId} {
        allow read: if isAuth();
        allow create: if isAuth() && (isUser(request.resource.data.authorId));
        allow delete: if isAuth() && (isUser(resource.data.authorId));
      }

      match /materials/{materialId} {
        allow read: if isAuth();
        allow create: if isAuth() && isUser(request.resource.data.uploaderId);
        allow delete: if isAuth() && isUser(resource.data.uploaderId);
      }
      
      match /exams/{examId} {
        allow read: if isAuth();
        allow create: if isAuth() && isUser(request.resource.data.authorId);
        allow delete: if isAuth() && isUser(resource.data.authorId);
      }

      match /joinRequests/{requestId} {
        allow read, create: if isAuth();
        // The user who made the request can delete it (cancel), or the classroom owner can
        allow delete: if isAuth() && (isUser(requestId) || isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId));
      }

      match /participants/{participantId} {
        allow read: if isAuth();
        allow create, delete: if isAuth() && isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

       match /teachers/{teacherId} {
        allow read: if isAuth();
        allow create, delete: if isAuth() && isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

      match /assignments/{assignmentId} {
        allow read, create: if isAuth();
        allow delete: if isAuth() && isUser(resource.data.creatorId);

        match /submissions/{submissionId} {
            allow read, create, update: if isAuth() && (isUser(submissionId) || isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)/assignments/$(assignmentId)).data.creatorId));
        }
      }
    }

    // Documents and Recordings (user-specific)
    match /documents/{documentId} {
      // Allow read if public, or if the user is the owner
      allow read: if resource.data.isPrivate == false || (isAuth() && isUser(resource.data.uploaderId));
      // Allow create/delete only by the uploader
      allow create: if isAuth() && isUser(request.resource.data.uploaderId);
      allow delete: if isAuth() && isUser(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
      // Allow read if public, or if the user is the owner
      allow read: if resource.data.isPrivate == false || (isAuth() && isUser(resource.data.uploaderId));
      // Allow create/delete only by the uploader
      allow create: if isAuth() && isUser(request.resource.data.uploaderId);
      allow delete: if isAuth() && isUser(resource.data.uploaderId);
    }

    // User-specific data
    match /users/{userId} {
      allow read, write: if isUser(userId);
      match /enrolled/{classroomId} {
        allow read, write: if isUser(userId);
      }
      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if isUser(userId);
      }
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
        allow write: if isUser(userId);
    }
  }
}
