rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isMeetingCreator(meetingId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
    }

    // --- Meetings, Participants, and Join Requests ---
    match /meetings/{meetingId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && isMeetingCreator(meetingId);

      // Participants can be read by anyone in the meeting and can be deleted by themselves or the host.
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isOwner(participantId);
        allow delete: if isSignedIn() && (isOwner(participantId) || isMeetingCreator(meetingId));
      }

      // Guests can create their own join request. The host can read and delete them.
      match /joinRequests/{userId} {
        allow create: if isSignedIn() && isOwner(userId);
        allow read: if isSignedIn() && (isOwner(userId) || isMeetingCreator(meetingId));
        allow delete: if isSignedIn() && (isOwner(userId) || isMeetingCreator(meetingId));
      }
    }

    // --- Teachings ---
    match /teachings/{teachingId} {
      // Anyone can discover public teachings. Members can read private ones.
      allow read: if resource.data.isPublic == true || (isSignedIn() && resource.data.allowedStudents.hasAny([request.auth.uid]));
      // Only the owner can create, update, or delete a teaching.
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    // --- User-specific subcollections ---
    match /users/{userId}/{collectionId}/{docId} {
      allow read, write, delete: if isSignedIn() && isOwner(userId);
    }
    
    // --- Documents & Recordings (General user content) ---
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (isSignedIn() && resource.data.uploaderId == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (isSignedIn() && resource.data.uploaderId == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }
    
    // Allow users to manage their own FCM tokens.
    match /fcmTokens/{userId} {
        allow write: if isSignedIn() && isOwner(userId);
    }
  }
}
