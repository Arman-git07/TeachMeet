rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is authenticated.
     * @return {boolean} True if the user is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /meetings/{meetingId} {
      /**
       * @description Allows anyone to read meeting details.
       * @path /meetings/{meetingId}
       * @allow (get, list): if true
       * @deny (create, update, delete): if false
       * @principle Public read access for meeting details.
       */
      allow get, list: if true;

      /**
       * @description Allows an authenticated user to create a meeting if they are the host.
       * @path /meetings/{meetingId}
       * @allow (create): Authenticated user creates a meeting with hostId matching their UID.
       * @deny (create): User attempts to create a meeting with a mismatched hostId.
       * @principle Enforces host-ownership for meeting creation.
       */
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;

      /**
       * @description Allows the host of a meeting to update or delete it.
       * @path /meetings/{meetingId}
       * @allow (update, delete): Authenticated user is the host of the meeting.
       * @deny (update, delete): User attempts to modify a meeting they don't host.
       * @principle Enforces host-ownership for meeting updates and deletion.
       */
      allow update, delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /joinRequests/{requestId} {
        /**
         * @description Allows a participant to create a join request for themselves.
         * @path /meetings/{meetingId}/joinRequests/{requestId}
         * @allow (create): Authenticated user creates a join request with userId matching their UID.
         * @deny (create): User attempts to create a join request for another user.
         * @principle Enforces user-ownership for join request creation.
         */
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

        /**
         * @description Allows a participant to read their own join request or the host to read any join request.
         * @path /meetings/{meetingId}/joinRequests/{requestId}
         * @allow (get): Authenticated user reads their own join request or the host reads any request.
         * @deny (get): User attempts to read another user's join request and is not the host.
         * @principle Allows user to read own request and host to read all requests.
         */
        allow get: if isSignedIn() && (
            resource.data.userId == request.auth.uid ||
            get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid
        );
        /**
         * @description  Participants cannot list other join requests.
         * @path /meetings/{meetingId}/joinRequests/{requestId}
         * @allow list: The host can read all join requests.
         * @deny list: A non-host user attempts to list join requests.
         * @principle Prevents unauthorized listing of join requests
         */
        allow list: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;

        /**
         * @description Allows the host to update/delete any join request or the participant to update their own request.
         * @path /meetings/{meetingId}/joinRequests/{requestId}
         * @allow (update, delete): Authenticated user is the host or the request owner.
         * @deny (update, delete): User attempts to modify a request they don't own and are not the host.
         * @principle Enforces host-control over requests and allows user to modify own request.
         */
        allow update, delete: if isSignedIn() && (get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid || (resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId));
      }

      match /participants/{participantId} {
        /**
         * @description Allows any authenticated user to read the list of participants.
         * @path /meetings/{meetingId}/participants/{participantId}
         * @allow (get, list): Authenticated user reads the participants list.
         * @deny (create, update, delete): if false
         * @principle Authenticated read access for participant list.
         */
        allow get, list: if isSignedIn();

        /**
         * @description Allows the host to manage (create, update, delete) the participants list.
         * @path /meetings/{meetingId}/participants/{participantId}
         * @allow (create, update, delete): Authenticated user is the host of the meeting.
         * @deny (create, update, delete): User attempts to modify the participants list and is not the host.
         * @principle Enforces host-ownership for participant management.
         */
        allow create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
    }

    // Existing rules for classrooms (preserved as requested in prompt)
    match /classrooms/{classroomId}/joinRequests/{userId} {
        allow read, write: if false; // TODO: Add your rules here
      }

      match /classrooms/{classroomId}/participants/{userId} {
        allow read, write: if false; // TODO: Add your rules here
      }
  }
}