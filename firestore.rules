rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to create their own user document
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to manage their FCM tokens
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for meetings
    match /meetings/{meetingId} {
      // Any authenticated user can create a new meeting document
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // Allow read/write for members of the meeting
      allow read, update, delete: if request.auth != null && (get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/meetings/$(meetingId)).data.members);

      // Rules for participants sub-collection
      match /participants/{participantId} {
        // A user can add themselves to the participants list.
        allow create: if request.auth != null && request.auth.uid == participantId;
        
        // Only a user themselves or the meeting creator can update/delete their participant document.
        allow read, update, delete: if request.auth != null && (request.auth.uid == participantId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
      }
    }

    // Rules for recordings
    match /recordings/{recordingId} {
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    // Rules for documents
    match /documents/{documentId} {
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    // =====================================================================
    // Definitive Rules for Teachings Collection
    // =====================================================================
    match /teachings/{teachingId} {

      // READ: Any authenticated user can read any teaching document.
      // This is necessary for the "Discover" tab to work correctly.
      // Client-side code will handle what to show based on membership.
      allow read: if request.auth != null;

      // CREATE: An authenticated user can create a new teaching if:
      // 1. They are the creator.
      // 2. They are the first and only member initially.
      // 3. The list of pending requests is empty.
      // 4. All required fields are present.
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.members == [request.auth.uid]
                    && request.resource.data.pendingRequests == []
                    && request.resource.data.title is string
                    && request.resource.data.description is string
                    && request.resource.data.isPublic is bool
                    && request.resource.data.creatorName is string
                    && request.resource.data.createdAt == request.time;

      // UPDATE: A user can update a teaching document if:
      // Case 1: The user is the creator (teacher) of the teaching.
      //   - They can change the title, description, and visibility.
      //   - They can add or remove members (approving/denying requests).
      //   - They CANNOT change the creatorId or createdAt timestamp.
      //   - The pendingRequests list must only shrink (items removed).
      // Case 2: The user is NOT the creator (student).
      //   - They can ONLY add their own UID to the `pendingRequests` array.
      //   - They cannot change any other field.
      allow update: if request.auth != null && (
        // Case 1: Creator's actions
        (resource.data.creatorId == request.auth.uid
          && request.resource.data.creatorId == resource.data.creatorId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.pendingRequests.size() <= resource.data.pendingRequests.size() // Allow removal
        ) ||
        // Case 2: Student's action (requesting to join)
        (resource.data.creatorId != request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests'])
          && request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])
        )
      );

      // DELETE: Only the creator of the teaching can delete it.
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }
  }
}
