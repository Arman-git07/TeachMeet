rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings Collection
    match /meetings/{meetingId} {
      // Host can create the meeting document.
      // This rule works because request.resource.data contains the data for the *new* document being created.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.hostId;

      // Anyone signed in can read the meeting details.
      allow read: if request.auth != null;

      // Only the host (checked against the existing document's data) can update or delete it.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Participants Subcollection
      match /participants/{participantId} {
        // A user can create their own participant entry, or the host can add them.
        allow create: if request.auth != null && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
        
        // Signed-in users can read the participant list.
        allow read: if request.auth != null;

        // A user can update/delete their own participant document. The host can also manage participants.
        allow update, delete: if request.auth != null && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }
      
      // Join Requests Subcollection
      match /joinRequests/{userId} {
        // Any authenticated user can create a request for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;

        // Only the meeting host can read, update, or delete join requests.
        allow read, update, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }
    }
    
    // User data collections
    match /users/{userId} {
       // A user can read/write their own data.
       allow read, write: if request.auth != null && request.auth.uid == userId;

        // Subcollections for user-specific data
        match /enrolled/{classroomId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
        }
        match /pendingJoinRequests/{classroomId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
        }
    }
    
    // Classrooms Collection
    match /classrooms/{classroomId} {
        // Allow reads for authenticated users. Writes are more granular.
        allow read: if request.auth != null;
        
        // Creator can update/delete.
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
        
        // Any authenticated user can create a classroom.
        allow create: if request.auth != null;

        // Subcollections
        match /{subcollection}/{docId} {
            // Allow reads for authenticated users within any classroom subcollection.
            allow read: if request.auth != null;
            // Write access is more complex and should be handled with more specific rules if needed,
            // but for now, we can restrict it to the classroom teacherId (creator).
            allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
        }
    }
    
    // Documents & Recordings Collections
    match /documents/{docId} {
       // Allow create for any authenticated user.
       allow create: if request.auth != null;
       // Allow read if the document is not private, or if the user is the uploader.
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       // Allow update/delete only for the uploader.
       allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recId} {
       // Same rules as documents.
       allow create: if request.auth != null;
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
