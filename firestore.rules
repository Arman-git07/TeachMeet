rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /classrooms/{classroomId} {
      allow read: if resource.data.isPublic == true ||
        request.auth != null && request.auth.uid == resource.data.teacherId;
      allow write: if request.auth != null &&
        request.auth.uid == request.resource.data.teacherId;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.teacherId;

      // Rules for the joinRequests subcollection
      match /joinRequests/{userId} {
        // Any authenticated user can create a request for themselves.
        allow create: if request.auth.uid == userId;

        // Only the teacher of the classroom can read or delete requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow a user to manage their own enrolled classrooms list
      match /enrolled/{classroomId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
