
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }
    
    function isMeetingCreator(meetingId, userId) {
      return getDoc('meetings/' + meetingId).data.creatorId == userId;
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read, write: if isUserAuthenticated() && isOwner(userId);
      
      match /myTeachings/{teachingId} {
        allow read, list, write, delete: if isUserAuthenticated() && isOwner(userId);
      }
      match /enrolledTeachings/{teachingId} {
        allow read, list, write, delete: if isUserAuthenticated() && isOwner(userId);
      }
    }
    
    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      allow update, delete: if isUserAuthenticated() && isMeetingCreator(meetingId, request.auth.uid);

      match /participants/{participantId} {
        allow list, read: if isUserAuthenticated(); // Simplified for now
        allow create, update: if isOwner(participantId) || (isUserAuthenticated() && isMeetingCreator(meetingId, request.auth.uid));
        allow delete: if isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid);
      }
      
      // This is the new, correct rule set for join requests.
      match /joinRequests/{userId} {
        // Any signed-in user can create their own join request.
        allow create: if isUserAuthenticated() && isOwner(userId);
        
        // The meeting host can read all requests and delete them (to approve/deny).
        // The user who created the request can also read it to check its status.
        allow read: if isUserAuthenticated() && (isMeetingCreator(meetingId, request.auth.uid) || isOwner(userId));

        // The meeting host can delete a request to approve or deny it.
        allow delete: if isUserAuthenticated() && isMeetingCreator(meetingId, request.auth.uid);
      }
    }

    // ===== TEACHINGS =====
    match /teachings/{teachingId} {
      // Public teachings are readable by anyone. Private ones are readable by creator or allowed students.
      allow read: if resource.data.isPublic == true || (isUserAuthenticated() && resource.data.creatorId == request.auth.uid) || (isUserAuthenticated() && request.auth.uid in resource.data.allowedStudents);
      allow list: if isUserAuthenticated();
      
      // Only the creator can create a teaching.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      
      // The creator can update/delete. Students can send join requests by updating the pendingRequests array.
      allow update: if isUserAuthenticated() && (request.resource.data.creatorId == request.auth.uid || request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]));
      allow delete: if isUserAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // ===== DOCUMENTS / RECORDINGS =====
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
      allow list: if isUserAuthenticated();
      allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
    
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
      allow list: if isUserAuthenticated();
      allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isUserAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
    
     // ===== FCM TOKENS =====
    match /fcmTokens/{userId} {
      allow read, write: if isUserAuthenticated() && isOwner(userId);
    }
  }
}
