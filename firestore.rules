rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read their own pending join requests
    match /users/{userId}/pendingJoinRequests/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to manage their enrolled classes list
    match /users/{userId}/enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Open up public classrooms for discovery, but secure join requests
    match /classrooms/{classroomId} {
      allow read: if true; // Anyone can see public classroom details
      allow create, update: if request.auth != null && request.auth.uid == resource.data.teacherId;
      
      match /joinRequests/{userId} {
        allow read: if get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid || request.auth.uid == userId);
      }

      // Secure other subcollections to be managed by teachers/owners
      match /{subcollection}/{docId} {
        allow read: if request.auth != null; // Allow any authenticated user to read content like announcements, materials etc.
        allow write, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }

      match /assignments/{assignmentId}/submissions/{studentId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == studentId;
        allow delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
    }

    // Meeting security rules
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.hostId;
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;

      match /participants/{participantId} {
        // Anyone can add themselves, host can remove others
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == participantId;
        allow delete: if request.auth != null && (get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid || request.auth.uid == participantId);
      }
      
      match /joinRequests/{userId} {
        // User can create their own request
        allow create: if request.auth != null && request.auth.uid == userId;
        // Host can read, update (accept), and delete (deny) requests
        allow read, update, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        // User can see the status of their own request
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rules for user-uploaded content
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // FCM Tokens for notifications
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
