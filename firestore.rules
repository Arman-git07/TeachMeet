rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classroom documents
    match /classrooms/{classroomId} {
      allow read: if true; // Publicly readable to be discoverable
      allow create: if request.auth != null; // Must be logged in to create
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.teacherId ||
        request.auth.uid == resource.data.createdBy
      );
    }
    
    // Classroom Subcollections
    match /classrooms/{classId}/{collection}/{docId} {
      // Default deny all subcollection writes unless specified below
      allow write: if false;
      allow read: if true; // Allow reading all subcollection data by default
    }

    // Join Requests
    match /classrooms/{classId}/joinRequests/{userId} {
       allow create, read: if request.auth != null && request.auth.uid == userId;
       allow delete, update: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
       );
    }

    // Participants
     match /classrooms/{classId}/participants/{userId} {
       allow read: if true;
       allow create, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
       );
    }

    // Teachers
    match /classrooms/{classId}/teachers/{userId} {
      allow read: if true;
      allow create, delete: if request.auth != null && (
        request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
      );
    }

    // Announcements
    match /classrooms/{classId}/announcements/{announcementId} {
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.creatorId ||
        request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
      );
      allow read: if true;
    }

    // Materials
    match /classrooms/{classId}/materials/{materialId} {
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.uploaderId ||
        request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
      );
      allow read: if true;
    }
    
    // Assignments & Submissions
    match /classrooms/{classId}/assignments/{assignmentId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (
            request.auth.uid == resource.data.creatorId ||
            request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
        
        match /submissions/{submissionId} {
            allow read, update: if true; // Allow teacher to update grades/feedback
            allow create: if request.auth != null;
            allow delete: if request.auth != null && (
                request.auth.uid == resource.data.studentId ||
                request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
            );
        }
    }

    // Exams
    match /classrooms/{classId}/exams/{examId} {
      allow create: if request.auth != null;
      allow read: if true;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.uploaderId ||
        request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
      );
    }

    // Documents and Recordings (publicly readable, owned by user)
    match /documents/{docId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }
     match /recordings/{recId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }

    // FCM Tokens
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
        allow read: if false; // Users should not be able to read other's tokens
    }
  }
}
