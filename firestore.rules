rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function isMeetingCreator(meetingId, userId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == userId;
    }
    
    function isMeetingParticipant(meetingId, userId) {
      return exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(userId));
    }

    // --- Meetings ---
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      allow update: if isUserAuthenticated() && isMeetingCreator(meetingId, request.auth.uid);

      // --- Participants ---
      match /participants/{participantId} {
        allow list, read: if isUserAuthenticated() && isMeetingParticipant(meetingId, request.auth.uid);
        allow create: if isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid);
        allow update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid);
      }

      // --- Join Requests ---
      match /joinRequests/{userId} {
        allow create: if isUserAuthenticated() && isOwner(userId);
        allow read, list: if isMeetingCreator(meetingId, request.auth.uid) || isOwner(userId);
        allow delete: if isMeetingCreator(meetingId, request.auth.uid);
      }
    }
    
    // --- Teachings ---
    match /teachings/{teachingId} {
      allow read: if true;
      allow create: if isUserAuthenticated()
                    && request.auth.uid == request.resource.data.creatorId;
      allow update, delete: if isUserAuthenticated() && request.auth.uid == resource.data.creatorId;
    }
    
    // User-specific data
    match /users/{userId} {
      allow read, write: if isUserAuthenticated() && isOwner(userId);

        // Teacher's own teaching records
        match /myTeachings/{teachingId} {
          allow read, write: if isOwner(userId);
        }

        // Student's enrolled teachings
        match /enrolledTeachings/{teachingId} {
          allow read, write: if isOwner(userId);
        }
    }
    
    // --- Documents & Recordings ---
    match /documents/{docId} {
        allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
        allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
        allow delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recId} {
        allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
        allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
        allow delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }

    // --- FCM Tokens ---
    match /fcmTokens/{userId} {
      allow write: if isOwner(userId);
    }
  }
}
