rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----- helpers -----
    function signedIn() {
      return request.auth != null;
    }

    function isCreator(classId) {
      let c = get(/databases/$(database)/documents/classrooms/$(classId));
      return c.data.teacherId == request.auth.uid;
    }

    function isTeacher(classId) {
      let c = get(/databases/$(database)/documents/classrooms/$(classId));

      let inTeacherSubcollection = exists(/databases/$(database)/documents/classrooms/$(classId)/teachers/$(request.auth.uid));
      
      let inParticipantsSubcollection = exists(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid)).data.role == 'teacher';

      return inTeacherSubcollection || inParticipantsSubcollection || isCreator(classId);
    }
    
    function isStudent(classId) {
        return exists(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid)).data.role == 'student';
    }

    function isMember(classId) {
      return isTeacher(classId) || isStudent(classId);
    }

    // ----- classrooms -----
    match /classrooms/{classroomId} {
      allow read: if signedIn();
      allow write: if signedIn() && resource.data.teacherId == request.auth.uid;

      // ----- announcements -----
      match /announcements/{announcementId} {
        allow read: if signedIn() && isMember(classroomId);
        
        allow create: if signedIn() && isTeacher(classroomId) && request.resource.data.creatorId == request.auth.uid;
        
        allow update, delete: if signedIn() && isTeacher(classroomId) && resource.data.creatorId == request.auth.uid;
      }
      
      // ----- participants -----
      match /participants/{userId} {
        allow read: if signedIn() && isMember(classroomId);
        allow create: if signedIn() && (isCreator(classroomId) || request.auth.uid == userId);
        allow delete: if signedIn() && isCreator(classroomId);
      }
      
      // ----- teachers (subject teachers) -----
      match /teachers/{teacherId} {
        allow read: if signedIn();
        allow write: if signedIn() && isCreator(classroomId);
      }
      
      // ----- joinRequests -----
      match /joinRequests/{userId} {
        allow create: if signedIn() && request.auth.uid == userId;
        allow read, delete: if signedIn() && isCreator(classroomId);
      }

      // ----- assignments -----
      match /assignments/{assignmentId} {
        allow read: if signedIn() && isMember(classroomId);
        allow write: if signedIn() && isTeacher(classroomId);
        
        match /submissions/{submissionId} {
            allow read: if signedIn() && isMember(classroomId);
            allow create: if signedIn() && request.auth.uid == request.resource.data.studentId;
            allow update: if signedIn() && isTeacher(classroomId); // For grading
        }
      }

      // ----- materials -----
      match /materials/{materialId} {
        allow read: if signedIn() && isMember(classroomId);
        allow create: if signedIn() && isTeacher(classroomId);
        allow delete: if signedIn() && isTeacher(classroomId);
      }

      // ----- exams -----
      match /exams/{examId} {
        allow read: if signedIn() && isMember(classroomId);
        allow create: if signedIn() && isTeacher(classroomId);
        allow delete: if signedIn() && isTeacher(classroomId);
      }
    }

    // ----- User-specific collections -----
    match /users/{userId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
        
        match /enrolled/{classroomId} {
            allow read, write: if signedIn() && request.auth.uid == userId;
        }
        
        match /pendingJoinRequests/{classroomId} {
            allow read, write, delete: if signedIn() && request.auth.uid == userId;
        }
    }
    
     // ----- Public/Private user content -----
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (signedIn() && resource.data.uploaderId == request.auth.uid);
        allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (signedIn() && resource.data.uploaderId == request.auth.uid);
        allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }

    // ----- Meeting related collections -----
    match /meetings/{meetingId} {
        allow read: if signedIn();
        allow write: if signedIn(); // Open for simplicity, can be tightened
        
        match /participants/{participantId} {
            allow read: if signedIn();
            allow write: if signedIn();
        }
        
        match /joinRequests/{userId} {
            allow read, write, delete: if signedIn();
        }
    }
    
    // ----- FCM Tokens for notifications -----
    match /fcmTokens/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

  }
}
