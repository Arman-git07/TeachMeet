/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure authorization while minimizing schema validation for rapid prototyping.
 * It enforces a strict owner-only access model for user-specific data and allows public read access where appropriate.
 *
 * Data Structure:
 * - /meetings/{meetingId}: Stores meeting metadata, including the hostId.
 * - /meetings/{meetingId}/joinRequests/{requestId}: Stores requests from users to join a meeting.
 * - /meetings/{meetingId}/participants/{participantId}: Stores user profile information of meeting participants.
 * - /classrooms/{classroomId}/joinRequests/{userId}: Stores requests from users to join a classroom.
 * - /classrooms/{classroomId}/participants/{userId}: Stores user profile information of classroom participants.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed to prevent information disclosure.
 * - Public read access is granted to the top-level `/meetings` collection, assuming all documents are public.
 * - All write operations are secured using `request.auth` and ownership checks.
 *
 * Denormalization for Authorization:
 * - The `hostId` is denormalized into the `/meetings/{meetingId}` document to avoid costly `get()` calls when authorizing access to subcollections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read meetings. Only the host can create, update, or delete meetings.
     * @path /meetings/{meetingId}
     * @allow (get, list): Any user can read meeting data.
     * @allow (create): Only the host (request.auth.uid) can create a meeting, and the hostId must match.
     * @allow (update, delete): Only the existing host can update or delete a meeting.
     * @deny  (create): If the request.auth.uid does not match the hostId
     * @deny  (update, delete): If the request.auth.uid does not match the existing hostId
     * @principle Public read, owner-only writes with host ID validation.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.hostId == request.auth.uid && resource != null;
    }

    /**
     * @description Allows participants to create join requests, and the host to read/update/delete them.
     * @path /meetings/{meetingId}/joinRequests/{requestId}
     * @allow (create): A signed-in user can create a join request with their UID as the requestId.
     * @allow (read): A signed-in user can read their own join request, or the host can read all join requests.
     * @allow (update, delete): Only the host can update or delete join requests.
     * @deny (create): If not signed in, or if the userId in the request does not match the authenticated user's UID.
     * @deny (read): If not signed in and not the owner.
     * @deny (update, delete): If not signed in, or if not the host.
     * @principle Owner-only create, shared access for reads, host-only updates/deletes.
     */
    match /meetings/{meetingId}/joinRequests/{requestId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow get, list: if isSignedIn() && (request.auth.uid == requestId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      allow update, delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId && resource != null;
    }

    /**
     * @description Allows the host to manage participants by creating, updating, or deleting their entries. Any signed-in user can read the participants list.
     * @path /meetings/{meetingId}/participants/{participantId}
     * @allow (read): Any signed-in user can read the list of participants.
     * @allow (create, update, delete): Only the host can add, modify, or remove participants.
     * @deny (create, update, delete): If not signed in, or if not the host.
     * @principle Public read, host-only writes.
     */
    match /meetings/{meetingId}/participants/{participantId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId && resource != null;
    }

    /**
     * @description Allows participants to create join requests, and the classroom host to read/update/delete them.
     * @path /classrooms/{classroomId}/joinRequests/{requestId}
     * @allow (create): A signed-in user can create a join request with their UID as the requestId.
     * @allow (read): A signed-in user can read their own join request, or the classroom host can read all join requests.
     * @allow (update, delete): Only the classroom host can update or delete join requests.
     * @deny (create): If not signed in, or if the userId in the request does not match the authenticated user's UID.
     * @deny (read): If not signed in and not the owner or host.
     * @deny (update, delete): If not signed in, or if not the host.
     * @principle Owner-only create, shared access for reads, host-only updates/deletes.
     */
    match /classrooms/{classroomId}/joinRequests/{requestId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow get, list: if isSignedIn() && (request.auth.uid == requestId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId);
      allow update, delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId && resource != null;
    }

    /**
     * @description Allows the classroom host to manage participants by creating, updating, or deleting their entries. Any signed-in user can read the participants list.
     * @path /classrooms/{classroomId}/participants/{participantId}
     * @allow (read): Any signed-in user can read the list of participants.
     * @allow (create, update, delete): Only the classroom host can add, modify, or remove participants.
     * @deny (create, update, delete): If not signed in, or if not the host.
     * @principle Public read, host-only writes.
     */
    match /classrooms/{classroomId}/participants/{participantId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId && resource != null;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}