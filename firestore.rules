rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }

    function isCreator(docPath, userId) {
      return get(docPath).data.creatorId == userId;
    }
    
    function isUploader(docPath, userId) {
        return get(docPath).data.uploaderId == userId;
    }
    
    // --- MEETINGS ---
    match /meetings/{meetingId} {
      // Anyone authenticated can read basic meeting info (like the topic)
      allow read: if isUserAuthenticated();
      // A user can create a meeting if they set themselves as the creator.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      // Only the creator can update or delete the main meeting document.
      allow update: if isUserAuthenticated() && isCreator(/databases/$(database)/documents/meetings/$(meetingId), request.auth.uid);
      // Let's prevent deletion of active meetings for now unless we build an "End Meeting" flow
      allow delete: if false;

      // --- Meeting Participants Subcollection ---
      match /participants/{participantId} {
        // Any authenticated user in the meeting can see who else is there.
        allow list, read: if isUserAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
        // A user can only create or update their own participant document.
        allow create, update: if isOwner(participantId);
        // A user can remove themselves, or the meeting creator can remove them.
        allow delete: if isOwner(participantId) || isCreator(/databases/$(database)/documents/meetings/$(meetingId), request.auth.uid);
      }
    }

    // --- TEACHINGS (CLASSROOMS) ---
    match /teachings/{teachingId} {
      // Anyone can see public teachings. Members can see private ones.
      allow read: if resource.data.isPublic == true || (isUserAuthenticated() && resource.data.members.hasAny([request.auth.uid]));
      allow list: if isUserAuthenticated();

      // User must be authenticated and set themselves as the creator.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;

      // Only the creator can update the teaching info.
      allow update: if isUserAuthenticated() && isCreator(/databases/$(database)/documents/teachings/$(teachingId), request.auth.uid) ||
                      // Allow a user to add THEMSELVES to pendingRequests
                      (isUserAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) && request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]));

      // Only the creator can delete their teaching.
      allow delete: if isUserAuthenticated() && isCreator(/databases/$(database)/documents/teachings/$(teachingId), request.auth.uid);
    }

    // --- DOCUMENTS ---
    match /documents/{documentId} {
        // Allow read if the document is public, or if the user is the one who uploaded it.
        allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
        // Allow list only for a user's own documents or public ones. This is complex for rules, so we enforce in queries.
        // A user can create a document if they set themselves as the uploader.
        allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        // Only the uploader can update a document's metadata (not implemented, but good practice).
        allow update: if isUserAuthenticated() && isUploader(/databases/$(database)/documents/documents/$(documentId), request.auth.uid);
        // Only the uploader can delete their own document.
        allow delete: if isUserAuthenticated() && isUploader(/databases/$(database)/documents/documents/$(documentId), request.auth.uid);
    }
    
    // --- RECORDINGS ---
     match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
        allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow update: if isUserAuthenticated() && isUploader(/databases/$(database)/documents/recordings/$(recordingId), request.auth.uid);
        allow delete: if isUserAuthenticated() && isUploader(/databases/$(database)/documents/recordings/$(recordingId), request.auth.uid);
    }
    
    // --- FCM TOKENS for Push Notifications ---
    match /fcmTokens/{userId} {
        // A user can only read, create, update, or delete their own FCM token document.
        allow read, write, delete: if isUserAuthenticated() && isOwner(userId);
    }
  }
}
