rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- User Profiles & Subcollections ---
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
      
      // Allow users to read their own enrolled classes and pending requests
      match /enrolled/{classroomId} {
        allow read: if isOwner(userId);
        allow write: if signedIn(); // Teacher can write here
      }
      match /pendingJoinRequests/{classroomId} {
         allow read, write, delete: if isOwner(userId);
      }
    }

    // --- Classrooms & Subcollections ---
    match /classrooms/{classroomId} {
      // Any authenticated user can query the classrooms collection.
      // Client-side queries are responsible for filtering (e.g., for public or owned classes).
      allow list, get: if signedIn();

      // Only the authenticated user who is the teacherId can create a classroom.
      allow create: if signedIn() && isOwner(request.resource.data.teacherId);
      
      // The host/creator can update/delete their own classroom.
      allow update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);

      // --- Join Requests Subcollection ---
      match /joinRequests/{requestId} {
        // Any authenticated user can create a join request.
        allow create: if signedIn();
        
        // The user who created the request can delete their own request (cancel).
        // The document ID `requestId` is the user's UID.
        allow delete: if signedIn() && isOwner(requestId);

        // The classroom host can read, update, and delete all requests.
        allow read, update: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      // --- Other Subcollections (Materials, Assignments, etc.) ---
      match /{subcollection}/{docId} {
        allow read: if signedIn(); // Allow all signed-in users to read subcollection items.
        // Write access is generally limited to the host/teachers.
        // A simple check: allow if the user is the original classroom creator.
        allow write: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /submissions/{submissionId} {
        allow read, write: if signedIn();
      }
    }

    // --- Meetings & Subcollections ---
    match /meetings/{meetingId} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if signedIn() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);

      match /joinRequests/{requestId} {
        allow create: if signedIn();
        allow read, update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }

      match /participants/{userId} {
        allow read: if signedIn();
        allow write: if signedIn() && (isOwner(userId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId));
        allow delete: if signedIn() && (isOwner(userId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId));
      }
    }
    
    // --- Public & Private Libraries ---
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (signedIn() && isOwner(resource.data.uploaderId));
      allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
      allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || (signedIn() && isOwner(resource.data.uploaderId));
       allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
       allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
  }
}
