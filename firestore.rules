
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to user profiles
    match /users/{userId} {
      allow read;
      allow write: if request.auth.uid == userId;
    }
    
    // Allow read/write access to fcmTokens for authenticated users
    match /fcmTokens/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Rules for meetings
    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting document
      allow create: if request.auth != null;
      // Anyone authenticated can read the meeting details (like creatorId)
      allow read: if request.auth != null;
      // Only the creator can update or delete the meeting document
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.creatorId;

      match /participants/{participantId} {
        // A user can only add/remove/update themselves from the participants list
        allow read, write, delete: if request.auth != null && request.auth.uid == participantId;
      }
    }
    
    // Rules for documents and recordings
    match /{collection}/{docId} where collection in ['documents', 'recordings'] {
      // Allow create for any authenticated user
      allow create: if request.auth != null;
      // Allow read if the document/recording is public OR if the user is the uploader
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      // Allow update/delete only if the user is the uploader
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    // Rules for Teachings
    match /teachings/{teachingId} {
      // Allow any authenticated user to create a teaching
      allow create: if request.auth != null;

      // Allow read if the teaching is public OR if the user is a member
      allow read: if resource.data.isPublic == true || (request.auth != null && request.auth.uid in resource.data.members);

      // Allow updates (like joining, leaving, managing) under specific conditions
      allow update: if request.auth != null && (
        // Case 1: The user is the creator. They can change anything.
        request.auth.uid == resource.data.creatorId ||
        // Case 2: A user is requesting to join (adding their UID to pendingRequests)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])) ||
        // Case 3: A user is leaving the class (removing their UID from members)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         request.resource.data.members == resource.data.members.removed(request.auth.uid))
      );

      // Only the creator can delete the teaching
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }
  }
}
