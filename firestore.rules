
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return request.auth.uid == resource.data.createdBy || request.auth.uid == resource.data.teacherId;
    }

    function isEnrolled(classroomId) {
      return exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid));
    }
    
    function isCreator(classroomId) {
        return request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
    }
    
    function isTeacher(classroomId) {
        return get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role in ['teacher', 'creator'];
    }

    // User profiles can be read by anyone, but only edited by the owner.
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
      
      // Subcollections for user-specific data
      match /{subcollection}/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }
    
    // Documents and Recordings can be read if public, or by the owner if private.
    // Only owner can create/delete.
    match /(documents|recordings)/{docId} {
       allow read: if resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId;
       allow create: if isAuth() && request.auth.uid == request.resource.data.uploaderId;
       allow update, delete: if isAuth() && request.auth.uid == resource.data.uploaderId;
    }

    // Classrooms can be read by anyone if public, or by members if private.
    // Only the creator can update/delete.
    // Any authenticated user can create a classroom.
    match /classrooms/{classroomId} {
      allow read: if resource.data.isPublic == true || (isAuth() && isEnrolled(classroomId));
      allow create: if isAuth();
      allow update, delete: if isAuth() && isCreator(classroomId);

      // Participants list can be read by other members.
      // Only the creator can add/remove participants.
      match /participants/{participantId} {
        allow read: if isAuth() && isEnrolled(classroomId);
        allow write, delete: if isAuth() && isCreator(classroomId);
      }
      
      // Teachers subcollection can be read by members, written by creator
      match /teachers/{teacherId} {
        allow read: if isAuth() && isEnrolled(classroomId);
        allow write, delete: if isAuth() && isCreator(classroomId);
      }

      // Join requests can be created by anyone, but only read/deleted by the classroom creator.
      match /joinRequests/{requestId} {
        allow read, delete: if isAuth() && isCreator(classroomId);
        allow create: if isAuth() && request.auth.uid == requestId;
      }

      // Announcements, materials, assignments, and exams can be read by any enrolled member.
      // They can only be created/deleted by a teacher or the creator.
      match /(announcements|materials|assignments|exams)/{itemId} {
        allow read: if isAuth() && isEnrolled(classroomId);
        allow create: if isAuth() && isTeacher(classroomId);
        allow update, delete: if isAuth() && (isCreator(classroomId) || request.auth.uid == resource.data.uploaderId || request.auth.uid == resource.data.authorId);
        
        // Submissions can be created by any enrolled student, but only read by teachers/creator.
        match /submissions/{submissionId} {
            allow read: if isAuth() && isTeacher(classroomId);
            allow create: if isAuth() && request.auth.uid == submissionId && isEnrolled(classroomId);
            allow update: if isAuth() && isTeacher(classroomId);
        }
      }
    }
  }
}
