
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isMeetingCreator(meetingId) {
      return isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
    }
    
    function isParticipant(meetingId) {
        return isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
    }

    // Meetings collection
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(request.resource.data.creatorId);
      allow update: if isMeetingCreator(meetingId);
      allow delete: if isMeetingCreator(meetingId);

      // Participants subcollection
      match /participants/{userId} {
        allow read: if isParticipant(meetingId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId) || isMeetingCreator(meetingId);
      }
    }

    // Classrooms collection
    match /classrooms/{classId} {
      allow read: if true; // Publicly readable for discovery
      allow create: if isAuthenticated() && isOwner(request.resource.data.teacherId);
      allow update: if isAuthenticated() && isOwner(resource.data.teacherId);
      allow delete: if isAuthenticated() && isOwner(resource.data.teacherId);

      // Subcollections for classrooms
      match /{subcollection}/{docId} {
        // Default deny, specific rules below
        allow read, write: if false;
      }
      
      match /joinRequests/{userId} {
        allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId));
        allow create: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && (isOwner(userId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId));
      }

      match /participants/{userId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId));
      }
      
      match /teachers/{teacherId} {
        allow read: if true;
        allow write: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId);
      }
      
      match /announcements/{announcementId} {
          allow read: if true; // All participants can read
          allow create: if isAuthenticated() && (exists(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid))); // Participants can create
          allow delete: if isAuthenticated() && (isOwner(resource.data.creatorId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId));
      }
      
      match /materials/{materialId} {
        allow read: if true;
        allow create: if isAuthenticated() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId)); // Only teacher
        allow delete: if isAuthenticated() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId)); // Only teacher
      }
      
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create, delete: if isAuthenticated() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId));
        match /submissions/{submissionId} {
           allow read: if isAuthenticated();
           allow create, update: if isAuthenticated() && (isOwner(submissionId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId));
        }
      }
      
       match /exams/{examId} {
        allow read: if true;
        allow create, delete: if isAuthenticated() && (isOwner(get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId));
      }

    }
    
    // User specific collections
    match /users/{userId} {
        allow read: if true;
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        
        match /enrolled/{classroomId} {
            allow read, write: if isOwner(userId);
        }
        
        match /pendingJoinRequests/{classroomId} {
             allow read, write, delete: if isOwner(userId);
        }
    }
    
    // Documents & Recordings
    match /{collection=documents,recordings}/{docId} {
      allow read: if resource.data.isPrivate == false || (isAuthenticated() && isOwner(resource.data.uploaderId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.uploaderId);
      allow delete: if isAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    match /fcmTokens/{userId} {
        allow read, write: if isOwner(userId);
    }

  }
}

    