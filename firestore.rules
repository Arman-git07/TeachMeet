
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.creatorId);
      // Allow host to update pendingRequests array
      allow update: if isOwner(request.resource.data.creatorId);
      allow delete: if isOwner(request.resource.data.creatorId);

      // Participants can be created by themselves, and deleted by themselves or the host.
      match /participants/{participantId} {
        allow read, list: if isSignedIn();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
    }
    
    // ===== TEACHINGS =====
    match /teachings/{teachingId} {
        // Anyone can read public teachings. Members/creator can read private ones.
        allow read: if resource.data.isPublic == true || (isSignedIn() && request.auth.uid in resource.data.allowedStudents);
        
        // Only authenticated users can create teachings, and they must be the creator.
        allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;

        // The creator can update their teaching.
        // A user can add themselves to `pendingRequests` if they are not already a member or pending.
        allow update: if isSignedIn() && (
            (resource.data.creatorId == request.auth.uid) ||
            (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]) &&
                !(request.auth.uid in resource.data.allowedStudents)
            )
        );
        
        // Only the creator can delete their teaching.
        allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }
    
    // ===== DOCUMENTS & RECORDINGS =====
    // These rules apply to both the `documents` and `recordings` collections.
    match /{collection}/{docId} {
      allow read: if resource.data.isPrivate == false || (isSignedIn() && request.auth.uid == resource.data.uploaderId);
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uploaderId;
      allow update: if isSignedIn() && request.auth.uid == resource.data.uploaderId;
    }
  }
}
