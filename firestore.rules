rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions to check user roles within a classroom
    function isEnrolled(classroomId, userId) {
      return exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(userId));
    }

    function isCreator(classroomId, userId) {
      return get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == userId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == userId;
    }
    
    function isTeacher(classroomId, userId) {
       // A teacher is the creator or listed in the teachers subcollection.
       return isCreator(classroomId, userId) || exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(userId));
    }

    // Classrooms Collection
    match /classrooms/{classroomId} {
      // Anyone authenticated can read public classroom details for discovery.
      // Enrolled users can read details of private classrooms.
      allow read: if request.auth != null && (resource.data.isPublic == true || isEnrolled(classroomId, request.auth.uid));

      // Any authenticated user can create a new classroom.
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      
      // Only the creator can update the main classroom document.
      allow update: if request.auth != null && isCreator(classroomId, request.auth.uid);
      
      // Only the creator can delete their classroom.
      allow delete: if request.auth != null && isCreator(classroomId, request.auth.uid);

      // --- Classroom Sub-collections ---

      // Announcements, Materials, Assignments, Exams
      match /{collectionName}/{itemId} 
      where collectionName in ['announcements', 'materials', 'assignments', 'exams'] {
        // Enrolled users can read content.
        allow read: if request.auth != null && isEnrolled(classroomId, request.auth.uid);
        // Teachers and the creator can create/delete content.
        allow write: if request.auth != null && isTeacher(classroomId, request.auth.uid);
      }
      
      // Submissions for assignments
      match /assignments/{assignmentId}/submissions/{studentId} {
        // Teachers/creator can read all submissions.
        // The student who made the submission can read their own.
        allow read: if request.auth != null && (isTeacher(classroomId, request.auth.uid) || request.auth.uid == studentId);
        
        // A student can create/update their own submission.
        // A teacher can update a submission (e.g., to add a grade).
        allow write: if request.auth != null && (isTeacher(classroomId, request.auth.uid) || request.auth.uid == studentId);
      }

      // Join Requests
      match /joinRequests/{userId} {
        // Only the classroom creator/teacher can read join requests.
        allow read, delete: if request.auth != null && isTeacher(classroomId, request.auth.uid);
        // Any authenticated user can create a request to join, for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;
      }
      
      // Participants & Teachers sub-collections for role management
      match /participants/{userId} {
        allow read: if request.auth != null && isEnrolled(classroomId, request.auth.uid);
        allow write: if request.auth != null && isTeacher(classroomId, request.auth.uid); // Only teachers can add/remove participants
      }
      
      match /teachers/{userId} {
         allow read: if request.auth != null && isEnrolled(classroomId, request.auth.uid);
         allow write: if request.auth != null && isCreator(classroomId, request.auth.uid); // Only original creator manages teachers
      }
    }

    // Meetings Collection
    match /meetings/{meetingId}/participants/{participantId} {
        // Any authenticated user can create their own participant document to join a meeting.
        allow create: if request.auth != null && request.auth.uid == participantId;
        // Participants can read other participants' info and update their own.
        allow read, update: if request.auth != null && (request.auth.uid == participantId || exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid)));
        // Participants can delete their own document when they leave.
        allow delete: if request.auth != null && request.auth.uid == participantId;
    }

    // Documents & Recordings Collections
    match /{collection=**}/{documentId} 
    where collection in ['documents', 'recordings'] {
        // Allow read if the document is public, or if the user is the owner.
        allow read: if request.auth != null && (resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId);
        // Allow create, update, delete only for the owner.
        allow write: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }

    // Users Collection (for storing user-specific, non-auth data)
    match /users/{userId} {
      // A user can read and write to their own document.
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Sub-collections for enrolled classes and pending requests
      match /{subcollection}/{docId} {
         allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // FCM Tokens for notifications
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
