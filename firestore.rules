rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    // ===== CORE COLLECTIONS =====

    // Teachings Collection: Global list of all classes, public or private.
    match /teachings/{teachingId} {
      // Allow read if the teaching is public, or if the user is the creator, or if the user is in the members list.
      allow read: if resource.data.isPublic == true || (isUserAuthenticated() && (request.auth.uid == resource.data.creatorId || request.auth.uid in resource.data.members));
      // Allow list (for Discover tab) only for authenticated users.
      allow list: if isUserAuthenticated();
      // Allow create if the user is authenticated and is the creator.
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.creatorId;
      // Allow update if the user is the creator. This covers adding members or changing details.
      allow update: if isUserAuthenticated() && request.auth.uid == resource.data.creatorId;
      // Allow delete only if the user is the creator.
      allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.creatorId;
    }
    
    // Meetings Collection
    match /meetings/{meetingId} {
      // Any authenticated user can read meeting details to check existence.
      allow read: if isUserAuthenticated();
      // Allow create if the user is authenticated and is the creator.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      // Allow update for actions like adding a user to pendingRequests. Anyone can do this.
      // Host will update to add members.
      allow update: if isUserAuthenticated();
      // Allow delete only if the user is the creator.
      allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.creatorId;

      // Meeting Participants Subcollection
      match /participants/{participantId} {
        // Participants can see each other.
        allow list, read: if isUserAuthenticated();
        // A user can only create/update their own participant document.
        allow create, update: if isOwner(participantId);
        // A user can delete themselves, or the host can remove them.
        allow delete: if isOwner(participantId) || (isUserAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
    }

    // Documents and Recordings (Simplified for clarity)
    match /documents/{docId} {
        allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && request.auth.uid == resource.data.uploaderId);
        allow list: if isUserAuthenticated();
        allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recId} {
        allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && request.auth.uid == resource.data.uploaderId);
        allow list: if isUserAuthenticated();
        allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if isUserAuthenticated() && request.auth.uid == resource.data.uploaderId;
    }
    
    // FCM Tokens: Users can only manage their own token.
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
