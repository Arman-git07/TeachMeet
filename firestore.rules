rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /meetings/{meetingId} {
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;

      // Only added participants can read the meeting
      allow read: if isAuthenticated()
        && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));

      match /participants/{userId} {
        // Host or user themselves can create the participant document
        allow create: if isUser(userId)
          || (isAuthenticated() && resource.data.creatorId == request.auth.uid);

        allow read: if isUser(userId);

        // Any approved participant can list participants
        allow list: if exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));

        allow update, delete: if isUser(userId);
      }

      match /joinRequests/{userId} {
        allow create: if isUser(userId);
        allow read, delete: if isAuthenticated()
          && resource.data.creatorId == request.auth.uid;
      }
    }
    
    // Default-deny all other paths for security
    match /{path=**} {
      allow read, write: if false;
    }
  }
}