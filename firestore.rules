rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }

    // Helper for teachings, which are called 'classrooms' in these rules.
    function isClassTeacher(classId, userId) {
      // Assuming the document in 'teachings' collection has a 'creatorId' field
      return get(/databases/$(database)/documents/teachings/$(classId)).data.creatorId == userId;
    }

    // Helper for checking membership in a teaching/classroom
    function isClassMember(classId, userId) {
      // Check if user is in the 'members' array of the teaching document
      return userId in get(/databases/$(database)/documents/teachings/$(classId)).data.members;
    }
    
    // Helper for meetings
    function isMeetingCreator(meetingId, userId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == userId;
    }

    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      
      // Allow updates only by the creator, OR by any user if they are ONLY adding their own UID to pendingRequests
      allow update: if (isMeetingCreator(meetingId, request.auth.uid)) ||
                      (isUserAuthenticated() && request.resource.data.diff(request.resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                       request.resource.data.pendingRequests == request.resource.data.pendingRequests.push(request.auth.uid));
                       
      allow delete: if isMeetingCreator(meetingId, request.auth.uid);

      match /participants/{participantId} {
        allow read, write, delete: if isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid);
        allow list: if isUserAuthenticated();
      }
    }

    // ===== TEACHINGS (CLASSROOMS) =====
    match /teachings/{classId} {
      // Public teachings are readable by anyone authenticated. Private ones only by members.
      allow read, list: if isUserAuthenticated() && (resource.data.isPublic == true || isClassMember(classId, request.auth.uid));

      // Anyone can create a teaching, but they must be the creator.
      allow create: if isUserAuthenticated() && isOwner(request.resource.data.creatorId);
      
      // The creator can update the main details of the teaching.
      // Other users can only update it to add themselves to pendingRequests.
      allow update: if isUserAuthenticated() && (
        (isClassTeacher(classId, request.auth.uid)) ||
        (request.resource.data.diff(request.resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == request.resource.data.pendingRequests.push(request.auth.uid))
      );
        
      allow delete: if isUserAuthenticated() && isClassTeacher(classId, request.auth.uid);
    }
    
    // ===== FCM TOKENS / NOTIFICATIONS =====
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ===== DOCUMENTS =====
    match /documents/{documentId} {
        allow read: if isUserAuthenticated() && (get(path).data.isPrivate == false || isOwner(get(path).data.uploaderId));
        allow create: if isOwner(request.resource.data.uploaderId);
        allow delete: if isOwner(get(path).data.uploaderId);
    }

    // ===== RECORDINGS =====
    match /recordings/{recordingId} {
        allow read: if isUserAuthenticated() && (get(path).data.isPrivate == false || isOwner(get(path).data.uploaderId));
        allow create: if isOwner(request.resource.data.uploaderId);
        allow delete: if isOwner(get(path).data.uploaderId);
    }
  }
}
