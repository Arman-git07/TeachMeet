/**
 * @description This ruleset enforces a strict authorization model for meetings and classrooms,
 *   using the 'participants' sub-collection as the definitive source of truth for membership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function canManageClassroom(classId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId == request.auth.uid || 
        exists(/databases/$(database)/documents/classrooms/$(classId)/teachers/$(request.auth.uid))
      );
    }

    /**
     * Classrooms Collection
     */
    match /classrooms/{classId} {
      function isParticipant() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/classrooms/$(classId)/participants/$(request.auth.uid));
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if canManageClassroom(classId);

      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipant()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.timestamp != null;
        allow update, delete: if false;
      }

      match /participants/{userId} {
        allow read: if isParticipant();
        allow get, list: if isParticipant() || canManageClassroom(classId);
        allow create, update, delete: if canManageClassroom(classId);
      }

      match /joinRequests/{userId} {
        allow get, list: if isSignedIn() && (userId == request.auth.uid || canManageClassroom(classId));
        allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
        allow update, delete: if isSignedIn() && (userId == request.auth.uid || canManageClassroom(classId));
      }
      
      match /announcements/{id} {
        allow get, list: if isParticipant() || canManageClassroom(classId);
        allow create, update, delete: if canManageClassroom(classId) || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      }

      match /materials/{id} {
        allow get, list: if isParticipant() || canManageClassroom(classId);
        allow create, update, delete: if canManageClassroom(classId) || (isSignedIn() && request.resource.data.uploaderId == request.auth.uid);
      }

      match /assignments/{id} {
        allow get, list: if isParticipant() || canManageClassroom(classId);
        allow create, update, delete: if canManageClassroom(classId) || (isSignedIn() && request.resource.data.creatorId == request.auth.uid);
        
        match /submissions/{studentId} {
          allow get, list: if isSignedIn() && (studentId == request.auth.uid || canManageClassroom(classId));
          allow create: if isSignedIn() && studentId == request.auth.uid;
          allow update, delete: if canManageClassroom(classId);
        }
      }

      match /exams/{id} {
        allow get, list: if isParticipant() || canManageClassroom(classId);
        allow create, update, delete: if canManageClassroom(classId) || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
        
        match /submissions/{studentId} {
          allow get, list: if isSignedIn() && (studentId == request.auth.uid || canManageClassroom(classId));
          allow create: if isSignedIn() && studentId == request.auth.uid;
          allow update, delete: if canManageClassroom(classId);
        }
      }

      match /teachers/{teacherId} {
        allow get, list: if true;
        allow create, update, delete: if canManageClassroom(classId);
      }
    }

    /**
     * Users Collection
     */
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
      match /pendingJoinRequests/{classId} { allow read, write, delete: if isSignedIn() && request.auth.uid == userId; }
      match /enrolled/{classId} { allow read: if isSignedIn() && request.auth.uid == userId; allow write: if canManageClassroom(classId); }
    }

    /**
     * Documents Collection (User-specific)
     */
    match /documents/{id} {
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow read: if resource.data.isPrivate == false || (isSignedIn() && resource.data.uploaderId == request.auth.uid);
      allow update, delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }

    /**
     * Recordings Collection (User-specific)
     */
    match /recordings/{id} {
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow read: if resource.data.isPrivate == false || (isSignedIn() && resource.data.uploaderId == request.auth.uid);
      allow update, delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }

    /**
     * Meetings Collection
     */
    match /meetings/{id} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      
      match /joinRequests/{rid} { 
        allow get, list: if isSignedIn() && (rid == request.auth.uid || get(/databases/$(database)/documents/meetings/$(id)).data.hostId == request.auth.uid); 
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid; 
        allow update, delete: if isSignedIn() && (rid == request.auth.uid || get(/databases/$(database)/documents/meetings/$(id)).data.hostId == request.auth.uid); 
      }
      
      match /participants/{uid} { 
        allow get, list: if true; 
        allow create, update: if isSignedIn() && (uid == request.auth.uid || get(/databases/$(database)/documents/meetings/$(id)).data.hostId == request.auth.uid); 
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/meetings/$(id)).data.hostId == request.auth.uid; 
      }
    }
    
    /**
     * FCM Tokens Collection
     */
    match /fcmTokens/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
