rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rules for classrooms collection
    match /classrooms/{classroomId} {
      // Allow anyone to read a classroom document if it's public.
      // Allow the teacher to read their own classroom document, public or not.
      allow get: if resource.data.isPublic == true 
                  || (request.auth != null && request.auth.uid == resource.data.teacherId);

      // Allow anyone to LIST public classrooms. This is crucial for the Discover tab.
      allow list: if resource.data.isPublic == true;

      // Allow authenticated users to create a classroom if they are the teacher.
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      
      // Allow the teacher of a classroom to update or delete it.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Allow authenticated users to create a join request.
      match /joinRequests/{userId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        // Allow the teacher of the classroom to read/delete requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }

    // Rules for user-specific data
    match /users/{userId} {
      // Allow users to read/write their own data.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Rules for enrolled subcollection
      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rules for documents and recordings
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }

    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }

    // Rules for meetings
    match /meetings/{meetingId} {
        allow read, create: if request.auth != null;
        allow update, delete: if request.auth.uid == resource.data.creatorId;

        match /participants/{participantId} {
            allow read: if request.auth != null;
            allow create: if request.auth != null && request.auth.uid == participantId;
            allow update: if request.auth != null && request.auth.uid == participantId;
            allow delete: if request.auth != null && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
        }

        match /joinRequests/{userId} {
            allow read: if request.auth.uid == userId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
            allow create: if request.auth.uid == userId;
            allow delete: if request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
        }
    }
  }
}
