/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure access control for meetings and related data.
 * It enforces ownership for meeting creation/modification and manages join requests
 * with participant-level security. Schema validation is relaxed for prototyping.
 *
 * Data Structure:
 * - /meetings/{meetingId}: Stores meeting metadata.
 * - /meetings/{meetingId}/joinRequests/{requestId}: Stores requests to join a meeting.
 * - /meetings/{meetingId}/participants/{userId}: Stores participant profiles for a meeting.
 *
 * Key Security Decisions:
 * - Meetings can be created by any authenticated user, with the hostId stored in the document.
 * - Join requests can be created by any authenticated user, acting on their own behalf.
 * - Only the meeting host can manage join requests (approve/deny).
 * - Listing of meetings is allowed for any signed-in user.
 *
 * Denormalization for Authorization:
 * - Meeting documents store the hostId directly, avoiding the need for separate lookups
 *   to determine the meeting host. This is essential for performant security rules.
 *
 * Structural Segregation:
 * - Separate collections are used for meetings, join requests, and participants, allowing
 *   for granular security rules and efficient queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read access to the meetings collection, and restricts write access to authenticated users.
     * @path /meetings/{meetingId}
     * @allow (get, list): Any signed-in user can read the document.
     * @allow (create): Any signed-in user can create a meeting, provided they set the hostId to their own UID.
     * @allow (update, delete): Only the meeting host can update or delete the meeting.
     * @deny: Any unauthenticated user cannot create, update, or delete a meeting.
     * @principle: Enforces meeting ownership for writes and allows open reads.
     */
    match /meetings/{meetingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.hostId);
    }

    /**
     * @description Allows users to create join requests, and allows meeting hosts to manage those requests.
     * @path /meetings/{meetingId}/joinRequests/{requestId}
     * @allow (create): Any signed-in user can create a join request with their own UID.
     * @allow (update, delete): Only the meeting host can update or delete join requests.
     * @deny: Any unauthenticated user cannot create, update, or delete join requests.
     * @principle: Enforces ownership and role-based access for join request management.
     */
    match /meetings/{meetingId}/joinRequests/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == requestId;
      allow update, delete: if isMeetingHost(meetingId);
    }

    /**
     * @description Manages meeting participants. Only the host can add/remove.
     * @path /meetings/{meetingId}/participants/{userId}
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isMeetingHost(meetingId);
    }
    /**
     * @description Allows read access to the classrooms collection, and restricts write access to authenticated users.
     * @path /classrooms/{classroomId}/joinRequests/{userId}
     */
       match /classrooms/{classroomId}/joinRequests/{userId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update, delete: if false;
      }
    /**
     * @description Allows read access to the classrooms collection, and restricts write access to authenticated users.
     * @path /classrooms/{classroomId}/participants/{userId}
     */
       match /classrooms/{classroomId}/participants/{userId} {
        allow get, list: if isSignedIn();
        allow create: if false;
        allow update, delete: if false;
      }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
    
    function isMeetingHost(meetingId) {
        return get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }
  }
}