
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classroom rules
    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;

      // Classroom subcollections
      match /joinRequests/{requestId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
        allow create: if request.auth != null && request.auth.uid == requestId;
        allow delete: if request.auth != null && (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid || request.auth.uid == requestId);
      }
    }

    // Meeting Rules - This is the critical fix
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null && resource.data.creatorId == request.auth.uid;

      // Join requests subcollection
      match /joinRequests/{userId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
      
      // Participants subcollection
      match /participants/{userId} {
        allow read: if true;
        // Allow a user to create/update their own document
        allow create, update: if request.auth != null && request.auth.uid == userId;
        // Allow the meeting creator (host) to create/delete any participant
        allow create, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }

    // Public documents and recordings
    match /{collection}/{docId} {
      allow read: if resource.data.isPrivate == false;
      allow create, update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
  }
}
