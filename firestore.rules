rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only read/write their own user document.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classrooms
    match /classrooms/{classroomId} {
      // Anyone authenticated can read public classrooms.
      allow read: if request.auth != null && resource.data.isPublic == true;
      
      // The teacher can read their own private classroom.
      allow read: if request.auth != null && request.auth.uid == resource.data.teacherId;
      
      // Only authenticated users can create classrooms.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.teacherId;
      
      // Only the teacher can update or delete their classroom.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Classroom Subcollections (Join Requests, Materials, etc.)
      match /{subcollection}/{docId} {
        // Teacher has full access to all subcollections of their classroom.
        allow read, write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
      }
    }
    
    // Join requests can be read by the user who made them.
    match /classrooms/{classroomId}/joinRequests/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
    
    // Meetings
    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting document (when they first land on the wait page as host).
      allow create: if request.auth != null;
      // Allow read/write for all authenticated users to check creatorId, etc.
      // In a production app, this would be more restrictive.
      allow read, write: if request.auth != null;

      // Meeting Participants subcollection
      match /participants/{userId} {
        // Anyone authenticated can join (create their participant doc).
        // Host can also create it when approving a request.
        allow create: if request.auth != null;
        
        // Users can update or delete their own participant document (e.g., on leave).
        // The host can also remove participants.
        allow update, delete: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId
        );
        
        // Authenticated users in the meeting can read participant lists.
        // **FIX**: Allows a user to read their own participant doc after creation.
        allow read: if request.auth != null;
      }

      // Join Requests subcollection for meetings
      match /joinRequests/{userId} {
        // Any authenticated user can create a join request for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // Only the meeting host can read or delete requests.
        allow read, delete: if request.auth != null && 
                               request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
      }
    }
    
    // Documents & Recordings: Users can read public files or their own private files.
    match /documents/{documentId} {
      allow read: if request.auth != null && (resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
       allow read: if request.auth != null && (resource.data.isPrivate == false || request.auth.uid == resource.data.uploaderId);
       allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
       allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
     match /fcmTokens/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
