rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all reads/writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
       match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rules for classrooms
    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.teacherId;
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      
      match /joinRequests/{userId} {
        allow read: if request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId || request.auth.uid == userId;
        allow create, delete: if request.auth.uid == userId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
      }
    }

    // Rules for meetings
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.creatorId;

      // Participants subcollection
      match /participants/{userId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
        allow delete: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
      }
      
      // Join Requests subcollection
      match /joinRequests/{userId} {
        allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
      }
    }
    
    // Rules for documents
    match /documents/{documentId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
       allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // Rules for recordings
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
       allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // Rules for FCM tokens
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
