
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read access to public documents and recordings for any user.
    // Allow users to manage their own documents and recordings.
    match /{collection}/{docId} {
      allow read: if collection == 'documents' && resource.data.isPrivate == false;
      allow read: if collection == 'recordings' && resource.data.isPrivate == false;
      allow read, write, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
    }

    // Classroom specific rules
    match /classrooms/{classroomId} {
        // Public classrooms can be read by anyone
        allow read: if resource.data.isPublic == true;
        // Authenticated users can read non-public classrooms they are part of
        allow read: if request.auth != null && (
          resource.data.teacherId == request.auth.uid ||
          request.auth.uid in resource.data.students ||
          exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid))
        );
        
        // Only the teacher who created the classroom can update or delete it
        allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
        
        // Any authenticated user can create a classroom
        allow create: if request.auth != null;
    }

    // Rules for subcollections within classrooms
    match /classrooms/{classroomId}/{subcollection}/{docId} {
        // Teacher of the classroom has full access to all subcollections
        allow read, write, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;

        // Allow students to create submissions and join requests
        allow create: if request.auth != null && (subcollection == 'submissions' || subcollection == 'joinRequests');
        
        // Allow enrolled students to read announcements, materials, assignments, and exams
        allow read: if request.auth != null && 
                      (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students.hasAny([request.auth.uid]) ||
                       exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)));
    }

    // Rules for Meeting documents
    match /meetings/{meetingId} {
      allow read: if request.auth != null; // Any authenticated user can read meeting info
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid; // Only the host can create
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid; // Only the host can update/delete
    }

    // Rules for meeting subcollections
    match /meetings/{meetingId}/{subcollection}/{docId} {
        // The meeting host has full control over all subcollections
        allow read, write, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;

        // Any authenticated user can create a join request for themselves
        allow create: if request.auth != null && subcollection == 'joinRequests' && docId == request.auth.uid;
        
        // Participants can read their own participant doc
        allow read: if request.auth != null && subcollection == 'participants' && docId == request.auth.uid;
    }
  }
}
