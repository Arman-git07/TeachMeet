rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings Collection Rules
    match /meetings/{meetingId} {
      // Host and authenticated users can read meetings
      allow read: if request.auth != null;

      // Any authenticated user can create a meeting
      allow create: if request.auth != null;

      // Update only if user is host
      allow update: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Only host can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Participants Subcollection Rules
      match /participants/{participantId} {
        // A user can manage their own participant document
        allow create, update, read, delete: if request.auth != null
                                          && request.auth.uid == participantId;
      }

      // Join Requests Subcollection
      match /joinRequests/{requestId} {
        // Create: participant can only create their own request
        allow create: if request.auth != null && request.resource.data.name != null;

        // Participant can read their own request
        allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.requestingUserId;
        
        // Host can read/manage all join requests
        allow read, update, delete: if request.auth != null 
                                  && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
    }

    // Classroom Collection Rules
    match /classrooms/{classroomId} {
      allow read: if resource.data.isPublic == true || (request.auth != null && (request.auth.uid == resource.data.teacherId || resource.data.students[request.auth.uid] == true));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Subcollections within classrooms
      match /{allPaths=**} {
        // Allow reads/writes if the user is the teacher or an enrolled student
        allow read, write: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students[request.auth.uid] == true);
      }
    }
    
    // User-specific data
    match /users/{userId}/{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Documents and Recordings
    match /documents/{docId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
     match /recordings/{recId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
