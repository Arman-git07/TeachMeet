rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /enrolled/{classroomId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
      match /pendingJoinRequests/{classroomId} {
         allow read: if request.auth != null && request.auth.uid == userId;
         allow write, delete: if request.auth != null && request.auth.uid == userId;
      }
       match /fcmTokens/{tokenDocId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /classrooms/{classroomId} {
      allow read;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.createdBy;

      match /joinRequests/{requestId} {
        allow read, create: if request.auth != null;
        // Allow user to cancel their own request, or class creator to deny.
        allow delete: if request.auth != null && (request.auth.uid == requestId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid);
      }
      
      match /participants/{participantId} {
        allow read, create, delete: if request.auth != null && (request.auth.uid == participantId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid);
      }
      
      match /teachers/{teacherId} {
        allow read, create, delete: if request.auth != null && (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid);
      }

      match /announcements/{announcementId} {
        allow read;
        allow create: if request.auth != null && (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers);
        allow delete: if request.auth != null && (request.auth.uid == resource.data.creatorId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid);
      }

      match /materials/{materialId} {
        allow read;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.uploaderId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid);
      }
      
      match /assignments/{assignmentId} {
        allow read;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.creatorId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid);

        match /submissions/{submissionId} {
          allow read, write: if request.auth != null;
        }
      }
      
      match /exams/{examId} {
        allow read;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.authorId || get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid);
      }
    }

    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /meetings/{meetingId} {
        allow read;
        // Allow creation or update if the user is authenticated and is the creator.
        allow write: if request.auth != null && request.auth.uid == request.resource.data.creatorId;

        match /participants/{participantId} {
            allow read, write: if request.auth != null && (request.auth.uid == participantId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
        }

        match /joinRequests/{requestId} {
            allow read, create: if request.auth != null;
            // Allow deletion by the user who made the request, or the host.
            allow delete: if request.auth != null && (request.auth.uid == requestId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
        }
    }
  }
}
