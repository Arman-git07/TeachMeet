
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if request.auth != null;

      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }
  }
}
