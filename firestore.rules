rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId}/{subcollection}/{docId} {
      allow read, write: if isUser(userId);
    }
    
    match /classrooms/{classroomId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && request.resource.data.teacherId == request.auth.uid;
    }

    match /classrooms/{classroomId}/{subcollection}/{docId} {
      allow read: if isAuthenticated();
      // Only the main classroom teacher can write to subcollections
      allow write: if isAuthenticated() && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid;
    }
    
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (isAuthenticated() && resource.data.uploaderId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (isAuthenticated() && resource.data.uploaderId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }

    match /fcmTokens/{userId} {
        allow write: if isUser(userId);
    }
    
    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting document (the host does this)
      allow create: if isAuthenticated();

      // Only host can update or delete the main meeting document
      allow update, delete: if isAuthenticated()
        && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;

      // Authenticated users can read the meeting doc (to find the host)
      allow read: if isAuthenticated();

      match /participants/{userId} {
        // Host can add participants
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;

        // Any participant can list other participants
        allow list: if isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
        
        // A user can read their own participant entry
        allow read: if isUser(userId);
        
        // A participant can update/delete their own entry (e.g., mute, leave)
        allow update, delete: if isUser(userId);
      }

      match /joinRequests/{userId} {
        // A user can create their own join request.
        allow create: if isUser(userId);

        // Host can read/delete join requests.
        allow read, delete: if isAuthenticated()
          && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      }
    }
  }
}
