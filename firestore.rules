
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function signedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- User Profiles ---
    // Anyone can create their own user profile document.
    // Users can only read/write their own data.
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if signedIn();

      // Subcollections for user-specific data
      match /enrolled/{classroomId} {
        allow read, delete: if isOwner(userId);
        // Teachers/creators can add students to the enrolled list
        allow create, write: if signedIn() && (
          isOwner(userId) ||
          get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers
        );
      }

      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    // --- Meetings ---
    match /meetings/{meetingId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.hostId);
      allow update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      
      match /participants/{userId} {
        allow read: if signedIn();
        allow create, update: if signedIn(); // Allow users to update their own status (e.g. hand raise)
        allow delete: if signedIn() && (isOwner(userId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId));
      }

      match /joinRequests/{requestId} {
        allow create: if signedIn() && request.auth.uid == request.resource.data.studentId;
        allow read, update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }
    }

    // --- Documents & Recordings ---
    match /{collection}/{docId} {
      allow read: if resource.data.isPrivate == false || (signedIn() && isOwner(resource.data.uploaderId));
      allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
      allow update, delete: if signedIn() && isOwner(resource.data.uploaderId);
    }

    // --- Classrooms ---
    match /classrooms/{classroomId} {
      // Allow signed-in users to list classrooms (queries are filtered on client)
      allow list, get: if signedIn();
      
      // Allow users to create classrooms if they are the teacherId
      allow create: if signedIn() && isOwner(request.resource.data.teacherId);
      
      // Allow updates/deletes only by the original creator/teacher
      allow update, delete: if signedIn() && isOwner(resource.data.teacherId);
      
      match /announcements/{announcementId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.authorId);
        allow delete: if signedIn() && isOwner(resource.data.authorId);
      }
      
      match /materials/{materialId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
        allow delete: if signedIn() && isOwner(resource.data.uploaderId);
      }

      match /assignments/{assignmentId} {
        allow read: if signedIn();
        allow create, update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);

        match /submissions/{submissionId} {
            allow read, create, update, delete: if signedIn();
        }
      }

      match /exams/{examId} {
          allow read: if signedIn();
          allow create, update, delete: if signedIn() && isOwner(request.resource.data.authorId);
      }
      
      match /joinRequests/{requestId} {
          // Allow creation if user is signed in and the ID they are creating matches their own ID
          allow create: if signedIn() && request.auth.uid == requestId;
          allow read, delete: if signedIn() && (
            isOwner(requestId) || // User can read/delete their own request
            isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId) // Teacher can read/delete any
          );
      }

      match /participants/{participantId} {
        allow read: if signedIn();
        allow create, update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }

       match /teachers/{teacherId} {
        allow read: if signedIn();
        allow create, update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
    }
  }
}
