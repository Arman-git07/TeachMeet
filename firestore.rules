rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Meetings collection
    match /meetings/{meetingId} {
      // Allow a signed-in user to create a meeting document if they set themselves as the host.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.hostId;

      // Allow any signed-in user to read the main meeting document.
      allow read: if request.auth != null;

      // Only allow the host to update or delete the meeting document.
      // This checks the *existing* document's data.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Participants subcollection
      match /participants/{participantId} {
        // Allow a user to add themselves as a participant.
        // Also, allow the host of the meeting to add any participant. This is crucial for the host's initial batched write.
        allow create: if request.auth != null && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);

        // Allow any signed-in user to read the list of participants.
        allow read: if request.auth != null;

        // Allow a user to update or remove themselves.
        // Also, allow the host to update or remove any participant.
        allow update, delete: if request.auth != null && (request.auth.uid == participantId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }
      
      // Join requests subcollection
      match /joinRequests/{requestId} {
        // Any signed-in user can request to join.
        allow create: if request.auth != null;
        
        // Only the host can read or delete join requests.
        allow read, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId;
      }
    }

    // Default deny all other reads/writes to collections not explicitly defined.
    match /{path=**}/documents {
      allow read, write: if false;
    }
  }
}
