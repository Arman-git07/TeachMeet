rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /meetings/{meetingId} {
      allow read, write: if request.auth != null;

      match /joinRequests/{userId} {
        allow create, read: if request.auth != null;
        // Allow the user who made the request OR the meeting host to delete.
        // Assuming the meeting document has a 'creatorId' field for the host.
        allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }

      match /participants/{userId} {
        allow read, write: if request.auth != null;
      }
    }

    match /classrooms/{classId} {
      // Allow read if user is the teacher OR if the class is public.
      allow read: if request.auth != null && (request.auth.uid == resource.data.teacherId || resource.data.isPublic == true);
      
      // Allow create only if the user is the teacher listed in the new document.
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      
      // Allow update and delete only if the user is the teacher of that class.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      match /joinRequests/{userId} {
        allow create, read: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId);
      }
    }

    match /users/{userId}/{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /documents/{documentId} {
      // Allow read if the document is public or if the user is the owner.
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      // Allow create if the user is authenticated and is the declared uploader.
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      // Allow delete only if the user is the owner.
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recordingId} {
      // Allow read if the recording is public or if the user is the owner.
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      // Allow create if the user is authenticated and is the declared uploader.
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
      // Allow delete only if the user is the owner.
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /fcmTokens/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
