rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings can be created by any authenticated user.
    // They can be read by any authenticated user.
    // They can only be updated or deleted by the user who created them (the host).
    match /meetings/{meetingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.creatorId;

      // Participants can be created by any authenticated user (when they join).
      // They can only be updated/deleted by themselves or the meeting host.
      match /participants/{userId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth.uid == userId;
        allow delete: if request.auth.uid == userId || request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId;
      }
    }
    
    // Classrooms
    match /classrooms/{classroomId} {
      allow read: if resource.data.isPublic == true || (request.auth != null && (request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.students || request.auth.uid in resource.data.teachers));
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == resource.data.teacherId || request.auth.uid in resource.data.teachers);
      allow delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Subcollections within classrooms
      match /{subcollection}/{docId} {
        // Teacher/Creator can do anything.
        // Enrolled students can read.
        allow read: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId || request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students || request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers);
        allow write: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId || request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers);
      }
      
       match /assignments/{assignmentId}/submissions/{submissionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (request.auth.uid == submissionId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
    }

    // Users can only manage their own documents.
    match /users/{userId}/{document=**} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Documents can be read by anyone if public, or by the owner if private.
    // They can only be written/deleted by the owner.
    match /documents/{docId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow write, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // Recordings can be read by anyone if public, or by the owner if private.
    // They can only be written/deleted by the owner.
    match /recordings/{recId} {
        allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
        allow write, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // FCM Tokens for push notifications can only be managed by the user themselves.
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
