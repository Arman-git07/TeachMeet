rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /classrooms/{classId} {
      // Basic read access, you might want to restrict this
      allow read, write: if request.auth != null;

      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
      
      match /assignments/{assignmentId} {
        allow read, write: if request.auth != null;
        
        match /submissions/{submissionId} {
          allow read, write: if request.auth != null;
        }
      }
      
      match /materials/{materialId} {
        allow read, write: if request.auth != null;
      }
      
      match /exams/{examId} {
        allow read, write: if request.auth != null;
      }

      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }

      match /joinRequests/{requestId} {
        allow read, write: if request.auth != null;
      }

      match /teachers/{teacherId} {
        allow read, write: if request.auth != null;
      }
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /pendingJoinRequests/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

     match /meetings/{meetingId} {
      allow read, write: if request.auth != null;
      
      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }

      match /joinRequests/{requestId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    match /fcmTokens/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
