rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Meetings collection
    match /meetings/{meetingId} {
      // Host can create their own meeting
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
      
      // Host can read/update/delete their meeting
      allow read, update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;
      
      // Subcollections inside a meeting (joinRequests, participants)
      // Allow any authenticated user to create a join request
      match /joinRequests/{requestId} {
          allow create: if request.auth != null;
          // Only the host can read/delete join requests
          allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
      
      // Allow host to add participants, and participants to read the list
      match /participants/{participantId} {
          allow create, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
          allow read: if request.auth != null;
      }
    }

    // User-specific data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Publicly readable, user-owned documents/recordings
    match /documents/{docId} {
        allow read: if resource.data.isPrivate == false;
        allow create, update, delete: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        allow read: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
     match /recordings/{recId} {
        allow read: if resource.data.isPrivate == false;
        allow create, update, delete: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
        allow read: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
  }
}