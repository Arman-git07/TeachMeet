
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /classrooms/{classId} {
      allow read: if true;

      // Classroom creator can always manage their class
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      // Announcements subcollection
      match /announcements/{announcementId} {
        allow read: if true;

        // Create: any signed-in user can post (you can restrict later if needed)
        allow create: if request.auth != null;

        // Delete: allowed if user is either
        // 1. the one who uploaded/posted this material (uploaderId)
        // 2. the creator of the classroom (createdBy field in parent doc)
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      // Materials subcollection
      match /materials/{materialId} {
        allow read: if true;

        // Create: any signed-in user can post (you can restrict later if needed)
        allow create: if request.auth != null;

        // Delete: allowed if user is either
        // 1. the one who uploaded/posted this material (uploaderId)
        // 2. the creator of the classroom (createdBy field in parent doc)
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      // Assignments subcollection
      match /assignments/{assignmentId} {
        allow read: if true;

        // Create: any signed-in user can post (you can restrict later if needed)
        allow create: if request.auth != null;

        // Delete: allowed if user is either
        // 1. the one who uploaded/posted this material (uploaderId)
        // 2. the creator of the classroom (createdBy field in parent doc)
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

       // Exams subcollection
      match /exams/{examId} {
        allow read: if true;

        // Create: any signed-in user can post (you can restrict later if needed)
        allow create: if request.auth != null;

        // Delete: allowed if user is either
        // 1. the one who uploaded/posted this material (uploaderId)
        // 2. the creator of the classroom (createdBy field in parent doc)
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
    }
  }
}
