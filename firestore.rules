rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read their own profile and public profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to read their own enrolled and pending collections
      match /enrolled/{classroomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /pendingJoinRequests/{classroomId} {
         allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Classroom documents
    match /classrooms/{classroomId} {
      allow read: if true; // Let users discover public classrooms
      allow create: if request.auth != null; // Any signed-in user can create a class
      
      // Only the creator can update the main classroom document
      allow update: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Only the creator can delete their classroom
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Join Requests: any authenticated user can request to join
      match /joinRequests/{userId} {
          allow create, read: if request.auth != null;
          // Deletion is handled by classroom owner via deny/approve actions
          allow delete: if request.auth != null && (
            request.auth.uid == userId || // User can cancel their own request
            request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy // Owner can delete
          );
      }
      
      // Participants: Read for all, write only for creator
      match /participants/{userId} {
        allow read: if true;
        allow write, delete: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }

      // Teachers: Read for all, write only for creator
      match /teachers/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy;
      }

      // Announcements can be created by auth'd users, deleted by author or class creator
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.authorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
      }

      // Materials can be created by auth'd users, deleted by uploader or class creator
      match /materials/{materialId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
      }
      
      // Assignments can be created by auth'd users, deleted by creator or class creator
       match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
         // Submissions subcollection
        match /submissions/{submissionId} {
            allow read: if true; // Teachers and student who submitted can read
            allow create, update: if request.auth != null; // Students can submit, teachers can grade
        }
      }

      // Exams can be created by auth'd users, deleted by author or class creator
      match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.authorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy
        );
      }
    }

    // Meeting documents
    match /meetings/{meetingId} {
      allow read, write: if request.auth != null;
      
      match /participants/{participantId} {
        allow read, write, delete: if request.auth != null;
      }
      
      match /joinRequests/{userId} {
        allow read, write, delete: if request.auth != null;
      }
    }
    
     // Documents collection
    match /documents/{documentId} {
      // Public documents are readable by anyone
      // Private documents are readable only by the uploader
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }

    // Recordings collection
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
