/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model for meetings and join requests.
 * All data is nested under /meetings/{meetingId} or other top-level collections such as /classrooms/{classroomId}.
 *
 * Key Security Decisions:
 * - Users can only create join requests for meetings.
 * - The host of a meeting has full control over its subcollections (participants, join requests).
 * - Participants can only be added to a meeting by the host.
 * - Listing of join requests by non-hosts is disallowed.
 *
 * Denormalization for Authorization:
 * - JoinRequest documents include the `hostId` of the meeting, allowing the host to easily query and manage requests.
 *
 * Structural Segregation:
 * - There is no clear segregation of private vs public data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows the host to manage meetings.
     * @path /meetings/{meetingId}
     * @allow (get, list): Anyone can read meeting details.
     * @allow (create): Only the host can create a meeting.
     * @allow (update, delete): Only the host can modify or delete a meeting.
     * @deny create: A participant tries to create a meeting.
     * @deny update: A non-host tries to update a meeting.
     * @deny delete: A non-host tries to delete a meeting.
     * @principle Enforces meeting ownership.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update, delete: if isExistingOwner(resource.data.hostId);
    }

    /**
     * @description Allows users to create join requests for meetings and allows hosts to read and delete requests.
     * @path /joinRequests/{joinRequestId}
     * @allow (create): A user can create a join request for a meeting if request.auth.uid == request.resource.data.userId.
     * @allow (read, delete): The host of the meeting can read and delete join requests.
     * @deny create: A user attempts to create a join request with a mismatched userId.
     * @deny update: No updates allowed on join requests (only creation and deletion).
     * @principle Ensures only authenticated users can request to join meetings and only host can read the request.
     */
    match /joinRequests/{joinRequestId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read, delete: if true;
      allow update: if false;
    }

    /**
     * @description Allows the host to manage participants in a meeting.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (create): Only the host can add participants to a meeting.
     * @allow (get): Anyone can read user profile details if they know the meeting id.
     * @allow (update, delete): Only the host can modify or delete participants.
     * @deny create: A participant tries to add themselves without approval.
     * @deny update: A non-host tries to update a participant's profile.
     * @deny delete: A non-host tries to remove a participant.
     * @principle Enforces meeting ownership for participant management.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get: if true;
      allow create, update, delete: if isExistingOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      allow list: if true;
    }

    /**
     * @description Allows the host to manage participants in a classroom.
     * @path /classrooms/{classroomId}/participants/{userId}
     */
    match /classrooms/{classroomId}/participants/{userId} {
      allow get: if true;
      allow create, update, delete: if isExistingOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId);
      allow list: if true;
    }

     /**
      * @description Allows users to create join requests for classrooms and allows hosts to read and delete requests.
      * @path /classrooms/{classroomId}/joinRequests/{userId}
      */
    match /classrooms/{classroomId}/joinRequests/{userId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read, delete: if true;
      allow update: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}