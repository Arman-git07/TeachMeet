rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Meetings Collection ---
    match /meetings/{meetingId} {

      // Host can create meeting if hostId == their UID
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.hostId;

      // Host can update meeting
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.hostId;

      // Any signed-in user can read meeting
      allow read: if request.auth != null;

      // Only host can delete
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.hostId;

      // --- Participants Subcollection ---
      match /participants/{participantId} {
        // User can create their own participant entry
        allow create: if request.auth != null
                      && request.auth.uid == participantId;

        // Any signed-in user can read participants
        allow read: if request.auth != null;

        // User can update/delete only their own participant entry
        allow update, delete: if request.auth != null
                              && request.auth.uid == participantId;
      }
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
