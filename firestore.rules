rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to manage their own FCM tokens for notifications
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Teachings Collection
    match /teachings/{teachingId} {
      // Anyone authenticated can read public teachings or teachings they are a member of
      allow read: if request.auth != null && (resource.data.isPublic == true || request.auth.uid in resource.data.members);
      
      // Anyone authenticated can create a teaching
      allow create: if request.auth != null;
      
      // Only the creator can delete their teaching
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;

      // Creator can update all fields.
      // Authenticated users can add themselves to the pendingRequests list.
      allow update: if request.auth != null && 
                    (request.auth.uid == resource.data.creatorId || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                      request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])));
    }

    // Recordings & Documents Collections
    match /{collection}/{docId} {
      // Allow read access to any authenticated user for public documents/recordings
      allow read: if request.auth != null && resource.data.isPrivate == false;
      
      // Allow read/write access only to the user who owns the private document/recording
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uploaderId && resource.data.isPrivate == true;
      
      // Allow any authenticated user to create a new document/recording
      allow create: if request.auth != null;
    }

    // Meetings Collection
    match /meetings/{meetingId} {
      // Allow read for authenticated users to check creatorId
      allow read: if request.auth != null;
      
      // Allow create for any authenticated user
      allow create: if request.auth != null;

      // Allow creator to update the meeting (e.g. approve/deny requests)
      // Allow any user to add themselves to pendingRequests
      allow update: if request.auth != null && (
        (resource.data.creatorId == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );

      // Participants subcollection
      match /participants/{participantId} {
        // Anyone in the meeting can see other participants
        allow read: if request.auth != null;
        
        // Allow users to add or remove themselves from a meeting
        allow write: if request.auth != null && request.auth.uid == participantId;
      }
    }
  }
}
