/**
 * @description This ruleset enforces a user-ownership model for meetings and their subcollections.
 *   It allows unauthenticated read access for meetings, while restricting write access to the meeting creator.
 *   Join requests and participants are managed by the meeting host.
 * @dataStructure
 *   /meetings/{meetingId}: Stores meeting information, including creatorId for ownership.
 *   /meetings/{meetingId}/joinRequests/{userId}: Stores requests to join a meeting.
 *   /meetings/{meetingId}/participants/{userId}: Stores user profile data for meeting participants.
 * @keySecurityDecisions
 *   - Unauthenticated users can read meeting data.
 *   - Only the meeting creator (host) can modify or delete meetings.
 *   - Listing of meetings and participants requires authentication.
 * @denormalizationForAuthorization
 *   The `creatorId` field is present in the `/meetings/{meetingId}` document to enable efficient ownership checks without additional `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(meetingId) {
      return isSignedIn() && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
    }

    /**
     * @description Controls access to the /meetings collection.
     * @path /meetings/{meetingId}
     * @allow (read) Any user can read a meeting.
     * @allow (create) Authenticated user can create a meeting if they are the host.
     * @deny (create) Unauthenticated user cannot create a meeting.
     * @principle Allows public read access while enforcing owner-only writes.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isOwner(meetingId);
    
        /**
         * @description Controls access to the /meetings/{meetingId}/joinRequests collection.
         * @path /meetings/{meetingId}/joinRequests/{userId}
         * @allow (create) Authenticated user can create a join request for themself.
         * @allow (read, update, delete) Authenticated meeting host can manage join requests.
         * @deny (create) User cannot create a join request for another user.
         * @deny (update) User cannot update a join request they don't own or are not the meeting host.
         * @principle Enforces that only the requesting user can create a request for themself, and the host can manage requests.
         */
        match /meetings/{meetingId}/joinRequests/{userId} {
          allow create: if isSignedIn() && request.auth.uid == userId;
          allow get, list: if isSignedIn(); // Any authenticated user can read join requests.
          allow update, delete: if isOwner(meetingId) && resource != null;
        }
    
        /**
         * @description Controls access to the /meetings/{meetingId}/participants collection.
         * @path /meetings/{meetingId}/participants/{userId}
         * @allow (read) Authenticated users can read participant data.
         * @allow (write) The meeting host and the participant themself can modify their own participant data.
         * @deny (write) A user cannot modify another participant's data if not the host.
         * @principle Ensures meeting hosts can manage participants, and participants can control their own data.
         */
        match /meetings/{meetingId}/participants/{userId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isSignedIn() && (request.auth.uid == userId || isOwner(meetingId)) && resource != null;
        }
    }
  }
}