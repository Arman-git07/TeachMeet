rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(resourceId) {
      return request.auth.uid == resourceId;
    }

    // Teachings Collection
    match /teachings/{teachingId} {
      // Anyone authenticated can create a teaching
      allow create: if isAuthenticated();
      
      // Allow read if public or if the user is a member
      allow read: if resource.data.isPublic == true || request.auth.uid in resource.data.members;
      
      // Allow update/delete only if the user is the creator
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // Meetings Collection
    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting document (implicitly on first join)
      allow create: if isAuthenticated();

      // Anyone can read meeting details like topic and creator
      allow read: if true;

      // Allow authenticated users to add themselves to the pendingRequests list
      allow update: if isAuthenticated() && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
                      request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]);

      // Participants Subcollection
      match /participants/{participantId} {
        // A user can add themselves as a participant if they are the meeting creator,
        // OR if the meeting creator is approving their request (logic handled in security rules for simplicity,
        // though a Cloud Function is better for strict validation).
        // The host (creator) can add anyone.
        allow create: if isAuthenticated() && 
                      (isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId));
                      
        // Only the user themselves can update their own status (mute, camera, etc.)
        // The host can also update participants (e.g., mute all - not implemented yet but rule allows).
        allow update: if isAuthenticated() && 
                      (isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId));
                      
        // User can remove themselves, or the host can remove them.
        allow delete: if isAuthenticated() && 
                      (isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId));
                      
        allow read: if true;
      }
    }
    
    // Documents, Recordings, and FCM Tokens
    match /{collection}/{docId} {
      // Default deny for collections not explicitly defined
      allow read, write: if false;
    }
    
    match /documents/{documentId} {
      allow create: if isAuthenticated() && isOwner(request.resource.data.uploaderId);
      allow read: if resource.data.isPrivate == false || (isAuthenticated() && isOwner(resource.data.uploaderId));
      allow update, delete: if isAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
      allow create: if isAuthenticated() && isOwner(request.resource.data.uploaderId);
      allow read: if resource.data.isPrivate == false || (isAuthenticated() && isOwner(resource.data.uploaderId));
      allow update, delete: if isAuthenticated() && isOwner(resource.data.uploaderId);
    }

    match /fcmTokens/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
  }
}
