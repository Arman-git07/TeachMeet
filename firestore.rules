
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function getDoc(path) {
      return get(/databases/$(database)/documents/$(path));
    }
    
    // ===== USER DATA =====
    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow write: if isOwner(userId);
    }
    
    match /fcmTokens/{userId} {
        allow read, write: if isOwner(userId);
    }

    // ===== TEACHINGS (Based on new data model) =====
    match /teachings/{teachingId} {
        // This collection will now manage the core data, members, and requests.
        // It is not directly listable by clients anymore.
        allow read: if isUserAuthenticated();
        
        allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
        
        // Only the creator can change title, description, isPublic status.
        // Any authenticated user can request to join by updating pendingRequests.
        allow update: if isUserAuthenticated() && 
            (request.resource.data.creatorId == request.auth.uid || 
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) && 
             request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])));

        // Only the creator can delete a teaching.
        allow delete: if isUserAuthenticated() && resource.data.creatorId == request.auth.uid;
    }
    
    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      
      // Allow creator to update, or users to add themselves to pendingRequests.
      allow update: if isUserAuthenticated() &&
        (resource.data.creatorId == request.auth.uid ||
         (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests', 'members']) &&
          (request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]) ||
           request.resource.data.members == resource.data.members.concat([request.auth.uid]))
         )
        );

      allow delete: if isUserAuthenticated() && resource.data.creatorId == request.auth.uid;

      match /participants/{participantId} {
        allow read: if isUserAuthenticated();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || resource.data.creatorId == request.auth.uid;
      }
    }
    
    // ===== DOCUMENTS & RECORDINGS =====
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
        allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
        allow delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
        allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
        allow delete: if isUserAuthenticated() && isOwner(resource.data.uploaderId);
    }
  }
}
