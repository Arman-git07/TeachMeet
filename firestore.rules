rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read on classrooms for discovery
    match /classrooms/{classroomId} {
      allow read: if true;

      // Creator/Teacher management
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;

      // Sub-collection rules
      match /{allSubcollections}/{document=**} {
        // Allow authenticated users to perform actions. More specific rules can be added.
        allow read, write: if request.auth != null;
      }
    }
    
    // User profile data
    match /users/{userId} {
       allow read: if true;
       allow create, update: if request.auth != null && request.auth.uid == userId;

       // Sub-collections under users
       match /{allSubcollections}/{document=**} {
         allow read, write: if request.auth != null && request.auth.uid == userId;
       }
    }
    
    // Document and Recording rules
    match /documents/{documentId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && resource.data.uploaderId == request.auth.uid);
       allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
       allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
    
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && resource.data.uploaderId == request.auth.uid);
       allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
       allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Meeting collections
    match /meetings/{meetingId} {
      // Anyone can read meeting info
      allow read: if true;

      // Only host (creator) can create/update/delete
      allow create, update, delete: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;

      // Make sure hostId cannot be changed by anyone else
      allow update: if request.auth != null
        && resource.data.hostId == request.auth.uid
        && request.resource.data.hostId == resource.data.hostId;
        
        // Participants subcollection
        match /participants/{participantId} {
            // Participant can create/update/read/delete their own document
            allow read, write: if request.auth != null && request.auth.uid == participantId;
            // Host can manage all participants
            allow read, write, delete: if request.auth != null
                && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        }

        // Join requests subcollection
        match /joinRequests/{requestId} {
            // User can create their own join request
            allow create: if request.auth != null && requestId == request.auth.uid;
            
            // Host can manage join requests
            allow read, update, delete: if request.auth != null
                && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
        }
    }
  }
}
