rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /meetings/{meetingId} {
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow update: if isSignedIn() && resource.data.hostId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;
    }

    match /meetings/{meetingId}/joinRequests/{reqId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /meetings/{meetingId}/participants/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /classrooms/{classroomId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /classrooms/{classroomId}/joinRequests/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /classrooms/{classroomId}/participants/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

  }

  function isSignedIn() {
    return request.auth != null;
  }
}