rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /classrooms/{classId} {
      allow read: if true;

      // Classroom creator can always manage their class
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;

      // Announcements subcollection
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      // Materials subcollection
      match /materials/{materialId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      // Assignments subcollection
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      // Exams subcollection
      match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
    }

    match /documents/{documentId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
       allow read: if true;
       allow create, update, delete: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
    }
    
    match /meetings/{meetingId} {
      allow read, create, update: if request.auth != null;

      match /participants/{participantId} {
        allow read, create, update: if request.auth != null;
        // Allow host to remove participants
        allow delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId
        );
      }
      match /joinRequests/{requestId} {
        allow read, delete: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId
        );
        allow create: if request.auth != null;
      }
    }
    
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
