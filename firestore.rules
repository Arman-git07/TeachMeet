rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /classrooms/{classroomId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.teacherId;
      
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.creatorId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy;
      }
      
      match /materials/{materialId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.uploaderId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy;
      }
      
      match /assignments/{assignmentId} {
         allow read, write: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.creatorId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy;
        
        match /submissions/{submissionId} {
            allow read, write: if request.auth != null;
        }
      }
      
      match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.authorId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.creatorId;
      }
      
      match /joinRequests/{requestId} {
        allow read, write, delete: if request.auth != null;
      }
      
      match /participants/{participantId} {
          allow read, write, delete: if request.auth != null;
      }
      
      match /teachers/{teacherId} {
          allow read, write, delete: if request.auth != null;
      }
    }
    
    // Allow any authenticated user to create a meeting document and sub-documents.
    // Reading/deleting a meeting is restricted to its creator.
    match /meetings/{meetingId} {
      allow read, delete: if request.auth.uid == resource.data.creatorId;
      allow create: if request.auth != null;

      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }
      
      match /joinRequests/{requestId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /documents/{documentId} {
        allow read: if resource.data.isPrivate == false || (resource.data.isPrivate == true && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
        allow read: if resource.data.isPrivate == false || (resource.data.isPrivate == true && request.auth.uid == resource.data.uploaderId);
        allow create: if request.auth.uid == request.resource.data.uploaderId;
        allow delete: if request.auth.uid == resource.data.uploaderId;
    }
    
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
    