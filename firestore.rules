rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read and write access to the entire database for any authenticated user.
    // WARNING: This is permissive and suitable for development.
    // For production, you should implement more granular rules to protect user data.
    // For example, users should only be able to write to their own documents,
    // and teachers should only be able to modify the classes they own.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
