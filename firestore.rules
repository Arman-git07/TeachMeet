rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /classrooms/{classId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.createdBy;

      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      match /materials/{materialId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
        // CORRECTED: Check for uploaderId, which matches the field saved in the onExamSubmit function.
        // Also added check for classroom creator.
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
    }
  }
}
