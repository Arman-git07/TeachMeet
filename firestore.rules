rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to keep rules DRY
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isClassroomCreator(classroomId) {
      return isUser(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
    }
    
    function isClassroomTeacher(classroomId) {
        let classroomDoc = get(/databases/$(database)/documents/classrooms/$(classroomId)).data;
        let teacherInfo = classroomDoc.teachers[? request.auth.uid in 'uid' ];
        return isSignedIn() && (
            request.auth.uid == classroomDoc.teacherId ||
            exists(/databases/$(database)/documents/classrooms/$(classroomId)/teachers/$(request.auth.uid)) ||
            (teacherInfo.size() > 0)
        );
    }

    function isClassroomStudent(classroomId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.students;
    }

    //----------------------------------------------------------------------
    // Meetings Collection
    //----------------------------------------------------------------------
    match /meetings/{meetingId} {
      // Anyone authenticated can read meeting details.
      allow read: if isSignedIn();

      // Any authenticated user can create a new meeting document.
      allow create: if isSignedIn();

      // Only the user designated as the creator can update or delete the meeting.
      allow update, delete: if isUser(resource.data.creatorId);

      //--------------------------------
      // Participants Subcollection
      //--------------------------------
      match /participants/{participantId} {
        // Anyone in the meeting can see who else is there.
        allow read: if isSignedIn();

        // A user can only add or update their own participant document.
        // This allows users to join and update their status (e.g., hand raised).
        allow write: if isUser(participantId);
      }
    }
    
    //----------------------------------------------------------------------
    // Users Collection
    //----------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isUser(userId);

      match /enrolled/{classroomId} {
        allow read, write: if isUser(userId);
      }
      match /pendingJoinRequests/{classroomId} {
        allow read, write: if isUser(userId);
      }
    }
    
    //----------------------------------------------------------------------
    // Classrooms Collection
    //----------------------------------------------------------------------
    match /classrooms/{classroomId} {
      // Allow read access to public classrooms for any user,
      // and to private classrooms only for members.
      allow read: if resource.data.isPublic == true || isClassroomCreator(classroomId) || isClassroomTeacher(classroomId) || isClassroomStudent(classroomId);

      // Only authenticated users can create classrooms.
      allow create: if isSignedIn();
      
      // Only the creator can delete the classroom.
      allow delete: if isClassroomCreator(classroomId);
      
      // Teachers and creators can update classroom info.
      allow update: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
      
      // --- Subcollections ---
      
      match /joinRequests/{requestId} {
        // Any signed-in user can request to join.
        allow create: if isSignedIn();
        // Only classroom managers can read/delete requests.
        allow read, delete: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
      }

      match /participants/{participantId} {
        allow read: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId) || isClassroomStudent(classroomId);
        allow write: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
      }
      
      match /teachers/{teacherId} {
         allow read: if true;
         allow write: if isClassroomCreator(classroomId);
      }

      match /announcements/{announcementId} {
        allow read: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId) || isClassroomStudent(classroomId);
        allow create: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
        allow delete: if isUser(resource.data.creatorId) || isClassroomCreator(classroomId);
      }
      
      match /materials/{materialId} {
        allow read: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId) || isClassroomStudent(classroomId);
        allow create: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
        allow delete: if isUser(resource.data.uploaderId) || isClassroomCreator(classroomId);
      }

      match /assignments/{assignmentId} {
        allow read: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId) || isClassroomStudent(classroomId);
        allow create: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
        allow delete: if isUser(resource.data.creatorId) || isClassroomCreator(classroomId);

        match /submissions/{submissionId} {
           // Student can create/update their own submission. Teacher can update (grade).
           allow read: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId) || isUser(submissionId);
           allow write: if isUser(submissionId);
           allow update: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
        }
      }

      match /exams/{examId} {
        allow read: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId) || isClassroomStudent(classroomId);
        allow create: if isClassroomCreator(classroomId) || isClassroomTeacher(classroomId);
        allow delete: if isUser(resource.data.authorId) || isClassroomCreator(classroomId);
      }
    }

    //----------------------------------------------------------------------
    // Documents and Recordings Collections
    //----------------------------------------------------------------------
    match /{collection}/{docId} {
        // For 'documents' and 'recordings' collections
        allow read: if collection == 'documents' || collection == 'recordings';
        allow write: if (collection == 'documents' || collection == 'recordings') && isUser(request.resource.data.uploaderId);
        allow delete: if (collection == 'documents' || collection == 'recordings') && isUser(resource.data.uploaderId);
    }
  }
}
