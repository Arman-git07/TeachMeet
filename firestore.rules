
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isUserAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isMeetingCreator(meetingId, userId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == userId;
    }
    
    function isClassroomTeacher(classroomId, userId) {
      return get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow write: if isOwner(userId);
      
      match /enrolled/{classroomId} {
        allow read, write, delete: if isOwner(userId);
      }
    }
    
    // --- Classrooms Collection ---
    match /classrooms/{classroomId} {
      allow read: if isUserAuthenticated();
      allow create: if isUserAuthenticated() && isOwner(request.resource.data.teacherId);
      allow update: if isUserAuthenticated() && isClassroomTeacher(classroomId, request.auth.uid);
      allow delete: if isUserAuthenticated() && isClassroomTeacher(classroomId, request.auth.uid);

      // Join requests for classrooms
      match /joinRequests/{studentId} {
        // A student can create their own request
        allow create: if isUserAuthenticated() && isOwner(studentId);
        
        // The teacher can read and delete (approve/deny) requests
        allow read, delete: if isUserAuthenticated() && isClassroomTeacher(classroomId, request.auth.uid);
        
        // The student can read their own request status
        allow read: if isUserAuthenticated() && isOwner(studentId);
        
        // The teacher can update the status (though deleting is simpler)
        allow update: if isUserAuthenticated() && isClassroomTeacher(classroomId, request.auth.uid);
      }
    }

    // --- Meetings Collection ---
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isUserAuthenticated() && isOwner(request.resource.data.creatorId);
      allow update, delete: if isUserAuthenticated() && isMeetingCreator(meetingId, request.auth.uid);
      
      // Participants subcollection
      match /participants/{participantId} {
        allow list, read: if isUserAuthenticated(); // Allow any auth user to read participant list
        
        // A user can create their own participant document (to request entry)
        allow create: if isUserAuthenticated() && isOwner(participantId);
        
        // A user can update their own document, OR the host can update any
        allow update: if isUserAuthenticated() && (isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid));
        
        // A user can delete their own document (leave), OR the host can remove anyone
        allow delete: if isUserAuthenticated() && (isOwner(participantId) || isMeetingCreator(meetingId, request.auth.uid));
      }
    }
    
    // --- Documents & Recordings (Library items) ---
    match /{collection=documents,recordings}/{docId} {
       allow read: if resource.data.isPrivate == false || (isUserAuthenticated() && resource.data.uploaderId == request.auth.uid);
       allow create: if isUserAuthenticated() && isOwner(request.resource.data.uploaderId);
       allow update, delete: if isUserAuthenticated() && request.auth.uid == resource.data.uploaderId;
    }
  }
}
