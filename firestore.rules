
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is a participant in a meeting
    function isParticipant(meetingId) {
      return exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
    }

    // Rules for the 'meetings' collection
    match /meetings/{meetingId} {
      // Anyone authenticated can create a meeting document (this happens on first join)
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      
      // Only participants of the meeting can read its details
      allow read: if request.auth != null && isParticipant(meetingId);
      
      // Only the host (creator) can update the main meeting document (e.g., topic)
      allow update: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid;
      
      // No one can delete a meeting document directly for safety
      allow delete: if false;

      // Rules for the 'participants' subcollection
      match /participants/{userId} {
        // Anyone authenticated can join a meeting (create their participant doc)
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // Participants can read the list of other participants
        allow read: if request.auth != null && isParticipant(meetingId);
        
        // A user can only update their own participant document
        allow update: if request.auth != null && request.auth.uid == userId;
        
        // A user can delete their own participant document (when they leave)
        // Or the host can remove a participant
        allow delete: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId == request.auth.uid);
      }
    }

    // Rules for 'documents' and 'recordings' collections
    match /{collection}/{docId} where collection in ['documents', 'recordings'] {
      // Anyone authenticated can create a document/recording record
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;

      // A user can read a document/recording if it's public, or if they are the uploader
      allow read: if request.auth != null && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);

      // A user can only update/delete a document/recording they uploaded
      allow update, delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
    }

    // Rules for FCM tokens
    match /fcmTokens/{userId} {
      // A user can only create or update their own FCM token document
      allow write: if request.auth != null && request.auth.uid == userId;
      // No one should be able to read other users' FCM tokens
      allow read: if false;
    }
  }
}
