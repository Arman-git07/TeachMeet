rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function signedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    
    // --- User Profiles ---
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      
      // User's own subcollections
      match /enrolled/{classroomId} {
        allow read: if isOwner(userId);
        // Allow teachers/creators to enroll users
        allow create, delete: if signedIn(); 
      }

      match /pendingJoinRequests/{classroomId} {
         allow read, create, delete: if isOwner(userId);
      }
    }
    
    // --- Main Collections ---
    match /documents/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
      allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }

    match /recordings/{recordingId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
      allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
    match /fcmTokens/{userId} {
        allow write: if isOwner(userId);
    }

    // --- Classrooms ---
    match /classrooms/{classroomId} {
      allow get: if signedIn();
      allow list: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.teacherId);
      allow update: if signedIn() && (isOwner(resource.data.teacherId) || isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId));
      allow delete: if signedIn() && isOwner(resource.data.teacherId);

      match /announcements/{announcementId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.authorId);
        allow delete: if signedIn() && isOwner(resource.data.authorId);
      }
      
      match /materials/{materialId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
        allow delete: if signedIn() && isOwner(resource.data.uploaderId);
      }
      
      match /assignments/{assignmentId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.creatorId);
        allow delete: if signedIn() && isOwner(resource.data.creatorId);
        
        match /submissions/{submissionId} {
          allow read, write: if signedIn();
        }
      }
      
      match /exams/{examId} {
        allow read: if signedIn();
        allow create: if signedIn() && isOwner(request.resource.data.authorId);
        allow delete: if signedIn() && isOwner(resource.data.authorId);
      }
      
       match /joinRequests/{requestId} {
        allow create: if signedIn() && request.auth.uid == request.resource.data.requesterId;
        allow read: if signedIn();
        allow update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      match /participants/{participantId} {
        allow read, write, delete: if signedIn();
      }
      
      match /teachers/{teacherId} {
        allow read, write, delete: if signedIn();
      }
    }
    
    // --- Meetings ---
    match /meetings/{meetingId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && isOwner(request.resource.data.hostId);
      allow delete: if signedIn() && isOwner(resource.data.hostId);
        
      match /joinRequests/{requestId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      }
        
      match /participants/{userId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && (isOwner(userId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId));
        allow delete: if signedIn() && (isOwner(userId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId));
      }
    }
  }
}
