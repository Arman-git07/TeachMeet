
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return request.auth.uid == userId;
    }
    
    // Teachings Collection
    match /teachings/{teachingId} {
      // READ: Any authenticated user can read any teaching document.
      // This allows for the "discover" functionality.
      allow read: if isAuthenticated();

      // CREATE: An authenticated user can create a teaching if:
      // 1. They are the creatorId in the new document.
      // 2. They are the first and only member in the members array.
      // 3. The pendingRequests array is empty.
      // 4. The creatorName is a string.
      // 5. isPublic is a boolean.
      allow create: if isAuthenticated() &&
                      request.resource.data.creatorId == request.auth.uid &&
                      request.resource.data.members == [request.auth.uid] &&
                      request.resource.data.pendingRequests == [] &&
                      request.resource.data.creatorName is string &&
                      request.resource.data.isPublic is bool;

      // UPDATE: A user can update a teaching if:
      // 1. They are updating the pendingRequests array by adding their own UID (requesting to join).
      // OR
      // 2. They are the creator of the teaching, and can:
      //    a. Update the title, description, or isPublic status.
      //    b. Manage the members and pendingRequests arrays (approve/deny).
      allow update: if isAuthenticated() && (
        // Any user can request to join
        request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])
        ||
        // The creator can manage the teaching
        isUser(resource.data.creatorId)
      );

      // DELETE: Only the creator of the teaching can delete it.
      allow delete: if isAuthenticated() && isUser(resource.data.creatorId);
    }

    // Meetings Collection
    match /meetings/{meetingId} {
      // Anyone authenticated can read meeting details (like topic/creator).
      allow read: if isAuthenticated();
      
      // The creator can create the initial meeting document.
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      
      // Any authenticated user can add/remove themselves from the members array,
      // and the host can add/remove anyone.
      allow update: if isAuthenticated();
      
      // Allow participants to create their own document within the subcollection.
      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isUser(participantId);
      }
    }
    
    // Documents Collection
    match /documents/{documentId} {
      // Allow read access to public documents, or private ones if they are the owner.
      allow read: if isAuthenticated() && (resource.data.isPrivate == false || isUser(resource.data.uploaderId));
      
      // Allow create only if the uploader is the current user.
      allow create: if isAuthenticated() && isUser(request.resource.data.uploaderId);
      
      // Allow delete only if the user is the one who uploaded it.
      allow delete: if isAuthenticated() && isUser(resource.data.uploaderId);
    }
    
    // Recordings Collection
    match /recordings/{recordingId} {
      // Allow read access to public recordings, or private ones if they are the owner.
      allow read: if isAuthenticated() && (resource.data.isPrivate == false || isUser(resource.data.uploaderId));
      
      // Allow create only if the uploader is the current user.
      allow create: if isAuthenticated() && isUser(request.resource.data.uploaderId);
      
      // Allow delete only if the user is the one who uploaded it.
      allow delete: if isAuthenticated() && isUser(resource.data.uploaderId);
    }
    
    // FCM Tokens Collection
    match /fcmTokens/{userId} {
      // A user can only read, create, or update their own FCM token document.
      allow read, write: if isUser(userId);
    }
  }
}
