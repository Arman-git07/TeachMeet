
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helper Functions ---
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // --- User Profiles ---
    // Users can read their own profile, and anyone can create one (on signup).
    // Updates are restricted to the owner.
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if signedIn();
      
      // A user can read/write/delete their own subcollections for enrolled classes and pending requests.
      match /enrolled/{classroomId} {
        allow read, write, delete: if isOwner(userId);
      }
      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    // --- Classrooms ---
    match /classrooms/{classroomId} {
      // Anyone can query for public classrooms or classrooms they are a part of.
      allow list: if signedIn();
      // Any signed-in user can read a classroom document (to check details before joining).
      allow read: if signedIn();

      // Only authenticated users can create classrooms, and they must be the teacherId.
      allow create: if signedIn() && request.resource.data.teacherId == request.auth.uid;
      
      // Only the main teacher (teacherId) can update or delete the classroom.
      allow update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      
      // --- Classroom Subcollections ---
      
      // Join Requests
      match /joinRequests/{requestId} {
        // A user can create a join request if the studentId in the request is their own UID.
        allow create: if signedIn() && request.resource.data.studentId == request.auth.uid;
        // The teacher of the class can read and delete join requests.
        allow read, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      // Participants
      match /participants/{userId} {
         // The teacher can add/remove (write/delete) participants.
         // Participants can read the list.
         allow read: if signedIn();
         allow write, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
      
      // Other subcollections (materials, announcements, etc.)
      // General rule: Teachers can write, anyone in the class (participant) can read.
      match /{subcollection}/{docId} {
        allow read: if signedIn() && get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).exists;
        allow write, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
      }
    }
    
    // --- Meetings ---
    match /meetings/{meetingId} {
        allow read, create, update: if signedIn();
        allow delete: if signedIn() && isOwner(resource.data.hostId);

        match /participants/{userId} {
            allow read, write, delete: if signedIn();
        }

        match /joinRequests/{requestId} {
          allow create: if signedIn();
          allow read, update, delete: if signedIn() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
        }
    }

    // --- General Collections for public data ---
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
      allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
    match /recordings/{recId} {
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      allow create: if signedIn() && isOwner(request.resource.data.uploaderId);
      allow delete: if signedIn() && isOwner(resource.data.uploaderId);
    }
    
     match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
