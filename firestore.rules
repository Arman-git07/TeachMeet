rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isUserAuthenticated() {
      return request.auth != null;
    }
    
    function isUserId(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function isPublicResource() {
      return resource.data.isPublic == true;
    }

    function isPrivateResourceOwner(userId) {
      return resource.data.isPrivate == true && isUserId(userId);
    }
    
    // --- Teachings ---
    match /teachings/{teachingId} {
      // READ:
      // - Anyone authenticated can read public teachings.
      // - Members of a teaching can read it, even if private.
      allow read: if isUserAuthenticated() && 
                     (isPublicResource() || request.auth.uid in resource.data.members);
      
      // CREATE:
      // - Must be authenticated.
      // - The creatorId in the new document must be the user's own ID.
      // - The user must be the only member initially.
      allow create: if isUserAuthenticated() &&
                       isUserId(request.resource.data.creatorId) &&
                       request.resource.data.members == [request.auth.uid];
                       
      // UPDATE:
      // - Update teaching details (title, description, isPublic): Only creator can do this.
      // - Join a private teaching (adding self to pendingRequests): Any authenticated user can do this for themselves.
      // - Approve/Deny requests (managing members/pendingRequests): Only the creator can do this.
      allow update: if isUserAuthenticated() && (
        // Case 1: Creator updating the teaching details.
        (isUserId(resource.data.creatorId) &&
         request.resource.data.keys().hasOnly(['title', 'description', 'isPublic'])) ||
        // Case 2: Any user requesting to join. Can only add their own UID to pendingRequests.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])) ||
        // Case 3: Creator approving or denying a request.
        (isUserId(resource.data.creatorId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests', 'members']))
      );

      // DELETE:
      // - Only the creator can delete their own teaching.
      allow delete: if isUserAuthenticated() && isUserId(resource.data.creatorId);
    }

    // --- Meetings ---
    match /meetings/{meetingId} {
      // READ: Anyone authenticated can read meeting details to join.
      allow read: if isUserAuthenticated();
      
      // CREATE: An authenticated user can create a meeting room, listing themselves as creator.
      allow create: if isUserAuthenticated() && isUserId(request.resource.data.creatorId);

      // UPDATE:
      // - Host can approve/deny by managing members and pendingRequests.
      // - Any user can request to join by adding themselves to pendingRequests.
      allow update: if isUserAuthenticated() && (
        (isUserId(resource.data.creatorId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasAny(['pendingRequests', 'members'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests']) &&
         request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid]))
      );
      
      // DELETE: Not typically allowed from client. Meetings expire or are cleared by a backend process.
      allow delete: if false;

      // Participants can join/leave the subcollection
      match /participants/{userId} {
        allow read, write: if isUserId(userId);
      }
    }

    // --- Documents & Recordings ---
    function isResourceOwner() {
      return isUserId(resource.data.uploaderId);
    }

    match /{collection}/{docId} {
      // READ: Anyone can read public items. Only owner can read their private items.
      allow read: if isUserAuthenticated() && (isPublicResource() || isPrivateResourceOwner(request.auth.uid));
      
      // CREATE: Authenticated user must be the uploader.
      allow create: if isUserAuthenticated() && isUserId(request.resource.data.uploaderId);
      
      // DELETE: Only the owner can delete.
      allow delete: if isUserAuthenticated() && isResourceOwner();
      
      // UPDATE: Not allowed from client to prevent tampering.
      allow update: if false;
    }
    
    // --- FCM Tokens ---
    match /fcmTokens/{userId} {
      allow read, write: if isUserId(userId);
    }
  }
}
