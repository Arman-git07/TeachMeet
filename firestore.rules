
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    
    function getRole(classroomId) {
      let role = get(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid)).data.role;
      if (role == null) {
        return "none";
      }
      return role;
    }
    
    function isCreator(classroomId) {
       return request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId;
    }

    function isTeacher(classroomId) {
        return getRole(classroomId) in ["creator", "teacher"];
    }

    function isEnrolled(classroomId) {
      return exists(/databases/$(database)/documents/classrooms/$(classroomId)/participants/$(request.auth.uid));
    }
    
    // USERS
    match /users/{userId} {
        // Anyone can read user profiles (for names, avatars etc.)
        allow read: if isAuth();
        // Only the user themselves can create or update their profile
        allow write: if isAuth() && request.auth.uid == userId;
    }
    
    match /users/{userId}/{subcollection}/{docId} {
        // User can manage their own subcollections (e.g., enrolled classes, pending requests)
        allow read, write, delete: if isAuth() && request.auth.uid == userId;
    }

    // CLASSROOMS
    match /classrooms/{classroomId} {
      // Anyone authenticated can create a classroom
      allow create: if isAuth() && request.resource.data.teacherId == request.auth.uid;
      
      // Enrolled members can read, only creator can update/delete
      allow read: if isAuth() && (isEnrolled(classroomId) || resource.data.isPublic == true);
      allow update, delete: if isAuth() && isCreator(classroomId);

      // Subcollections for a classroom
      match /{subcollection}/{docId} {
        // Teachers/creators can create/delete content
        allow create, delete: if isAuth() && isTeacher(classroomId);
        // Enrolled members can read content
        allow read: if isAuth() && isEnrolled(classroomId);
        // Only the original uploader or a manager can update
        allow update: if isAuth() && (request.auth.uid == resource.data.uploaderId || isTeacher(classroomId));
      }
      
      // Join Requests subcollection
      match /joinRequests/{userId} {
        // Anyone can create their own join request
        allow create: if isAuth() && request.auth.uid == userId;
        // Only the creator can read/delete requests
        allow read, delete: if isAuth() && isCreator(classroomId);
      }
      
      // Participants subcollection
      match /participants/{userId} {
        // Only the creator can add/remove participants
        allow write, delete: if isAuth() && isCreator(classroomId);
        // All enrolled members can see the participant list
        allow read: if isAuth() && isEnrolled(classroomId);
      }
      
      // Teachers subcollection (for subject teachers)
      match /teachers/{userId} {
         allow read: if isAuth() && isEnrolled(classroomId);
         allow write, delete: if isAuth() && isCreator(classroomId);
      }

      // Assignment Submissions
      match /assignments/{assignmentId}/submissions/{studentId} {
        // The specific student can create/update their own submission
        allow create, update: if isAuth() && request.auth.uid == studentId;
        // Teachers/creators can read/update (for grading)
        allow read, update: if isAuth() && isTeacher(classroomId);
      }
    }
    
    // Documents & Recordings
    match /{collectionName=**}/{docId} {
        // Rules for top-level 'documents' and 'recordings' collections
        allow create: if isAuth() && request.resource.data.uploaderId == request.auth.uid;
        allow read: if isAuth() && (resource.data.isPrivate == false || resource.data.uploaderId == request.auth.uid);
        allow update, delete: if isAuth() && resource.data.uploaderId == request.auth.uid;
    }
  }
}
