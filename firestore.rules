rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /classrooms/{classId} {
      allow read: if true;

      // Classroom creator can always manage their class
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy == request.auth.uid;

      // Materials subcollection
      match /materials/{materialId} {
        allow read: if true;

        // Create: any signed-in user can post
        allow create: if request.auth != null;

        // Delete: allowed if user is either
        // 1. the owner of the material (uploaderId field in doc)
        // 2. the creator of the classroom (createdBy field in parent doc)
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      // Announcements subcollection
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      // Assignments subcollection
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      // Exams subcollection
      match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }
      
      // Submissions sub-subcollection
       match /assignments/{assignmentId}/submissions/{submissionId} {
        allow read, create, update: if request.auth != null;
        allow delete: if request.auth != null && (
            request.auth.uid == resource.data.studentId ||
            request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
            );
        }
    }
  }
}
