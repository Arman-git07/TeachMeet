rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is the host of a meeting
    function isMeetingHost(meetingId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
    }

    // Classroom rules
    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.teacherId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.teacherId;

      // Rules for subcollections within a classroom
      match /{subcollection}/{docId} {
        // Teachers and the creator can manage most subcollections
        allow read, write, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teachers;
      }
      
      match /submissions/{submissionId} {
         allow create: if request.auth != null; // Any authenticated user can submit
         allow read, update, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid; // Only teacher can manage
      }
    }

    // Meetings collection
    match /meetings/{meetingId} {
      // An authenticated user can create a meeting if they set themselves as the host.
      // This is the key rule to fix the host join issue.
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;

      // Any authenticated user can read the main meeting document (to check if it exists, etc.)
      allow read: if request.auth != null;

      // Only the host can update or delete the main meeting document.
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;

      // Participants subcollection
      match /participants/{participantId} {
        // A user can only create their own participant document.
        allow create: if request.auth != null && request.auth.uid == participantId;
        
        // Any authenticated user in the meeting can see other participants.
        allow read: if request.auth != null;
        
        // A user can only update or delete their own participant document.
        // Or the host of the meeting can update/delete any participant.
        allow update, delete: if request.auth != null && (request.auth.uid == participantId || isMeetingHost(meetingId));
      }

      // Join Requests subcollection
      match /joinRequests/{requestId} {
        // Any authenticated user can create a request to join.
        allow create: if request.auth != null && request.auth.uid == requestId;
        
        // Only the host can read or delete join requests.
        allow read, delete: if request.auth != null && isMeetingHost(meetingId);
      }
    }
    
    // Documents collection
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // Recordings collection
    match /recordings/{recordingId} {
       allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
       allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
       allow update, delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // User data collections
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      match /pendingJoinRequests/{classroomId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /enrolled/{classroomId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }
    
     // FCM tokens
    match /fcmTokens/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
