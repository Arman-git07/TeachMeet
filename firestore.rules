
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isUserOwner(userId) {
      return request.auth.uid == userId;
    }

    function isUserInList(list) {
      return request.auth.uid in list;
    }

    // FCM Tokens: Users can only manage their own token
    match /fcmTokens/{userId} {
      allow read, write: if isUserOwner(userId);
    }
    
    // Meetings: Rules for creating, joining, and managing meetings
    match /meetings/{meetingId} {
      // READ: Anyone authenticated can read meeting details to check for existence, etc.
      allow read: if isUserAuthenticated();

      // CREATE: Any authenticated user can create a meeting.
      // They must set themselves as the creator and provide a topic.
      // 'members' array is not allowed on create.
      allow create: if isUserAuthenticated()
                      && request.resource.data.creatorId == request.auth.uid
                      && request.resource.data.topic is string
                      && !('members' in request.resource.data);

      // UPDATE: Complex rules for updating a meeting document.
      allow update: if isUserAuthenticated()
                      // Rule 1: The creator (host) can update topic, add members, or remove pending requests.
                      && (
                        isUserOwner(resource.data.creatorId)
                        && (
                          request.resource.data.topic != resource.data.topic ||
                          request.resource.data.members == resource.data.members.concat(request.resource.data.pendingRequests) ||
                          request.resource.data.pendingRequests.size() < resource.data.pendingRequests.size()
                        )
                      )
                      // Rule 2: An authenticated user can add themselves (and only themselves) to the pendingRequests array.
                      || (
                        request.resource.data.pendingRequests == resource.data.pendingRequests.concat([request.auth.uid])
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingRequests'])
                      );
                      
      // DELETE: Only the creator of the meeting can delete it.
      allow delete: if isUserAuthenticated() && isUserOwner(resource.data.creatorId);

      // Participants Subcollection
      match /participants/{userId} {
        // READ/LIST: Any authenticated user in the meeting can see who else is there.
        allow read: if isUserAuthenticated();
        
        // CREATE: Any authenticated user can create their own participant document.
        allow create: if isUserAuthenticated() && isUserOwner(userId);
        
        // UPDATE/DELETE: Users can only update or delete their own participant document.
        allow update, delete: if isUserAuthenticated() && isUserOwner(userId);
      }
    }
    
    // Recordings and Documents
    match /{collection}/{docId} {
        // READ: User can read any public document/recording, or any private one they own.
        allow read: if isUserAuthenticated()
                    && (resource.data.isPrivate == false || isUserOwner(resource.data.uploaderId));
        
        // CREATE: User can create a document/recording and must set themselves as the uploader.
        allow create: if isUserAuthenticated() && isUserOwner(request.resource.data.uploaderId);
        
        // UPDATE/DELETE: User can only update or delete a document/recording they uploaded.
        allow update, delete: if isUserAuthenticated() && isUserOwner(resource.data.uploaderId);
    }
  }
}
