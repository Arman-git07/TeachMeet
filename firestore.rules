rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Meetings Collection
    match /meetings/{meetingId} {
      // Host can create a meeting if the hostId matches their UID.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.hostId;

      // Anyone signed in can read the meeting details.
      allow read: if request.auth != null;

      // Only the host can update or delete the meeting document.
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostId;

      // Participants Subcollection
      match /participants/{participantId} {
        // A signed-in user can add themselves as a participant.
        // The host can add themselves, and guests can be added by the host (not implemented yet, but rule is ready).
        allow create: if request.auth != null && request.auth.uid == participantId;
        
        // Anyone signed-in can read the list of participants.
        allow read: if request.auth != null;

        // A user can only update or delete their own participant document.
        allow update, delete: if request.auth != null && request.auth.uid == participantId;
      }

      // Join Requests Subcollection
      match /joinRequests/{userId} {
        // A signed-in user can create a request for themselves.
        allow create: if request.auth != null && request.auth.uid == userId;

        // The host can read and delete join requests.
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId == request.auth.uid;
      }
    }

    // Users collection (for profile info, enrolled classes, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classrooms collection
    match /classrooms/{classroomId} {
        // Teachers/owners can create and manage. Students can read.
        allow read: if request.auth != null;
        allow write: if request.auth != null && (resource.data.teacherId == request.auth.uid || request.auth.uid in resource.data.teachers);
        
        // Subcollections within classrooms
        match /{subcollection}/{docId} {
            // General rule: allow read for authenticated users
            allow read: if request.auth != null;

            // Allow create for authenticated users (specific logic should be in cloud functions or client)
            allow create: if request.auth != null;

            // Update/delete only by the creator/author or a classroom manager
            allow update, delete: if request.auth != null && 
                                     (request.auth.uid == resource.data.authorId || 
                                      request.auth.uid == resource.data.creatorId ||
                                      request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId);
        }
    }
    
    // Documents & Recordings: can be read if public, or if the user is the owner.
    match /documents/{docId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
  }
}
