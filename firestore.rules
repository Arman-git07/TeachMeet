
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if a user is the owner of a resource
    function isOwner(resource) {
      return request.auth.uid == resource.data.uploaderId || request.auth.uid == resource.data.creatorId;
    }

    // Rules for Meetings
    match /meetings/{meetingId} {
      // Anyone authenticated can create a new meeting document
      allow create: if isAuthenticated();
      // Only participants of the meeting can read or update it
      allow read, update: if isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
      // Only the creator of the meeting can delete it (future-proofing)
      allow delete: if isAuthenticated() && isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)));

      // Rules for Participants subcollection
      match /participants/{participantId} {
        // Any authenticated user can join a meeting (create their participant doc)
        // A user can only create their own participant document
        allow create: if isAuthenticated() && request.auth.uid == participantId;
        // Any authenticated user in the meeting can see other participants
        allow read: if isAuthenticated() && exists(/databases/$(database)/documents/meetings/$(meetingId)/participants/$(request.auth.uid));
        // A user can only update or delete their own participant document
        allow update, delete: if isAuthenticated() && request.auth.uid == participantId;
      }
    }

    // Rules for Documents
    match /documents/{documentId} {
      allow create: if isAuthenticated();
      // Allow read if the document is public, or if the user is the owner of a private doc
      allow read: if resource.data.isPrivate == false || isOwner(resource);
      // Allow update/delete only if the user is the owner
      allow update, delete: if isOwner(resource);
    }
    
    // Rules for Recordings
    match /recordings/{recordingId} {
      allow create: if isAuthenticated();
      allow read: if resource.data.isPrivate == false || isOwner(resource);
      allow update, delete: if isOwner(resource);
    }
    
    // Rules for Teachings
    match /teachings/{teachingId} {
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.creatorId;
      // Only the creator can read, update, or delete their own teachings
      allow read, update, delete: if isAuthenticated() && isOwner(resource);
    }
    
    // Rules for FCM tokens
    match /fcmTokens/{userId} {
        // A user can only create, read, or update their own FCM token document
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
