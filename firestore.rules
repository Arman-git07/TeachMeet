rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /classrooms/{classId} {
      allow read: if true;

      // Classroom creator can always manage their class
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;

      // ---- Announcements ----
      match /announcements/{announcementId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId ||      // person who posted (uses creatorId)
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy // classroom creator
        );
      }

      // ---- Materials ----
      match /materials/{materialId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      // ---- Assignments ----
      match /assignments/{assignmentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId || // assignments use creatorId
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );

        match /submissions/{submissionId} {
            allow create, update: if request.auth != null && request.resource.data.studentId == request.auth.uid;
            allow read: if request.auth != null && (request.auth.uid == resource.data.studentId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy);
            allow delete: if request.auth != null && (request.auth.uid == resource.data.studentId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy);
        }
      }

      // ---- Exams ----
      match /exams/{examId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.creatorId || // exams use creatorId
          request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classId)).data.createdBy
        );
      }

      // Other subcollections
       match /joinRequests/{requestId} {
        allow read, write: if request.auth != null;
      }
      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }
       match /teachers/{teacherId} {
        allow read, write: if request.auth != null;
      }
    }

     match /users/{userId}/{allSubcollections=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
