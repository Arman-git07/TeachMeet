/**
 * @description This ruleset enforces a role-based access control model for meetings and join requests.
 *   Only the host of a meeting can approve or reject join requests. Participants can be added to meetings
 *   by the host.
 * @dataStructure
 *   /meetings/{meetingId} : Meeting documents, containing meeting metadata.
 *   /meetings/{meetingId}/joinRequests/{requestId} : Join requests for a specific meeting.
 *   /meetings/{meetingId}/participants/{userId} : Participants in a specific meeting.
 *   /classrooms/{classroomId}/joinRequests/{userId} : Join requests for a specific classroom.
 *   /classrooms/{classroomId}/participants/{userId} : Participants in a specific classroom.
 * @keySecurityDecisions
 *   - Only the host can manage join requests (approve/reject).
 *   - Anyone can read meeting and participant data (public read).
 *   - Denormalization: `hostId` on the `Meeting` document is used for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    function isExistingOwner(hostId) {
      return isOwner(hostId) && resource != null;
    }

    /**
     * @description Allows reading meeting details. Write access is restricted to the host.
     * @path /meetings/{meetingId}
     * @allow (get, list): if true
     * @allow (create): if request.auth.uid == request.resource.data.hostId
     * @allow (update, delete): if isExistingOwner(resource.data.hostId)
     * @deny (create, update, delete): if the request.auth.uid does not match the meeting's hostId.
     * @principle Public read with owner-only writes.  The host must be the owner to modify.
     */
    match /meetings/{meetingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.hostId);
      allow delete: if isExistingOwner(resource.data.hostId);
    }

    /**
     * @description Allows the host to manage join requests for a specific meeting.
     * @path /meetings/{meetingId}/joinRequests/{requestId}
     * @allow (get, list): if true
     * @allow (create): if false;
     * @allow (update): if isExistingOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
     * @allow (delete): if isExistingOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
     * @deny: create if true; only the server should create these
     * @principle Host-only management of join requests.
     */
    match /meetings/{meetingId}/joinRequests/{requestId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostId);
    }

    /**
     * @description Allows reading participant details. Write access is open to allow adding participants.
     * @path /meetings/{meetingId}/participants/{userId}
     * @allow (get, list): if true
     * @allow (create): if true;
     * @allow (update): if true;
     * @allow (delete): if true;
     * @principle Public read and write for participants.
     */
    match /meetings/{meetingId}/participants/{userId} {
      allow get, list: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    /**
     * @description Allows the host to manage join requests for a specific classroom.
     * @path /classrooms/{classroomId}/joinRequests/{requestId}
     * @allow (get, list): if true
     * @allow (create): if false;
     * @allow (update): if isExistingOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId);
     * @allow (delete): if isExistingOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId);
     * @deny: create if true; only the server should create these
     * @principle Host-only management of join requests.
     */
       match /classrooms/{classroomId}/joinRequests/{requestId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/classrooms/$(classroomId)).data.hostId);
    }
    /**
     * @description Allows reading participant details. Write access is open to allow adding participants.
     * @path /classrooms/{classroomId}/participants/{userId}
     * @allow (get, list): if true
     * @allow (create): if true;
     * @allow (update): if true;
     * @allow (delete): if true;
     * @principle Public read and write for participants.
     */
    match /classrooms/{classroomId}/participants/{userId} {
      allow get, list: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
  }
}