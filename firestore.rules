rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    // ===== USERS =====
    match /users/{userId} {
      // Users can read/write their own document, e.g. for profile updates
      allow read, write: if isOwner(userId);

      // --- USER SUBCOLLECTIONS ---
      // These rules secure the lists of teachings a user has created or enrolled in.
      // Only the user themselves can read or modify these lists.
      match /myTeachings/{teachingId} {
        allow read, write, delete: if isOwner(userId);
      }
      match /enrolledTeachings/{teachingId} {
        allow read, write, delete: if isOwner(userId);
      }
    }
    
    // ===== MEETINGS =====
    match /meetings/{meetingId} {
      allow read: if isUserAuthenticated();
      allow create: if isOwner(request.resource.data.creatorId);
      // Allow update for adding pendingRequests by any authenticated user
      allow update: if isUserAuthenticated(); 
      allow delete: if isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);

      match /participants/{participantId} {
        allow read, list: if isUserAuthenticated();
        allow create, update: if isOwner(participantId);
        allow delete: if isOwner(participantId) || isOwner(get(/databases/$(database)/documents/meetings/$(meetingId)).data.creatorId);
      }
    }

    // ===== TEACHINGS =====
    // This is the global collection where all teaching documents are stored.
    match /teachings/{teachingId} {
      // Allow read if the teaching is public OR if the user is the creator OR if they are in the allowedStudents list.
      allow read: if resource.data.isPublic == true ||
                    isOwner(resource.data.creatorId) ||
                    (resource.data.allowedStudents != null && request.auth.uid in resource.data.allowedStudents);
      
      // Allow any authenticated user to create a teaching, as long as they set themselves as the creator.
      allow create: if isUserAuthenticated() && request.resource.data.creatorId == request.auth.uid;

      // Allow updates only by the creator. This includes adding students to `allowedStudents` and changing `pendingRequests`.
      allow update: if isOwner(resource.data.creatorId);

      // Allow deletion only by the creator.
      allow delete: if isOwner(resource.data.creatorId);
    }
    
    // ===== DOCUMENTS & RECORDINGS =====
    // These rules are for user-uploaded files.
    match /{collection}/{docId} {
      // Allow read if the document is not private, or if the user is the one who uploaded it.
      allow read: if resource.data.isPrivate == false || isOwner(resource.data.uploaderId);
      
      // Allow creation by any authenticated user, as long as they set themselves as the uploader.
      allow create: if isUserAuthenticated() && request.resource.data.uploaderId == request.auth.uid;
      
      // Allow updates and deletes only by the uploader.
      allow update, delete: if isOwner(resource.data.uploaderId);
    }

    // ===== FCM TOKENS =====
    // For push notifications
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
