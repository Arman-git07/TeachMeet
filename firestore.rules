rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Allow users to read their own profile, but not others
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
    }

    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // Allow creator or teachers to manage participants
      match /participants/{participantId} {
        allow read: if true;
        allow create, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid;
      }
      
      // Allow students to send join requests, creator/teachers to manage them
      match /joinRequests/{requestId} {
        allow create: if request.auth != null && request.auth.uid == requestId;
        allow read, delete: if request.auth != null && get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy == request.auth.uid;
      }

      // Teachers can post announcements, creator can delete any
      match /announcements/{announcementId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.creatorId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy);
      }

      // Teachers can add materials, creator can delete any
      match /materials/{materialId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.uploaderId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy);
      }
      
      // Teachers can add assignments, creator can delete any
      match /assignments/{assignmentId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.creatorId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy);
        
        // Students can submit, teachers can grade
        match /submissions/{submissionId} {
            allow create, update: if request.auth != null;
            allow read: if true;
        }
      }
      
      // FINAL FIX: Teachers can add exams. Creator or the uploader can delete them.
      match /exams/{examId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.creatorId || request.auth.uid == get(/databases/$(database)/documents/classrooms/$(classroomId)).data.createdBy);
      }
    }

    // Rules for meetings
    match /meetings/{meetingId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null;

      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }

      match /joinRequests/{userId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow read, delete: if request.auth != null; // Host can manage
      }
    }
    
    // Rules for user-specific data
    match /users/{userId}/{subcollection}/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Rules for documents and recordings library
    match /documents/{documentId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    match /recordings/{recordingId} {
      allow read: if resource.data.isPrivate == false || (request.auth != null && request.auth.uid == resource.data.uploaderId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploaderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uploaderId;
    }
    
    // FCM Tokens
    match /fcmTokens/{userId} {
        allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
